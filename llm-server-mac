    local cache
    cache="$(mac_tune_cache_path)"
    if [[ -f "$cache" && "$RETUNE" == "0" ]]; then
        mac_load_tune_cache && return 0
    fi

    local rounds="${USER_TUNE_ROUNDS:-8}"
    [[ "$rounds" =~ ^[0-9]+$ ]] || rounds=8
    (( rounds < 1 )) && rounds=1
    (( rounds > 30 )) && rounds=30

    echo ""
    echo "═══ macOS AI Tune — Metal-safe flag optimization ═══"
    echo "  Model: $MODEL_NAME"
    echo "  Rounds: $rounds"
    echo "  Scope: batch, ubatch, KV type, threads, parallel, flash-attn"
    echo ""

    if [[ "${LLM_SERVER_TEST_MAC_AI_TUNE_CACHE_ONLY:-0}" == "1" ]]; then
        echo "macOS AI Tune test hook: skipping live tuning."
        return 0
    fi

    echo "Round 0/$rounds: starting baseline..."
    if ! try_start; then
        echo "ERROR: baseline macOS config failed to start; fallback launch will handle it."
        return 1
    fi
    local bench baseline_gen baseline_pp best_gen best_pp best_name best_flags all_results
    bench=$(mac_bench_gen_tps)
    baseline_gen=$(awk '{print $1}' <<< "$bench")
    baseline_pp=$(awk '{print $2}' <<< "$bench")
    best_gen="$baseline_gen"
    best_pp="$baseline_pp"
    best_name="baseline"
    best_flags="{}"
    all_results="[]"
    echo "  Baseline: gen=${baseline_gen} tok/s  pp=${baseline_pp} tok/s"

    local round
    for (( round=1; round<=rounds; round++ )); do
        local prompt_file proposal name flags_json reasoning
        prompt_file="$(mktemp -t llm-mac-tune-prompt.XXXXXX)"
        cat > "$prompt_file" <<EOF
Hardware:
- CPU: $CPU_BRAND
- Performance cores: $PERF_CORES
- Physical cores: $PHYSICAL_CORES
- Unified memory total MB: $RAM_TOTAL_MB
- Available memory MB: $RAM_AVAIL_MB
- Metal GPU: ${METAL_GPU_NAME:-none}

Model:
- Name: $MODEL_NAME
- Size MB: $TOTAL_SIZE_MB
- Layers: $LAYER_COUNT
- Experts: $EXPERT_COUNT
- Context: $CTX_SIZE
- Strategy: $STRATEGY

Current best:
- Name: $best_name
- Generation tok/s: $best_gen
- Prompt tok/s: $best_pp

Allowed flags only:
$(mac_allowed_tune_flags_json)

Rules:
- Prefer stable Apple Silicon Metal settings.
- Do not use CUDA, tensor split, device placement, mmap, mlock, or model path flags.
- Keep memory conservative. If unsure, reduce -b/-ub or use q8_0/f16 KV.
- Respond only JSON: {"name":"short_name","flags":{"-b":1024,"-ub":512},"reasoning":"why"}.
EOF
        proposal="$(mac_query_llm_for_flags "$prompt_file")"
        rm -f "$prompt_file"
        name=$(python3 -c 'import json,sys; d=json.load(sys.stdin); print(d.get("name") or "config")' <<< "$proposal" 2>/dev/null || echo "config")
        flags_json=$(python3 -c 'import json,sys; d=json.load(sys.stdin); print(json.dumps(d.get("flags") or {}))' <<< "$proposal" 2>/dev/null || echo "{}")
        reasoning=$(python3 -c 'import json,sys; d=json.load(sys.stdin); print(d.get("reasoning") or "")' <<< "$proposal" 2>/dev/null || echo "")

        echo "Round $round/$rounds: $name"
        [[ -n "$reasoning" ]] && echo "  Reason: $reasoning"
        echo "  Flags: $flags_json"

        kill_server "$RUNNING_PID"
        sleep 1
        local gen="0" pp="0" status="ok"
        if mac_try_start_with_flags_json "$flags_json"; then
            bench=$(mac_bench_gen_tps)
            gen=$(awk '{print $1}' <<< "$bench")
            pp=$(awk '{print $2}' <<< "$bench")
            echo "  Result: gen=${gen} tok/s  pp=${pp} tok/s"
            if python3 -c "import sys; sys.exit(0 if float('$gen') > float('$best_gen') else 1)" 2>/dev/null; then
                best_gen="$gen"
                best_pp="$pp"
                best_name="$name"
                best_flags="$flags_json"
                echo "  New best."
            fi
            kill_server "$RUNNING_PID"
            sleep 1
        else
            status="crashed"
            echo "  Result: crashed or failed health check"
            kill_server ""
        fi
        all_results=$(RESULT_FLAGS="$flags_json" RESULT_NAME="$name" RESULT_STATUS="$status" RESULT_ROUND="$round" RESULT_GEN="$gen" RESULT_PP="$pp" python3 -c '
import json, os, sys
rows = json.loads(sys.stdin.read())
try:
    flags = json.loads(os.environ.get("RESULT_FLAGS") or "{}")
except json.JSONDecodeError:
    flags = {}
rows.append({
    "round": int(os.environ["RESULT_ROUND"]),
    "name": os.environ["RESULT_NAME"],
    "gen_tps": float(os.environ["RESULT_GEN"]),
    "pp_tps": float(os.environ["RESULT_PP"]),
    "flags": flags,
    "status": os.environ["RESULT_STATUS"],
})
print(json.dumps(rows))
' <<< "$all_results")

        if (( round < rounds )); then
            try_start || { echo "ERROR: cannot restart baseline for next mac AI Tune round"; break; }
        fi
    done

    kill_server "$RUNNING_PID"
    kill_server ""

    BEST_FLAGS="$best_flags" ALL_RESULTS="$all_results" TUNE_CACHE="$cache" TUNE_MODEL="$MODEL_NAME" TUNE_BEST_NAME="$best_name" TUNE_BASE_GEN="$baseline_gen" TUNE_BASE_PP="$baseline_pp" TUNE_BEST_GEN="$best_gen" TUNE_BEST_PP="$best_pp" TUNE_ROUNDS="$rounds" python3 -c '
import json, os
from datetime import datetime, timezone
best_flags = json.loads(os.environ.get("BEST_FLAGS") or "{}")
all_results = json.loads(os.environ.get("ALL_RESULTS") or "[]")
cache = {
    "model": os.environ["TUNE_MODEL"],
    "tuned_at": datetime.now(timezone.utc).isoformat().replace("+00:00", "Z"),
    "provider": "self-mac-metal",
    "baseline_gen_tps": float(os.environ["TUNE_BASE_GEN"]),
    "baseline_pp_tps": float(os.environ["TUNE_BASE_PP"]),
    "best_config": {
        "name": os.environ["TUNE_BEST_NAME"],
        "flags": best_flags,
        "gen_tps": float(os.environ["TUNE_BEST_GEN"]),
        "pp_tps": float(os.environ["TUNE_BEST_PP"]),
    },
    "rounds": int(os.environ["TUNE_ROUNDS"]),
    "all_results": all_results,
}
with open(os.environ["TUNE_CACHE"], "w", encoding="utf-8") as f:
    json.dump(cache, f, indent=2)
print("Saved macOS AI Tune cache: {}".format(os.environ["TUNE_CACHE"]))
'
    mac_load_tune_cache || true
}

run_benchmark() {
    local url="http://127.0.0.1:${PORT}"
    echo ""
    echo "═══ Benchmark ═══"

    local result
    result=$(curl -sf "$url/v1/chat/completions" \
        -H "Content-Type: application/json" \
        -d '{"model":"test","messages":[{"role":"user","content":"Explain the theory of relativity in simple terms. Cover special and general relativity, time dilation, and gravitational effects."}],"max_tokens":200,"temperature":0.1}' 2>/dev/null)

    if [[ -z "$result" ]]; then
        echo "Benchmark failed — server not responding"
        return 1
    fi

    local pp_tokens tg_tokens
    pp_tokens=$(echo "$result" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('usage',{}).get('prompt_tokens',0))" 2>/dev/null)
    tg_tokens=$(echo "$result" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('usage',{}).get('completion_tokens',0))" 2>/dev/null)

    local rates timings pp_rate tg_rate
    rates=$(echo "$result" | python3 -c "
import sys,json
d=json.load(sys.stdin)
t=d.get('timings') or {}
pp=t.get('prompt_per_second') or 0
tg=t.get('predicted_per_second') or 0
print(f'{float(pp):.1f} {float(tg):.1f}' if pp and tg else '')
" 2>/dev/null || true)
    if [[ -n "$rates" ]]; then
        read -r pp_rate tg_rate <<< "$rates"
        echo "  Prompt processing: ${pp_tokens:-?} tokens @ ${pp_rate:-?} tok/s"
        echo "  Generation:        ${tg_tokens:-?} tokens @ ${tg_rate:-?} tok/s"
    else
        timings=$(curl -sf "$url/slots" 2>/dev/null || true)
    if [[ -n "$timings" ]]; then
        pp_rate=$(echo "$timings" | python3 -c "
import sys,json
d=json.load(sys.stdin)
s=d[0] if isinstance(d,list) else d
t_pp = s.get('t_prompt_processing', 0)
n_pp = s.get('n_prompt_tokens_processed', 1)
if t_pp > 0: print(f\"{n_pp / (t_pp / 1000):.1f}\")
else: print('?')
" 2>/dev/null)
        tg_rate=$(echo "$timings" | python3 -c "
import sys,json
d=json.load(sys.stdin)
s=d[0] if isinstance(d,list) else d
t_gen = s.get('t_token_generation', 0)
n_gen = s.get('n_decoded', 1)
if t_gen > 0: print(f\"{n_gen / (t_gen / 1000):.1f}\")
else: print('?')
" 2>/dev/null)
        echo "  Prompt processing: ${pp_tokens:-?} tokens @ ${pp_rate:-?} tok/s"
        echo "  Generation:        ${tg_tokens:-?} tokens @ ${tg_rate:-?} tok/s"
    else
        echo "  Prompt tokens: ${pp_tokens:-?}"
        echo "  Generated tokens: ${tg_tokens:-?}"
    fi
    fi
    echo ""
    echo "Benchmark complete. Shutting down server..."
    kill_server ""
    exit 0
}

