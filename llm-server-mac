mac_allowed_tune_flags_json() {
    cat <<'JSON'
["-b","-ub","--cache-type-k","--cache-type-v","--threads","--threads-batch","--parallel","--flash-attn"]
JSON
}

mac_apply_tune_flags_json() {
    local flags_json="$1"
    local records=()
    while IFS= read -r line; do
        [[ -n "$line" ]] && records+=("$line")
    done < <(FLAGS_JSON="$flags_json" python3 -c '
import json, os
try:
    flags = json.loads(os.environ.get("FLAGS_JSON", "{}"))
except json.JSONDecodeError:
    flags = {}
if not isinstance(flags, dict):
    flags = {}
aliases = {
    "--batch-size": "-b",
    "--ubatch-size": "-ub",
    "-fa": "--flash-attn",
    "-t": "--threads",
    "-tb": "--threads-batch",
    "-np": "--parallel",
}
allowed = {"-b","-ub","--cache-type-k","--cache-type-v","--threads","--threads-batch","--parallel","--flash-attn"}
for k, v in flags.items():
    if not isinstance(k, str):
        continue
    k = aliases.get(k, k)
    if k not in allowed or v is False or v is None or v == "":
        continue
    print("K\t" + k)
    print("F\t" + k)
    if v is not True:
        print("F\t" + str(v))
')

    (( ${#records[@]} == 0 )) && return 1

    local override_keys=() extras=() rec kind value
    for rec in "${records[@]}"; do
        IFS=$'\t' read -r kind value <<< "$rec"
        case "$kind" in
            K) override_keys+=("$value") ;;
            F) extras+=("$value") ;;
        esac
    done

    local deduped=()
    local skip_next=0 i flag key dominated
    for (( i=0; i<${#COMMON_FLAGS[@]}; i++ )); do
        if (( skip_next )); then
            skip_next=0
            continue
        fi
        flag="${COMMON_FLAGS[$i]}"
        dominated=0
        for key in "${override_keys[@]}"; do
            if [[ "$flag" == "$key" ]]; then
                dominated=1
                if (( i + 1 < ${#COMMON_FLAGS[@]} )) && [[ "${COMMON_FLAGS[$((i+1))]}" != -* ]]; then
                    skip_next=1
                fi
                break
            fi
        done
        (( dominated )) || deduped+=("$flag")
    done
    COMMON_FLAGS=("${deduped[@]}" "${extras[@]}")
}

mac_load_tune_cache() {
    local cache="${EXPLICIT_TUNE_CACHE:-$(mac_tune_cache_path)}"
    [[ -f "$cache" ]] || return 1
    local flags_json
    flags_json=$(TUNE_CACHE="$cache" MODEL_NAME="$MODEL_NAME" python3 -c '
import json, os, sys
try:
    with open(os.environ["TUNE_CACHE"], encoding="utf-8") as f:
        data = json.load(f)
except Exception as exc:
    print(f"Error: invalid tune cache: {exc}", file=sys.stderr)
    sys.exit(2)
if data.get("model") != os.environ["MODEL_NAME"]:
    print("Error: tune cache is for {}, not {}".format(data.get("model") or "?", os.environ["MODEL_NAME"]), file=sys.stderr)
    sys.exit(2)
best = data.get("best_config") or {}
flags = best.get("flags") or {}
if not isinstance(flags, dict):
    flags = {}
print(json.dumps(flags))
' 2>/dev/null) || return 1
    if mac_apply_tune_flags_json "$flags_json"; then
        TUNE_LOADED=1
        echo "Using macOS AI-tuned config: $(basename "$cache")"
        return 0
    fi
    return 1
}

