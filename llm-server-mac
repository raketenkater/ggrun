# Section 6: Helper Functions
# ═══════════════════════════════════════════════════════════════

kill_server() {
    local pid=${1:-}
    if [[ -n "$pid" ]] && kill -0 "$pid" 2>/dev/null; then
        kill -9 "$pid" 2>/dev/null || true
        wait "$pid" 2>/dev/null || true
    fi
    # Port cleanup
    local port_pids
    port_pids=$(lsof -t -i:"${PORT}" 2>/dev/null) || true
    if [[ -n "$port_pids" ]]; then
        kill -9 $port_pids 2>/dev/null || true
    fi
    local w=0
    while (( w < 10 )); do
        lsof -i:"${PORT}" >/dev/null 2>&1 || break
        sleep 1; (( w++ ))
    done
    sleep 1
}

RUNNING_PID=""
try_start() {
    local extra_flags=("$@")
    RUNNING_PID=""
    "$LLAMA_SERVER" "${COMMON_FLAGS[@]}" "${extra_flags[@]}" > >(tee -a "$SERVER_LOG") 2>&1 &
    local pid=$!
    local i=0
    while (( i < 240 )); do
        if curl -sf "http://127.0.0.1:${PORT}/health" >/dev/null 2>&1; then
            RUNNING_PID=$pid
            return 0
        fi
        if ! kill -0 "$pid" 2>/dev/null; then
            return 1
        fi
        sleep 1; (( i++ ))
    done
    kill -9 "$pid" 2>/dev/null || true
    wait "$pid" 2>/dev/null || true
    return 1
}

print_cmd() {
    echo ""
    echo "Command:"
    local line="  $LLAMA_SERVER"
    local args=("$@")
    for (( i=0; i<${#args[@]}; i++ )); do
        local arg="${args[$i]}"
        if [[ "$arg" == -* ]] && (( i + 1 < ${#args[@]} )) && [[ "${args[$((i+1))]}" != -* ]]; then
            local pair="$arg ${args[$((i+1))]}"
            i=$(( i + 1 ))
        else
            local pair="$arg"
        fi
        if (( ${#line} + ${#pair} + 1 > 80 )); then
            echo "$line \\"
            line="    $pair"
        else
            line="$line $pair"
        fi
    done
    echo "$line"
}

