MAX_RESTARTS=5
STARTUP_TIMEOUT="${LLM_SERVER_STARTUP_TIMEOUT:-240}"
MAC_FALLBACK_FLAGS=()

mac_apply_startup_fallback() {
    local stage="$1"
    shift
    local skip_next=0 f
    MAC_FALLBACK_FLAGS=()

    for f in "$@"; do
        if (( skip_next )); then
            skip_next=0
            continue
        fi
        case "$f" in
            -b|-ub|--cache-type-k|--cache-type-v)
                skip_next=1
                continue
                ;;
        esac
        if (( stage >= 1 )); then
            case "$f" in
                --flash-attn)
                    skip_next=1
                    continue
                    ;;
            esac
        fi
        if (( stage >= 2 )); then
            case "$f" in
                -ngl|--defrag-thold)
                    skip_next=1
                    continue
                    ;;
                --run-time-repack|-khad|-muge|-ger|--mlock)
                    continue
                    ;;
            esac
        fi
        MAC_FALLBACK_FLAGS+=("$f")
    done

    case "$stage" in
        0)
            echo "Startup fallback: lowering Metal batch sizes."
            MAC_FALLBACK_FLAGS+=(-b 512 -ub 256)
            ;;
        1)
            echo "Startup fallback: using f16 KV and disabling flash-attn for compatibility."
            MAC_FALLBACK_FLAGS+=(--cache-type-k f16 --cache-type-v f16 -b 512 -ub 256)
            ;;
        2)
            echo "Startup fallback: disabling Metal offload and retrying CPU mode."
            MAC_FALLBACK_FLAGS+=(-ngl 0 --cache-type-k f16 --cache-type-v f16 -b 512 -ub 256)
            ;;
        *)
            return 1
            ;;
    esac
}

run_with_restart() {
    local flags=("$@")
    local restarts=0
    local last_start=0
    local fallback_stage=0

    while true; do
        last_start=$(date +%s)
        echo "Starting server (PID will follow)..."
        "$LLAMA_SERVER" "${flags[@]}" 2>&1 | tee "$SERVER_LOG" &
        local pid=$!
        echo "Server PID: $pid"

        local healthy=0
        for i in $(seq 1 "$STARTUP_TIMEOUT"); do
            if curl -sf "http://127.0.0.1:${PORT}/health" >/dev/null 2>&1; then
                healthy=1
                break
            fi
            if ! kill -0 "$pid" 2>/dev/null; then
                break
            fi
            sleep 1
        done

        if (( healthy )); then
            echo "Server healthy."
            if (( BENCHMARK )); then
                run_benchmark
                BENCHMARK=0
            fi
            restarts=0
            wait "$pid" 2>/dev/null || true
            local exit_code=$?
        else
            echo "Server failed to become healthy."
            kill -9 "$pid" 2>/dev/null || true
            wait "$pid" 2>/dev/null || true
            local exit_code=1
            if mac_apply_startup_fallback "$fallback_stage" "${flags[@]}"; then
                flags=("${MAC_FALLBACK_FLAGS[@]}")
                fallback_stage=$(( fallback_stage + 1 ))
                restarts=0
                echo ""
                if [[ "${LLM_SERVER_TEST_STOP_AFTER_MAC_FALLBACK:-0}" == "1" ]]; then
                    print_cmd "${flags[@]}"
                    exit 0
                fi
                continue
            fi
        fi

        local uptime=$(( $(date +%s) - last_start ))

        if (( exit_code == 0 || exit_code == 143 )); then
            echo "Server exited cleanly (code $exit_code). Not restarting."
            exit 0
        fi

        restarts=$(( restarts + 1 ))
        echo ""
        echo "═══ Server crashed (exit code $exit_code, uptime ${uptime}s) ═══"
        tail -5 "$SERVER_LOG" 2>/dev/null
        echo ""

        if (( restarts > MAX_RESTARTS )); then
            echo "Too many restarts ($MAX_RESTARTS). Giving up."
            echo "Check $SERVER_LOG for details."
            exit 1
        fi

        local wait_sec=$(( 2 ** restarts ))
        (( wait_sec > 30 )) && wait_sec=30

        if (( uptime > 60 )); then
            wait_sec=2
            echo "Runtime crash (ran ${uptime}s). Restart $restarts/$MAX_RESTARTS in ${wait_sec}s..."
        else
            echo "Startup crash. Restart $restarts/$MAX_RESTARTS in ${wait_sec}s..."
        fi

        sleep "$wait_sec"
        kill_server ""
    done
}

