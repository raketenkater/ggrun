#!/usr/bin/env bash
# Legacy Bash entrypoint kept only to migrate old installs to Go v3.

set -euo pipefail

DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"
PREFIX="$(cd "$DIR/../.." 2>/dev/null && pwd -P || pwd)"
INSTALLER=""
CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/llm-server"
DISMISS_FILE="$CACHE_DIR/bash-v3-migration-dismissed"

find_installer() {
    for p in "$DIR/install.sh" "$DIR/../install.sh" "$DIR/../../install.sh" "$PREFIX/install.sh"; do
        [[ -f "$p" ]] && { printf '%s
' "$p"; return 0; }
    done
    return 1
}

is_interactive() {
    [[ -t 0 && -t 1 && -z "${LLM_SERVER_NO_MIGRATION_NOTICE:-}" ]]
}

recently_dismissed() {
    [[ -f "$DISMISS_FILE" ]] || return 1
    local now then
    now="$(date +%s)"
    then="$(cat "$DISMISS_FILE" 2>/dev/null || echo 0)"
    [[ "$then" =~ ^[0-9]+$ ]] || return 1
    (( now - then < 604800 ))
}

run_go_if_available() {
    for p in "$DIR/llm-server-go" "$DIR/../llm-server-go" "$DIR/../../bin/llm-server-go" "$PREFIX/bin/llm-server-go"; do
        if [[ -x "$p" ]]; then
            exec "$p" "$@"
        fi
    done
}

run_go_if_available "$@"

if ! is_interactive || recently_dismissed; then
    cat >&2 <<'EOF'
llm-server v3 is Go-first. This legacy Bash entrypoint no longer serves models.
Run the installer to switch this install to Go v3:
  curl -fsSL https://raw.githubusercontent.com/raketenkater/llm-server/main/setup.sh | bash
EOF
    exit 2
fi

cat <<'EOF'
llm-server v3 is now Go-first.

The Go version is the main release line. It is faster, cross-platform, supports
Vulkan/Metal/CPU backends, and keeps compatibility with ik_llama.cpp and llama.cpp.
EOF
printf '
Switch this install to Go v3 now? [Y/n] '
read -r answer </dev/tty || answer=""
answer="${answer:-y}"
case "$answer" in
    y|Y|yes|YES|Yes)
        INSTALLER="$(find_installer || true)"
        if [[ -n "$INSTALLER" ]]; then
            LLM_INSTALL_MAIN=go LLM_INSTALL_NONINTERACTIVE=1 bash "$INSTALLER"
        else
            curl -fsSL https://raw.githubusercontent.com/raketenkater/llm-server/main/setup.sh | env LLM_INSTALL_MAIN=go LLM_INSTALL_NONINTERACTIVE=1 bash
        fi
        NEW_BIN="$(command -v llm-server || true)"
        if [[ -n "$NEW_BIN" && "$NEW_BIN" != "$0" ]]; then
            exec "$NEW_BIN" "$@"
        fi
        echo "Go v3 install completed. Open a new shell, then run llm-server again."
        exit 0
        ;;
    *)
        mkdir -p "$CACHE_DIR"
        date +%s >"$DISMISS_FILE"
        echo "Skipped. The legacy Bash entrypoint will ask again later."
        exit 2
        ;;
esac
