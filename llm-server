# Run a benchmark request and extract gen tok/s from /slots
# Prints the tok/s to stdout
bench_gen_tps() {
    local url="http://127.0.0.1:${PORT}"
    # Send a completion and extract timings directly from the response
    local result
    result=$(curl -sf "$url/v1/chat/completions" \
        -H "Content-Type: application/json" \
        --max-time 180 \
        -d '{"model":"test","messages":[{"role":"system","content":"You are a helpful assistant. /no_think"},{"role":"user","content":"Explain quantum computing in detail, covering qubits, superposition, entanglement, and error correction."}],"max_tokens":500,"temperature":0.1}' \
        2>/dev/null)

    if [[ -z "$result" ]]; then
        echo "0 0"
        return
    fi

    # Try timings from response (llama.cpp includes these)
    python3 -c "
import sys, json
try:
    d = json.load(sys.stdin)
    t = d.get('timings', {})
    gen = t.get('predicted_per_second', 0)
    pp = t.get('prompt_per_second', 0)
    if gen > 0:
        print(f'{gen:.2f} {pp:.2f}')
    else:
        # Fallback: calculate from usage
        u = d.get('usage', {})
        print(f'0 0')
except: print('0 0')
" <<< "$result" 2>/dev/null || echo "0 0"
}

# Query /v1/chat/completions with a message array (conversation history)
# Args: $1 = JSON messages array as string
# Prints the assistant content to stdout
query_llm_chat() {
    local messages_json="$1"
    local url="http://127.0.0.1:${PORT}"

    local response
    # chat_template_kwargs.enable_thinking=false suppresses <think> blocks for
    # Qwen3/3.5/3.6 (the tune conversation doesn't need chain-of-thought; it
    # otherwise eats the whole token budget). Ignored by non-Qwen templates.
    response=$(curl -sf "$url/v1/chat/completions" \
        -H "Content-Type: application/json" \
        --max-time 1800 \
        -d "{\"messages\":${messages_json},\"max_tokens\":16384,\"temperature\":0.3,\"chat_template_kwargs\":{\"enable_thinking\":false}}" 2>/dev/null) || true

    if [[ -z "$response" ]]; then
        echo "ERROR"
        return 0
    fi

    python3 -c "
import sys, json
try:
    d = json.load(sys.stdin)
    c = d['choices'][0]['message']
    # Combine both content and reasoning — JSON config could be in either
    content = c.get('content', '') or ''
    reasoning = c.get('reasoning_content', '') or ''
    # Prefer content if it has JSON, otherwise check reasoning
    text = content if '{' in content else (reasoning if '{' in reasoning else content)
    print(text)
except:
    print('ERROR')
" <<< "$response"
}

# Build fixed flags string (these never change during tuning)
build_fixed_flags() {
    local flags="-m \"${MODEL_PATH}\" --host \"${HOST}\" --port \"${PORT}\" --ctx-size \"${CTX_SIZE}\" --reasoning --mmproj"

    # Standard mode may tune performance/memory knobs, but placement stays fixed.
    # Full placement mode unlocks these unless the user explicitly selected them.
    if (( !DO_UNLIMITED )); then
        flags+=" --device --tensor-split --split-mode -mg -ngl -ot --n-cpu-moe"
    fi

    # Include MoE placement flags if set; they are not tunable yet.
    if (( ${#TUNE_EXTRA_FIXED[@]} > 0 )); then
        for f in "${TUNE_EXTRA_FIXED[@]}"; do
             if [[ " $flags " != *" $f "* ]]; then
                flags+=" $f"
            fi
        done
    fi
    if (( ${#TUNE_USER_LOCKED_KEYS[@]} > 0 )); then
        local f
        for f in "${TUNE_USER_LOCKED_KEYS[@]}"; do
            if [[ " $flags " != *" $f "* ]]; then
                flags+=" $f"
            fi
        done
