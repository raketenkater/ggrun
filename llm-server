#!/bin/bash
# shellcheck disable=SC2004,SC1090,SC2034,SC2001,SC2155,SC2086,SC2015,SC2207
#
# llm-server — Universal smart launcher for ik_llama.cpp / llama.cpp
# Auto-detects GPUs, RAM, model architecture (dense/MoE), and optimizes placement.
# Works on any system: 0-8+ GPUs, any VRAM/RAM configuration.
#
# Usage:
#   llm-server <repo/name> --download    # Download from HuggingFace
#   llm-server -h                        # Show this help message
#   llm-server <model.gguf>              # Launch (uses cached tune if available)
#   llm-server <model.gguf> --dry-run    # Print command without executing
#   llm-server --port 8082 <model.gguf>  # Custom port
#   llm-server <model.gguf> --benchmark  # Start, run quick benchmark, print tok/s
#   llm-server <model.gguf> --cpu        # Force CPU-only (ignore GPUs)
#   llm-server <model.gguf> --server-bin /path/to/llama-server
#   llm-server <model.gguf> --lib-path /path/to/libs
#   llm-server <model.gguf> --backend llama   # force llama.cpp
#   llm-server <model.gguf> --backend ik_llama # force ik_llama.cpp
#   llm-server <model.gguf> --kv-quality high  # KV cache: high(f16), mid(q8_0), low(q4_0)
#   llm-server <model.gguf> --gpus 0,1         # Use only GPU 0 and 1
#   llm-server <model.gguf> --ram-budget 60G   # Cap RAM usage at 60GB
#   llm-server --update                         # Update llm-server + ik_llama.cpp + llama.cpp
#   llm-server <model.gguf> --vision           # Auto-detect/download mmproj for vision
#   llm-server <model.gguf> --mmproj auto      # Same as --vision
#   llm-server <model.gguf> --mmproj proj.gguf # Enable vision with specific mmproj file
#   llm-server <model.gguf> --ai-tune          # AI-driven flag optimization (8 rounds)
#   llm-server <model.gguf> --ai-tune --retune # Force re-tune even if cache exists
#   llm-server <model.gguf> --ai-tune --rounds 4 # Customize number of rounds
#   llm-server <model.gguf> --ai-tune --placement-tune # Full tune: may change placement/split/perf flags except user-chosen flags
#   llm-server <model.gguf> --tune-cache cache.json # Launch with an explicit tuned config
#   llm-server <model.gguf> --ai-tune -v       # Verbose: show full ai-tune logs (default: progress box only)
#
# Environment variables:
#   LLAMA_SERVER    Path to llama-server binary (auto-detected if not set)
#   LLM_MODEL_DIR   Default model directory (default: ~/ai_models)
#   LLM_PORT        Server port (default: 8081)
#   LLM_CTX_SIZE    Context size (default: 65536)

set -euo pipefail

# Resolve this script's directory, following symlinks so an install at
# ~/.local/bin/llm-server → /home/…/llm-server/llm-server still finds the
# sibling parse_gguf.py that ships in the repo/install.
_resolve_script_dir() {
    local src="${BASH_SOURCE[0]}"
    while [[ -L "$src" ]]; do
        local dir
        dir="$(cd "$(dirname "$src")" 2>/dev/null && pwd -P)" || break
        src="$(readlink "$src")"
        [[ "$src" != /* ]] && src="$dir/$src"
    done
    cd "$(dirname "$src")" 2>/dev/null && pwd -P
}
SCRIPT_DIR="$(_resolve_script_dir || true)"
PARSE_GGUF="$SCRIPT_DIR/parse_gguf.py"
if [[ ! -f "$PARSE_GGUF" ]]; then
    _alt="$(command -v parse_gguf.py 2>/dev/null || true)"
    [[ -n "$_alt" ]] && PARSE_GGUF="$_alt"
fi

_discover_app_home() {
    [[ -n "${LLM_APP_HOME:-}" ]] && { echo "$LLM_APP_HOME"; return 0; }
    [[ "$(basename "$SCRIPT_DIR")" == "bin" ]] || return 1
    local parent
    parent="$(cd "$SCRIPT_DIR/.." 2>/dev/null && pwd -P)" || return 1
    [[ -d "$parent/models" || -d "$parent/config" || -d "$parent/cache" ]] || return 1
    echo "$parent"
}
LLM_APP_HOME="$(_discover_app_home 2>/dev/null || true)"
[[ -n "$LLM_APP_HOME" ]] && export LLM_APP_HOME

# Optional user config: sourceable bash file at $XDG_CONFIG_HOME/llm-server/config
# (defaults to ~/.config/llm-server/config). Same syntax as env vars — anything
# settable on the command line (LLAMA_SERVER, LLM_RAM_BUDGET, LLM_DEFAULT_CTX, …)
# can be persisted there. Loaded before defaults so explicit env still wins.
if [[ -z "${LLM_CONFIG:-}" && -n "$LLM_APP_HOME" && -f "$LLM_APP_HOME/config/config.sh" ]]; then
    LLM_CONFIG="$LLM_APP_HOME/config/config.sh"
else
    LLM_CONFIG="${LLM_CONFIG:-${XDG_CONFIG_HOME:-$HOME/.config}/llm-server/config}"
fi
[[ -f "$LLM_CONFIG" ]] && source "$LLM_CONFIG"

# RUNNING_PID tracks the in-flight health-check / pre-launch server so a fatal
# script exit (set -e landmine, SIGINT, SIGTERM) doesn't leak a 100GB+ ik_llama
# process. `run_with_restart` explicitly resets this for the foreground server
# since that one is the user's intended long-running process.
#
# V3: launches go through setsid so the server is its own session/pgid leader.
# Cleanup targets the whole process group, which (a) catches spawned helper
# threads/children and (b) lets us avoid the previous lsof-port-sweep that
# could `kill -9` an unrelated service bound to the same port.
RUNNING_PID=""
_pgid_of() {
    local pid="${1:-}"
    [[ -z "$pid" ]] && return 1
    kill -0 "$pid" 2>/dev/null || return 1
    local pgid
    pgid=$(ps -o pgid= -p "$pid" 2>/dev/null | tr -d ' ') || return 1
    [[ -n "$pgid" ]] || return 1
    echo "$pgid"
}
_cleanup_orphan_server() {
    local pid="${RUNNING_PID:-}"
    [[ -z "$pid" ]] && return 0
    kill -0 "$pid" 2>/dev/null || return 0
    local pgid
    pgid=$(_pgid_of "$pid" 2>/dev/null || true)
    # Refuse to signal our own group (would TERM the script itself).
    if [[ -n "$pgid" && "$pgid" != "$$" && "$pgid" != "$(ps -o pgid= -p $$ | tr -d ' ')" ]]; then
        kill -TERM -- "-$pgid" 2>/dev/null || true
    else
        kill -TERM "$pid" 2>/dev/null || true
    fi
    local i=0
    while (( i < 5 )) && kill -0 "$pid" 2>/dev/null; do sleep 1; (( ++i )); done
    if kill -0 "$pid" 2>/dev/null; then
        if [[ -n "$pgid" && "$pgid" != "$$" && "$pgid" != "$(ps -o pgid= -p $$ | tr -d ' ')" ]]; then
            kill -KILL -- "-$pgid" 2>/dev/null || true
        else
            kill -9 "$pid" 2>/dev/null || true
        fi
    fi
}
trap _cleanup_orphan_server EXIT

# ═══════════════════════════════════════════════════════════════
# Section 1: Configuration & Argument Parsing
# ═══════════════════════════════════════════════════════════════

VERSION="2.1.0"

# Persistent Configuration — source early so env vars (LLM_PORT, etc.) are available
CONFIG_DIR="${LLM_CONFIG_DIR:-${LLM_APP_HOME:+$LLM_APP_HOME/config}}"
CONFIG_DIR="${CONFIG_DIR:-$HOME/.config/llm-server}"
CONFIG_FILE="$CONFIG_DIR/config.sh"
[[ -f "$CONFIG_FILE" ]] && source "$CONFIG_FILE"

PORT="${LLM_PORT:-8081}"
HOST="0.0.0.0"
CTX_SIZE="${LLM_CTX_SIZE:-65536}"
# Set to 1 when the user explicitly passes --ctx-size or LLM_CTX_SIZE so the
# max-context-fit suggestion stays out of their way.
CTX_EXPLICIT=0
[[ -n "${LLM_CTX_SIZE:-}" ]] && CTX_EXPLICIT=1

# Tuning constants
# MAX_RESTARTS: give-up threshold for repeated startup failures.
# Override with --keep-alive (or LLM_KEEP_ALIVE=1) to never give up.
MAX_RESTARTS="${LLM_MAX_RESTARTS:-5}"
KEEP_ALIVE="${LLM_KEEP_ALIVE:-0}"
TUNE_LONG_TIMEOUT=0
SYSTEM_HEADROOM_MB=5120          # RAM reserved for OS/system
COMPUTE_PER_GPU_MB=512           # CUDA context + compute buffers per GPU
MIN_CRAM_MB=512                  # minimum useful CPU RAM for expert offload
VRAM_OVERHEAD_PERCENT=130        # model size * this / 100 = estimated VRAM needed
SINGLE_GPU_HEADROOM_MB=4096      # extra VRAM headroom to fit single-GPU mode

MODEL_DIR="${LLM_MODEL_DIR:-${LLM_APP_HOME:+$LLM_APP_HOME/models}}"
MODEL_DIR="${MODEL_DIR:-$HOME/ai_models}"
# Ensure model directory exists
mkdir -p "$MODEL_DIR"
CACHE_DIR="${LLM_CACHE_DIR:-${LLM_APP_HOME:+$LLM_APP_HOME/cache}}"
CACHE_DIR="${CACHE_DIR:-$HOME/.cache/llm-server}"
LOG_DIR="${LLM_LOG_DIR:-${LLM_APP_HOME:+$LLM_APP_HOME/logs}}"
LOG_DIR="${LOG_DIR:-/tmp}"
mkdir -p "$CACHE_DIR" "$LOG_DIR"
SERVER_LOG="$LOG_DIR/llm-server.log"
# Guard against stale directory at log path
[[ -d "$SERVER_LOG" ]] && rm -rf "$SERVER_LOG" 2>/dev/null || SERVER_LOG="/tmp/llm-server-$$.log"
LIB_HUB_DIR=""

RETUNE=0
USER_TUNE_ROUNDS=""
DOWNLOAD=0
DRY_RUN=0
VERBOSE=0
BENCHMARK=0
CPU_ONLY=0
MODEL_ARG=""
USER_SERVER_BIN=""
USER_LIB_PATH=""
EXPLICIT_TUNE_CACHE=""
EXTRA_LLAMA_FLAGS=()   # unknown flags forwarded verbatim to llama-server
TUNE_USER_LOCKED_KEYS=() # normalized llama flags the user explicitly chose; AI-tune must not override them
KV_QUALITY="low"  # high (f16), mid (q8_0), low (q4_0, default)
KV_QUALITY_EXPLICIT=0  # set to 1 when user passes --kv-quality — locks KV against AI-tune downgrades
PARALLEL_SLOTS=""      # --parallel N passthrough, empty = llama-server default (4)
GPUS_FILTER=""
RAM_BUDGET_MB=0
MMPROJ_PATH=""
DO_UPDATE=0
SHOW_CONFIGS=0
DO_AI_TUNE=0
DO_UNLIMITED=0
BACKEND=""  # "llama" or "ik_llama" - empty = auto-detect

# Ensure ~/.local/bin (where install.sh puts our scripts) is on PATH so any
# sub-process invocations resolve correctly.
export PATH="$HOME/.local/bin:$PATH"

# Cleanup on exit
cleanup() {
    if [[ -n "${LIB_HUB_DIR:-}" && -d "$LIB_HUB_DIR" ]]; then
        rm -rf "$LIB_HUB_DIR"
    fi
}
_on_exit() {
    _cleanup_orphan_server
    cleanup
}
trap _on_exit EXIT

# Create a "Lib Hub" (symlink all found .so files into one temp dir)
# This solves the issue where libraries are scattered in build subfolders.
setup_lib_hub() {
    local bin_path="$1"
    local bin_dir
    bin_dir="$(dirname "$bin_path")"
    local build_root
    build_root="$(dirname "$bin_dir")"

    if [[ ! -d "$build_root" ]]; then return; fi

    # Skip for system-installed binaries. Their libs are resolved by ldconfig
    # and standard rpath — they don't need a hub, and building one by symlinking
    # every .so under /usr into LD_LIBRARY_PATH actively breaks them (pulls in
    # unrelated libs that export newer/older symbols than the binary expects).
    # See issue #12: /usr/bin/llama-server + `find /usr -name '*.so*'` pulled in
    # a stale libggml-cpu.so.0 exporting quantize_row_nvfp4_ref and the binary
    # died with "symbol lookup error".
    case "$bin_dir" in
        /usr/bin|/usr/local/bin|/bin|/sbin|/usr/sbin|/opt/*/bin)
            # If a previous call set up a hub for another binary, drop it so
            # we don't leave a stale LD_LIBRARY_PATH entry active.
            [[ -n "${LIB_HUB_DIR:-}" && -d "$LIB_HUB_DIR" ]] && rm -rf "$LIB_HUB_DIR"
            LIB_HUB_DIR=""
            return
            ;;
    esac

    # Require a recognizable llama.cpp / ik_llama.cpp build tree before we
    # start symlinking .so files. Marker: sibling dirs that CMake produces
    # (ggml/, src/, common/) or the binary's own dir containing libllama.so.
    # `compgen -G` expands the glob and returns 0 only if at least one path
    # matches — `[[ -e foo* ]]` doesn't, since [[ uses literal-glob semantics.
    local _has_libllama_versioned=0
    compgen -G "$bin_dir/libllama.so.*" >/dev/null 2>&1 && _has_libllama_versioned=1
    if [[ ! -d "$build_root/ggml" && ! -d "$build_root/src" && \
          ! -e "$bin_dir/libllama.so" && $_has_libllama_versioned -eq 0 ]]; then
        [[ -n "${LIB_HUB_DIR:-}" && -d "$LIB_HUB_DIR" ]] && rm -rf "$LIB_HUB_DIR"
        LIB_HUB_DIR=""
        return
    fi

    # Create fresh hub dir
    [[ -n "$LIB_HUB_DIR" && -d "$LIB_HUB_DIR" ]] && rm -rf "$LIB_HUB_DIR"
    LIB_HUB_DIR=$(mktemp -d /tmp/llm-lib-hub.XXXXXX)

    # Find and symlink all .so files (real files only — versioned .so.0.9.7 etc.)
    find "$build_root" -name "*.so*" -type f -exec ln -sf {} "$LIB_HUB_DIR/" \; 2>/dev/null

    # Fix broken versioned symlink chains: if binary needs libfoo.so.0 but only
    # libfoo.so.0.9.7 exists (common after partial rebuilds), create the missing link
    for real_lib in "$LIB_HUB_DIR"/*.so.*.*; do
        [[ -f "$real_lib" ]] || continue
        local base
        base="$(basename "$real_lib")"
        # Extract libfoo.so.0 from libfoo.so.0.9.7
        local so_major="${base%.*.*}"
        [[ "$so_major" != "$base" && ! -e "$LIB_HUB_DIR/$so_major" ]] && \
            ln -sf "$real_lib" "$LIB_HUB_DIR/$so_major"
        # Extract libfoo.so from libfoo.so.0.9.7
        local so_base="${base%%\.so\.*}.so"
        [[ ! -e "$LIB_HUB_DIR/$so_base" ]] && \
            ln -sf "$real_lib" "$LIB_HUB_DIR/$so_base"
    done

    # Export the hub to the library path
    export LD_LIBRARY_PATH="$LIB_HUB_DIR:${LD_LIBRARY_PATH:-}"

    # Also add the binary's directory for good measure
    export LD_LIBRARY_PATH="${bin_dir}:$LD_LIBRARY_PATH"
}

# Auto-detect llama-server binary
find_server_binary() {
    if [[ -n "${USER_SERVER_BIN:-}" && -x "$USER_SERVER_BIN" ]]; then
        echo "$USER_SERVER_BIN"
        return
    fi
    if [[ -n "${LLAMA_SERVER:-}" && -x "$LLAMA_SERVER" ]]; then
        echo "$LLAMA_SERVER"
        return
    fi
    
    local candidates=()
    
    # Respect --backend flag
    if [[ "$BACKEND" == "ik_llama" ]]; then
        candidates+=("$HOME/ik_llama.cpp/build/bin/llama-server")
    elif [[ "$BACKEND" == "llama" ]]; then
        candidates+=("$SCRIPT_DIR/llama-server")
        candidates+=("$HOME/.local/bin/llama-server")
        candidates+=("$HOME/llama.cpp/build/bin/llama-server")
    else
        # Auto-detect: prefer ik_llama.cpp (faster multi-GPU)
        candidates=(
            "$SCRIPT_DIR/llama-server"
            "$HOME/.local/bin/llama-server"
            "$HOME/ik_llama.cpp/build/bin/llama-server"
            "$HOME/llama.cpp/build/bin/llama-server"
        )
    fi
    
    # Also check PATH
    candidates+=("$(command -v llama-server 2>/dev/null || true)")
    
    for bin in "${candidates[@]}"; do
        [[ -n "$bin" && -x "$bin" ]] && echo "$bin" && return
    done
    echo ""
}

# Parse arguments
# ─────────────────────────────────────────────────────────────────
# Create a copy of args to allow re-parsing if needed, though we unify here
ARGS=("$@")
while [[ $# -gt 0 ]]; do
    case "$1" in
        --retune)    RETUNE=1; shift ;;
        --dry-run)   DRY_RUN=1; shift ;;
        --verbose|-v) VERBOSE=1; shift ;;
        --benchmark) BENCHMARK=1; shift ;;
        --cpu)       CPU_ONLY=1; shift ;;
        --model-dir) MODEL_DIR="$2"; shift 2 ;;
        --port)      PORT="$2"; shift 2 ;;
        --ctx-size)  CTX_SIZE="$2"; CTX_EXPLICIT=1; shift 2 ;;
        --server-bin) USER_SERVER_BIN="$2"; shift 2 ;;
        --lib-path)   USER_LIB_PATH="$2"; shift 2 ;;
        --kv-quality)
            case "${2:-}" in high|mid|low) ;; *) echo "Error: --kv-quality must be one of: high, mid, low"; exit 1 ;; esac
            KV_QUALITY="$2"; KV_QUALITY_EXPLICIT=1; shift 2 ;;
        --gpus)      GPUS_FILTER="$2"; shift 2 ;;
        --ram-budget) RAM_BUDGET_MB="$2"; shift 2 ;;
        --mmproj)      MMPROJ_PATH="$2"; shift 2 ;;
        --vision)      MMPROJ_PATH="auto"; shift ;;  # alias: auto-detect/download mmproj
        --download)  DOWNLOAD=1; shift ;;
        --update)    DO_UPDATE=1; shift ;;
        --show-configs) SHOW_CONFIGS=1; shift ;;
        --ai-tune)   DO_AI_TUNE=1; shift ;;
        --tune-cache) EXPLICIT_TUNE_CACHE="$2"; shift 2 ;;
        --unlimited|--placement-tune|--full-auto-tune) DO_UNLIMITED=1; shift ;;
        --tune-long-timeout) TUNE_LONG_TIMEOUT=1; shift ;;
        --rounds)    USER_TUNE_ROUNDS="$2"; shift 2 ;;
        --parallel)  PARALLEL_SLOTS="$2"; shift 2 ;;
        --keep-alive) KEEP_ALIVE=1; shift ;;
        --backend)   BACKEND="$2"; shift 2 ;;
        --version)     echo "llm-server v$VERSION"; exit 0 ;;
        --help|-h)
            sed -n '3,/^$/s/^# \?//p' "$0"
            exit 0
            ;;
        --)
            # Explicit separator: everything after goes to llama-server verbatim
            shift
            while [[ $# -gt 0 ]]; do EXTRA_LLAMA_FLAGS+=("$1"); shift; done
            ;;
        -*)
            # Unknown flag → forward to llama-server. Also greedily consume the next
            # token as its value unless the next token is the model path (looks like
            # a .gguf or is an existing file) and MODEL_ARG isn't set yet.
            EXTRA_LLAMA_FLAGS+=("$1"); shift
            if [[ $# -gt 0 && "$1" != -* ]]; then
                if [[ -z "$MODEL_ARG" && ( "$1" == *.gguf || -e "$1" ) ]]; then
                    MODEL_ARG="$1"; shift
                else
                    EXTRA_LLAMA_FLAGS+=("$1"); shift
                fi
            fi
            ;;
        *)
            if [[ -z "$MODEL_ARG" ]]; then
                MODEL_ARG="$1"; shift
            else
                EXTRA_LLAMA_FLAGS+=("$1"); shift
            fi
            ;;
    esac
done

normalize_tune_key() {
    case "$1" in
        --mg|--main-gpu) echo "-mg" ;;
        --batch-size) echo "-b" ;;
        --ubatch-size) echo "-ub" ;;
        --ngl|--n-gpu-layers) echo "-ngl" ;;
        --n-cpu-moe|-ncmoe) echo "--n-cpu-moe" ;;
        --override-tensor) echo "-ot" ;;
        --threads|-t) echo "--threads" ;;
        --threads-batch|-tb) echo "--threads-batch" ;;
        --parallel|-np) echo "--parallel" ;;
        --flash-attn|-fa) echo "--flash-attn" ;;
        --reasoning|-rea) echo "--reasoning" ;;
        *) echo "$1" ;;
    esac
}

add_tune_lock_key() {
    local key="$1" existing
    [[ -z "$key" || "$key" != -* ]] && return 0
    for existing in "${TUNE_USER_LOCKED_KEYS[@]}"; do
        [[ "$existing" == "$key" ]] && return 0
    done
    TUNE_USER_LOCKED_KEYS+=("$key")
}

record_user_tune_locks() {
    local i key
    for (( i=0; i<${#EXTRA_LLAMA_FLAGS[@]}; i++ )); do
        [[ "${EXTRA_LLAMA_FLAGS[$i]}" == -* ]] || continue
        key=$(normalize_tune_key "${EXTRA_LLAMA_FLAGS[$i]}")
        add_tune_lock_key "$key"
    done
    [[ -n "$PARALLEL_SLOTS" ]] && add_tune_lock_key "--parallel"
    if (( KV_QUALITY_EXPLICIT )); then
        add_tune_lock_key "--cache-type-k"
        add_tune_lock_key "--cache-type-v"
    fi
    (( CTX_EXPLICIT )) && add_tune_lock_key "--ctx-size"
    if [[ -n "$GPUS_FILTER" ]]; then
        add_tune_lock_key "--device"
        add_tune_lock_key "--tensor-split"
        add_tune_lock_key "--split-mode"
        add_tune_lock_key "-mg"
        add_tune_lock_key "-ngl"
        add_tune_lock_key "-ot"
        add_tune_lock_key "--n-cpu-moe"
    fi
    if [[ -n "$MMPROJ_PATH" ]]; then
        add_tune_lock_key "--mmproj"
    fi
}
record_user_tune_locks

# Now find the binary (BACKEND is now set from args)
LLAMA_SERVER="$(find_server_binary)"

# Initial lib hub setup
if [[ -n "$LLAMA_SERVER" ]]; then
    setup_lib_hub "$LLAMA_SERVER"
fi

# Parse --ram-budget human units (e.g. "60G" → 61440 MB)
if [[ -n "$RAM_BUDGET_MB" && "$RAM_BUDGET_MB" != "0" ]]; then
    case "$RAM_BUDGET_MB" in
        *[Gg]) RAM_BUDGET_MB=$(( ${RAM_BUDGET_MB%[Gg]} * 1024 )) ;;
        *[Mm]) RAM_BUDGET_MB=${RAM_BUDGET_MB%[Mm]} ;;
        *[0-9]) ;;  # already numeric (MB)
        *) echo "Error: --ram-budget must be a number with optional G/M suffix (e.g. 60G, 4096M, 4096)"; exit 1 ;;
    esac
    if ! [[ "$RAM_BUDGET_MB" =~ ^[0-9]+$ ]]; then
        echo "Error: --ram-budget must be a number with optional G/M suffix (e.g. 60G, 4096M, 4096)"; exit 1
    fi
fi

# Validate --port
if ! [[ "$PORT" =~ ^[0-9]+$ ]] || (( PORT < 1 || PORT > 65535 )); then
    echo "Error: --port must be a number between 1 and 65535 (got: $PORT)"
    exit 1
fi

# Validate --ctx-size
if ! [[ "$CTX_SIZE" =~ ^[0-9]+$ ]] || (( CTX_SIZE < 1 )); then
    echo "Error: --ctx-size must be a positive number (got: $CTX_SIZE)"
    exit 1
fi

# ═══════════════════════════════════════════════════════════════
# --show-configs: inspect cached tune/placement per model
# ═══════════════════════════════════════════════════════════════
CACHE_DIR="${LLM_CACHE_DIR:-${LLM_APP_HOME:+$LLM_APP_HOME/cache}}"
CACHE_DIR="${CACHE_DIR:-$HOME/.cache/llm-server}"

_human_age() {
    # seconds → "2d ago" / "3h ago" / "12m ago"
    local s=$1
    if (( s < 60 )); then echo "${s}s ago"
    elif (( s < 3600 )); then echo "$(( s/60 ))m ago"
    elif (( s < 86400 )); then echo "$(( s/3600 ))h ago"
    else echo "$(( s/86400 ))d ago"
    fi
}

_backend_status() {
    # dir → "abc1234 · 2d old · N behind" or "abc1234 · N/A (no upstream)"
    local dir=$1
    [[ ! -d "$dir/.git" ]] && { echo "missing"; return; }
    local hash age_s age behind upstream
    hash=$(cd "$dir" && git rev-parse --short HEAD 2>/dev/null) || { echo "missing"; return; }
    age_s=$(cd "$dir" && git log -1 --format=%ct HEAD 2>/dev/null)
    age=$(_human_age $(( $(date +%s) - age_s )))
    upstream=$(cd "$dir" && git rev-parse --abbrev-ref --symbolic-full-name '@{u}' 2>/dev/null)
    if [[ -n "$upstream" ]]; then
        behind=$(cd "$dir" && git rev-list --count "HEAD..$upstream" 2>/dev/null || echo ?)
        if [[ "$behind" == "0" ]]; then echo "$hash · $age · up to date"
        else echo "$hash · $age · $behind behind"; fi
    else
        echo "$hash · $age · no upstream"
    fi
}

_show_backend_header() {
    echo "Backends (last fetched state; run --update to refresh):"
    for pair in "ik_llama.cpp:$HOME/ik_llama.cpp" "llama.cpp:$HOME/llama.cpp" "llama.cpp-vulkan:$HOME/llama.cpp"; do
        local label=${pair%%:*} dir=${pair##*:}
        local extra=""
        [[ "$label" == "llama.cpp-vulkan" ]] && { [[ -d "$dir/build-vulkan" ]] || continue; extra=" (build-vulkan)"; }
        printf "  %-18s %s%s\n" "$label" "$(_backend_status "$dir")" "$extra"
    done
    echo
}

_tune_backend_tag() {
    # tune file basename → backend label
    local f=$1
    case "$f" in
        *_ik.json)      echo "ik_llama" ;;
        *_llama.json)   echo "llama" ;;
        *_vulkan.json)  echo "llama-vk" ;;
        *)              echo "llama" ;;   # pre-tagged caches
    esac
}

show_configs_table() {
    _show_backend_header
    if [[ ! -d "$CACHE_DIR" ]]; then
        echo "No cache dir yet ($CACHE_DIR). Run: llm-server <model> [--ai-tune]"
        return
    fi
    shopt -s nullglob
    # tune_history.jsonl (append-only log) is intentionally NOT listed here —
    # only per-model winner files `tune_<model>_<hash>_<backend>.json`.
    local tunes=("$CACHE_DIR"/tune_*.json)
    local confs=("$CACHE_DIR"/*.conf)
    shopt -u nullglob
    if (( ${#tunes[@]} == 0 && ${#confs[@]} == 0 )); then
        echo "No cached configs. Run: llm-server <model> [--ai-tune]"
        return
    fi
    printf "%-40s %-6s %-5s %-8s %-7s %-12s %-9s\n" \
        "MODEL" "TYPE" "TUNE" "GAIN" "TOK/S" "CACHED" "BACKEND"
    printf "%-40s %-6s %-5s %-8s %-7s %-12s %-9s\n" \
        "----------------------------------------" "------" "-----" "--------" "-------" "------------" "---------"
    # Index tune caches by model basename → pick best
    declare -A TUNE_FILE TUNE_GAIN TUNE_TPS TUNE_ROUNDS TUNE_AGE TUNE_BACKEND TUNE_TYPE
    local now; now=$(date +%s)
    for f in "${tunes[@]}"; do
        [[ -f "$f" ]] || continue
        local info
        info=$(python3 - <<PY 2>/dev/null
import json, os, sys
try:
    d = json.load(open("$f"))
    model = d.get("model","?")
    best = d.get("best_config",{}) or {}
    tps = best.get("gen_tps") or 0
    base = d.get("baseline_gen_tps") or 0
    gain = ((tps-base)/base*100) if (base>0 and tps>0) else 0
    rounds = d.get("rounds", 0)
    import datetime
    ta = d.get("tuned_at","")
    try:
        dt = datetime.datetime.fromisoformat(ta.replace("Z","+00:00"))
        age = int(dt.timestamp())
    except Exception:
        age = int(os.path.getmtime("$f"))
    print(f"{model}\t{tps:.1f}\t{gain:+.1f}\t{rounds}\t{age}")
except Exception as e:
    sys.exit(1)
PY
)
        [[ -z "$info" ]] && continue
        local model tps gain rounds age
        IFS=$'\t' read -r model tps gain rounds age <<< "$info"
        local bck; bck=$(_tune_backend_tag "$(basename "$f")")
        # Keep best per (model, backend) — prefer newest tune
        local key="${model}__${bck}"
        if [[ -z "${TUNE_FILE[$key]:-}" ]] || (( age > ${TUNE_AGE[$key]:-0} )); then
            TUNE_FILE[$key]=$f
            TUNE_TPS[$key]=$tps
            TUNE_GAIN[$key]=$gain
            TUNE_ROUNDS[$key]=$rounds
            TUNE_AGE[$key]=$age
            TUNE_BACKEND[$key]=$bck
        fi
    done
    # Type heuristic from model filename
    _model_type() {
        case "${1,,}" in
            *a3b*|*a10b*|*a24b*|*-moe-*|*_moe_*|*minimax*|*qwen3.5-122b*) echo "MoE" ;;
            *) echo "dense" ;;
        esac
    }
    # Emit rows (tuned)
    for key in "${!TUNE_FILE[@]}"; do
        local model=${key%__*} bck=${TUNE_BACKEND[$key]}
        local short="$model" type
        type=$(_model_type "$model")
        (( ${#short} > 40 )) && short="${short:0:37}..."
        local cached; cached=$(_human_age $(( now - TUNE_AGE[$key] )))
        printf "%-40s %-6s %-5s %-8s %-7s %-12s %-9s\n" \
            "$short" "$type" "${TUNE_ROUNDS[$key]}rnd" "${TUNE_GAIN[$key]}%" \
            "${TUNE_TPS[$key]}" "$cached" "$bck"
    done
    # Placement-only caches (no matching tune) — dedupe by model name, show newest
    declare -A SEEN_MODEL
    declare -A PLACEMENT_MTIME
    for f in "${confs[@]}"; do
        [[ -f "$f" ]] || continue
        local model
        # Tolerate trailing whitespace, CRLF, and future header spellings.
        model=$(grep -m1 -iE "^# *Auto[- ]tuned config for" "$f" 2>/dev/null \
                | sed -E 's/.*for +//; s/[[:space:]]+$//; s/\.gguf$//' \
                || true)
        [[ -z "$model" ]] && continue
        local hit=0
        for key in "${!TUNE_FILE[@]}"; do
            [[ "${key%__*}" == "$model.gguf" || "${key%__*}" == "$model" ]] && { hit=1; break; }
        done
        (( hit )) && continue
        local mt; mt=$(stat -c %Y "$f" 2>/dev/null || echo "$now")
        if [[ -z "${PLACEMENT_MTIME[$model]:-}" ]] || (( mt > ${PLACEMENT_MTIME[$model]} )); then
            PLACEMENT_MTIME[$model]=$mt
        fi
    done
    for model in "${!PLACEMENT_MTIME[@]}"; do
        local short="$model" type
        type=$(_model_type "$model")
        (( ${#short} > 40 )) && short="${short:0:37}..."
        printf "%-40s %-6s %-5s %-8s %-7s %-12s %-9s\n" \
            "$short" "$type" "-" "-" "-" "$(_human_age $(( now - PLACEMENT_MTIME[$model] )))" "placement"
    done
}

show_configs_detail() {
    local model_arg=$1
    _show_backend_header
    local model_path="$model_arg"
    [[ -f "$model_path" ]] || model_path="${LLM_MODEL_DIR:-$HOME/ai_models}/$model_arg"
    if [[ ! -f "$model_path" ]]; then
        echo "Model not found: $model_arg"
        exit 1
    fi
    local model_name; model_name=$(basename "$model_path")
    echo "Model: $model_name"
    echo "  Path: $model_path"
    echo "  Size: $(du -h "$model_path" 2>/dev/null | awk '{print $1}' || true)"
    echo
    shopt -s nullglob
    local tunes=("$CACHE_DIR"/tune_"$model_name"_*.json)
    shopt -u nullglob
    if (( ${#tunes[@]} == 0 )); then
        echo "No tune cache for this model. Run: llm-server \"$model_arg\" --ai-tune"
    fi
    local now; now=$(date +%s)
    for f in "${tunes[@]}"; do
        local bck; bck=$(_tune_backend_tag "$(basename "$f")")
        echo "Tune cache ($bck): $f"
        python3 - <<PY 2>/dev/null
import json, datetime
d = json.load(open("$f"))
best = d.get("best_config", {}) or {}
base = d.get("baseline_gen_tps") or 0
tps = best.get("gen_tps") or 0
gain = ((tps-base)/base*100) if (base>0 and tps>0) else 0
print(f"  Config:     {best.get('name','?')}")
print(f"  Baseline:   {base:.2f} tok/s gen, {d.get('baseline_pp_tps',0):.2f} tok/s pp")
print(f"  Best:       {tps:.2f} tok/s gen, {best.get('pp_tps',0):.2f} tok/s pp  ({gain:+.1f}%)")
print(f"  Rounds:     {d.get('rounds', 0)}")
print(f"  Tuned at:   {d.get('tuned_at','?')}")
flags = best.get("flags", {})
if flags:
    print(f"  Tuned flags: " + " ".join(f"{k} {v}" if v else k for k,v in flags.items()))
PY
        echo
    done
    echo "Resolved launch command:"
    # Re-invoke self with --dry-run to get the actual command without reimplementing.
    # Keep this non-interactive; otherwise a TTY caller can hang on context prompts.
    SHOW_CONFIGS=0 LLM_ASSUME_YES=1 LLM_SERVER_UPDATE_CHECKED=1 \
        "$0" --server-bin "$LLAMA_SERVER" --ctx-size "$CTX_SIZE" "$model_arg" --dry-run 2>&1 \
        | sed -n '/^Command:/,$p' | sed 's/^/  /'
}

if (( SHOW_CONFIGS )); then
    if [[ -n "$MODEL_ARG" ]]; then
        show_configs_detail "$MODEL_ARG"
    else
        show_configs_table
    fi
    exit 0
fi

if [[ -z "$MODEL_ARG" ]] && (( !DO_UPDATE )) && (( !SHOW_CONFIGS )); then
    echo "Error: No model specified. Usage: llm-server <model.gguf> or <repo/name> --download"
    exit 1
fi

# ── Download Logic ──
if (( DOWNLOAD )); then
    TOTAL_VRAM_MB=0
    if command -v nvidia-smi >/dev/null 2>&1; then
        # Trailing `|| echo 0` guards pipefail: if nvidia-smi fails transiently,
        # awk gets empty input and prints nothing; without the guard the whole
        # `var=$(pipeline)` silently kills the script under set -euo pipefail.
        TOTAL_VRAM_MB=$(nvidia-smi --query-gpu=memory.free --format=csv,noheader,nounits 2>/dev/null | awk '{s+=$1} END {print s+0}' || echo 0)
    fi
    RAM_AVAIL_MB=$(grep MemAvailable /proc/meminfo 2>/dev/null | awk '{print int($2/1024)}' || echo 0)
    # Try finding the downloader in several places
    DOWNLOADER="$(dirname "$(readlink -f "$0")")/download_any_gguf.py"
    if [[ ! -f "$DOWNLOADER" ]]; then
        DOWNLOADER="$MODEL_DIR/download_any_gguf.py"
    fi
    
    if [[ ! -f "$DOWNLOADER" ]]; then
        echo "Error: Downloader script (download_any_gguf.py) not found."
        echo "Please ensure it exists in /home/mik/ai_models/ or the script directory."
        exit 1
    fi

    echo "Launching GGUF Downloader for: $MODEL_ARG"
    echo "Wait for the interactive session..."
    echo ""
    
    python3 "$DOWNLOADER" --repo "$MODEL_ARG" --dir "$MODEL_DIR" --cache-dir "$CACHE_DIR" --vram "$TOTAL_VRAM_MB" --ram "$RAM_AVAIL_MB"
    
    echo ""
    echo "Download step complete."
    echo "To launch your new model, run: llm-server <path_to_downloaded_file>"
    exit 0
fi

# ── Update Logic ──
if (( DO_UPDATE )); then

    # Self-update: pull latest llm-server from git, re-install with rollback
    LLM_SERVER_REPO="${LLM_SERVER_REPO:-$HOME/llm-server}"
    if [[ -d "$LLM_SERVER_REPO/.git" ]]; then
        echo "═══ Updating llm-server ═══"
        pushd "$LLM_SERVER_REPO" > /dev/null
        old_hash=$(git rev-parse HEAD 2>/dev/null || echo "unknown")

        # Save current script state for potential rollback
        script_path=$(readlink -f "$0")
        script_backup="${script_path}.bak"
        cp "$script_path" "$script_backup"

        if git pull --ff-only 2>&1 | tail -3; then
            new_hash=$(git rev-parse HEAD 2>/dev/null || echo "unknown")
            if [[ "$old_hash" != "$new_hash" ]]; then
                echo "  Updated: $(git log --oneline "${old_hash}..${new_hash}" | wc -l) new commits"
                git log --oneline "${old_hash}..${new_hash}" | head -5 | sed 's/^/    /'
                
                # Re-install updated scripts
                if [[ -x "./install.sh" ]]; then
                    echo "  Re-installing..."
                    if ! bash ./install.sh > /dev/null 2>&1; then
                        echo "  Error: Install failed. Rolling back script content..."
                        git checkout "$old_hash" 2>/dev/null
                        cp "$script_backup" "$script_path"
                        rm -f "$script_backup"
                        popd > /dev/null
                        return 1
                    fi
                fi

                # Quick self-check: can the new script run --version?
                if ! "$script_path" --version > /dev/null 2>&1; then
                    echo "  Error: New version failed self-check. Rolling back..."
                    git checkout "$old_hash" 2>/dev/null
                    cp "$script_backup" "$script_path"
                    # Re-run install to restore previous versions of other tools
                    [[ -x "./install.sh" ]] && bash ./install.sh > /dev/null 2>&1
                    echo "  Rolled back to $old_hash"
                else
                    echo ""
                    echo "  ✓ llm-server updated and verified. Restart to use the new version."
                fi
            else
                echo "  Already up to date."
            fi
        else
            echo "  Warning: git pull failed (unclean repo?). Skipping self-update."
        fi
        rm -f "$script_backup"
        popd > /dev/null
    else
        echo "Info: llm-server repo not found at $LLM_SERVER_REPO — skipping self-update."
    fi
    echo ""

    update_backend() {
        local name="$1" repo_dir="$2"
        local build_dir="$repo_dir/build"
        local binary="$build_dir/bin/llama-server"
        local fallback_state_dir="$CACHE_DIR/update-fallbacks"
        mkdir -p "$fallback_state_dir"

        echo ""
        echo "═══ Updating $name ═══"

        if [[ ! -d "$repo_dir/.git" ]]; then
            echo "  Skip: $repo_dir is not a git repo"
            return 1
        fi

        cd "$repo_dir"

        # Save current state for rollback
        local old_commit original_branch
        old_commit=$(git rev-parse HEAD 2>/dev/null)
        original_branch=$(git symbolic-ref --quiet --short HEAD 2>/dev/null || true)
        local old_binary_hash=""
        [[ -x "$binary" ]] && old_binary_hash=$(md5sum "$binary" | awk '{print $1}')
        echo "  Current: $(git log --oneline -1)"

        # Backup working binary OUTSIDE $build_dir, so a clean reconfigure that
        # wipes build/ can't also destroy the rollback target.
        local binary_backup="$repo_dir/.llm-server.llama-server.backup"
        if [[ -x "$binary" ]]; then
            cp "$binary" "${binary_backup}"
            echo "  Backed up working binary"
        fi

        # Pull latest
        echo "  Pulling latest..."
        # Handle detached head — reattach before pulling
        if ! git symbolic-ref -q HEAD >/dev/null; then
            echo "  Warning: detached HEAD detected. Checking out default branch..."
            local default_branch
            default_branch=$(git remote show origin | sed -n '/HEAD branch/s/.*: //p')
            [[ -z "$default_branch" ]] && default_branch="master"
            git checkout "$default_branch"
            # Re-capture so we compare against branch HEAD, not the detached commit
            old_commit=$(git rev-parse HEAD 2>/dev/null)
            original_branch="$default_branch"
        fi
        [[ -z "$original_branch" ]] && original_branch=$(git symbolic-ref --quiet --short HEAD 2>/dev/null || echo "master")
        # Refuse pull on dirty tree — git's "Please commit or stash" message
        # is unactionable in this context. Tell the user what we see and skip
        # cleanly. (Many users carry local patches like the tool-call fix in
        # ik_llama; we don't want to silently stash those.)
        local dirty
        dirty=$(git status --porcelain --untracked-files=no 2>/dev/null)
        if [[ -n "$dirty" ]]; then
            echo "  Skip: working tree has uncommitted changes:"
            echo "$dirty" | head -5 | sed 's/^/    /'
            echo "    (commit or stash them in $repo_dir, then re-run --update)"
            rm -f "${binary_backup}"
            return 1
        fi
        if ! git pull --ff-only 2>&1 | tail -3; then
            echo "  Warning: fast-forward pull failed, trying rebase..."
            if ! git pull --rebase 2>&1 | tail -3; then
                echo "  FAILED: git pull failed — skipping $name"
                rm -f "${binary_backup}"
                return 1
            fi
        fi

        local new_commit
        new_commit=$(git rev-parse HEAD 2>/dev/null)
        if [[ "$old_commit" == "$new_commit" ]]; then
            echo "  Already up to date."
            rm -f "${binary_backup}"
            return 2
        fi
        echo "  Updated: $(git log --oneline -1)"

        # Ensure CUDA compiler is discoverable. Many systems have CUDA installed
        # under /usr/local/cuda* but don't put nvcc on PATH; cmake will then fail
        # to reconfigure even when an incremental rebuild would have worked.
        if ! command -v nvcc >/dev/null 2>&1 && [[ -z "${CUDACXX:-}" ]]; then
            local _nvcc=""
            for d in /usr/local/cuda/bin /usr/local/cuda-*/bin; do
                [[ -x "$d/nvcc" ]] && _nvcc="$d/nvcc" && export PATH="$d:$PATH" && break
            done
            [[ -n "$_nvcc" ]] && export CUDACXX="$_nvcc" && echo "  Found CUDA: $_nvcc"
        fi

        # Bounded walk-back: if HEAD fails to build/test, try up to N-1 parent
        # commits before giving up. Handles transient upstream regressions
        # (e.g. HEAD crashes on --help) without falling back all the way to the
        # previously-installed version. Override with LLM_SERVER_UPDATE_WALKBACK.
        local walkback_max="${LLM_SERVER_UPDATE_WALKBACK:-3}"
        local attempt success=0 target_commit success_commit=""
        for (( attempt=0; attempt < walkback_max; attempt++ )); do
            if (( attempt == 0 )); then
                target_commit="$new_commit"
            else
                target_commit=$(git rev-parse "${new_commit}~${attempt}" 2>/dev/null) || break
                echo ""
                echo "  ── Attempt $((attempt+1))/${walkback_max}: walking back to $(git log --oneline -1 "$target_commit") ──"
                git checkout --quiet "$target_commit" 2>/dev/null || { echo "  checkout failed; stopping walk-back"; break; }
            fi
            if _update_build_and_test "$build_dir" "$binary"; then
                success=1
                success_commit="$target_commit"
                break
            fi
        done

        if (( !success )); then
            echo ""
            echo "  All ${walkback_max} attempts failed — rolling back to previous version..."
            git checkout "$old_commit" 2>/dev/null
            [[ -f "${binary_backup}" ]] && mv "${binary_backup}" "$binary"
            echo "  Rolled back to $(git log --oneline -1)"
            return 1
        fi

        if [[ -n "$success_commit" && "$success_commit" != "$new_commit" ]]; then
            local fallback_marker="$fallback_state_dir/${name//[^A-Za-z0-9_.-]/_}.env"
            {
                printf 'repo_dir=%q\n' "$repo_dir"
                printf 'branch=%q\n' "$original_branch"
                printf 'head_commit=%q\n' "$new_commit"
                printf 'fallback_commit=%q\n' "$success_commit"
                printf 'recorded_at=%q\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ)"
            } > "$fallback_marker"
            echo "  Walk-back succeeded at $(git log --oneline -1 "$success_commit")"
            echo "  Reattaching repo to branch '$original_branch' while keeping built fallback binary."
            git checkout --quiet "$original_branch" 2>/dev/null || \
                echo "  Warning: could not reattach to $original_branch; repo remains at fallback commit" >&2
        fi

        local new_binary_hash
        new_binary_hash=$(md5sum "$binary" | awk '{print $1}')
        if [[ "$old_binary_hash" == "$new_binary_hash" ]]; then
            echo "  Binary unchanged (no relevant code changes)"
        else
            echo "  New binary built successfully ✓"
        fi

        # Clean up backup
        rm -f "${binary_backup}"
        echo "  $name updated: $(git log --oneline -1)"
        return 0
    }

    # Build + smoke-test at whatever commit is currently checked out. No
    # rollback side effects — caller decides what to do on failure. Returns 0
    # on success, non-zero on any build / smoke-test / model-launch failure.
    _update_build_and_test() {
        local build_dir="$1" binary="$2"
        local nproc
        nproc=$(nproc 2>/dev/null || echo 8)

        echo "  Building..."
        if [[ -d "$build_dir" ]]; then
            if ! cmake --build "$build_dir" --config Release -j"$nproc" 2>&1 | tail -5; then
                echo "  Build failed — trying clean reconfigure..."
                local cmake_flags=()
                if [[ -f "$build_dir/CMakeCache.txt" ]]; then
                    local val
                    val=$(grep "^GGML_CUDA:BOOL=ON" "$build_dir/CMakeCache.txt" 2>/dev/null) && cmake_flags+=(-DGGML_CUDA=ON)
                    val=$(grep "^GGML_CUDA_FA_ALL_QUANTS:BOOL=ON" "$build_dir/CMakeCache.txt" 2>/dev/null) && cmake_flags+=(-DGGML_CUDA_FA_ALL_QUANTS=ON)
                    val=$(grep "^GGML_CUDA_NCCL:BOOL=ON" "$build_dir/CMakeCache.txt" 2>/dev/null) && cmake_flags+=(-DGGML_CUDA_NCCL=ON)
                    val=$(grep "^CMAKE_CUDA_ARCHITECTURES:" "$build_dir/CMakeCache.txt" 2>/dev/null) && cmake_flags+=("-DCMAKE_CUDA_ARCHITECTURES=$(echo "$val" | cut -d= -f2)")
                    val=$(grep "^CMAKE_CUDA_COMPILER:" "$build_dir/CMakeCache.txt" 2>/dev/null | cut -d= -f2)
                    if [[ -n "$val" && "$val" != *NOTFOUND* && -x "$val" ]]; then
                        cmake_flags+=("-DCMAKE_CUDA_COMPILER=$val")
                    elif [[ -n "${CUDACXX:-}" ]]; then
                        cmake_flags+=("-DCMAKE_CUDA_COMPILER=$CUDACXX")
                    fi
                fi
                rm -rf "$build_dir"
                if ! { cmake -B "$build_dir" -DCMAKE_BUILD_TYPE=Release "${cmake_flags[@]}" 2>&1 | tail -5 \
                      && cmake --build "$build_dir" --config Release -j"$nproc" 2>&1 | tail -5; }; then
                    echo "  Build failed at this commit."
                    return 1
                fi
                echo "  Clean rebuild succeeded"
            fi
        else
            echo "  No build directory — run cmake manually first."
            return 1
        fi

        if [[ ! -x "$binary" ]]; then
            echo "  Binary missing after build."
            return 1
        fi

        # Shallow smoke: --version exits 0 on both llama.cpp and ik_llama.cpp.
        # (Note: ik_llama's --help exits 1 by design, so --help is not portable.)
        if ! timeout 10 "$binary" --version >/dev/null 2>&1; then
            echo "  Binary crashes on --version at this commit."
            return 1
        fi

        # Deep smoke: load smallest real model in a dedicated process on a
        # free port; accept any of several version-robust "ready" markers.
        local test_model
        test_model=$(ls -S ~/ai_models/*.gguf 2>/dev/null \
            | grep -viE 'mmproj|projector' \
            | tail -1)
        if [[ -z "$test_model" ]]; then
            echo "  Skipping model launch test (no GGUF models found)"
            return 0
        fi
        echo "  Testing model launch: $(basename "$test_model")"
        local test_port
        test_port=$(python3 -c 'import socket; s=socket.socket(); s.bind(("127.0.0.1",0)); print(s.getsockname()[1]); s.close()' 2>/dev/null || echo 18081)
        local test_log
        test_log=$(mktemp)
        timeout 120s "$binary" -m "$test_model" \
            --ctx-size 512 --parallel 1 --port "$test_port" \
            --host 127.0.0.1 -ngl 0 > "$test_log" 2>&1 &
        local test_pid=$! ready=0
        for _ in $(seq 1 120); do
            if grep -qE "server is listening|main loop|model loaded|HTTP server listening" "$test_log"; then
                ready=1; break
            fi
            kill -0 "$test_pid" 2>/dev/null || break
            sleep 1
        done
        kill "$test_pid" 2>/dev/null; wait "$test_pid" 2>/dev/null
        if (( ready )); then
            echo "  Model launch test: PASSED ✓"
            rm -f "$test_log"
            return 0
        fi
        echo "  Model launch test: FAILED at this commit"
        echo "  --- last 10 lines of test output ---"
        tail -10 "$test_log" | sed 's/^/    /'
        rm -f "$test_log"
        return 1
    }

    echo "═══ llm-server backend updater ═══"

    IK_DIR="$HOME/ik_llama.cpp"
    MAIN_DIR="$HOME/llama.cpp"
    # Status codes from update_backend: 0=updated, 2=already up to date, 1=failed/skipped
    ik_status=99
    main_status=99

    if [[ -d "$IK_DIR" ]]; then
        ik_status=0
        update_backend "ik_llama.cpp" "$IK_DIR" || ik_status=$?
    else
        echo "ik_llama.cpp not found at $IK_DIR — skipping"
    fi

    if [[ -d "$MAIN_DIR" ]]; then
        main_status=0
        update_backend "llama.cpp" "$MAIN_DIR" || main_status=$?
    else
        echo "llama.cpp not found at $MAIN_DIR — skipping"
    fi

    _update_label() {
        case "$1" in
            0)  echo "updated ✓" ;;
            2)  echo "already up to date" ;;
            99) echo "not present" ;;
            *)  echo "failed/skipped" ;;
        esac
    }

    echo ""
    echo "═══ Update summary ═══"
    echo "  ik_llama.cpp: $(_update_label "$ik_status")"
    echo "  llama.cpp:    $(_update_label "$main_status")"

    # Show what's available now
    for dir in "$IK_DIR" "$MAIN_DIR"; do
        curr_bin="$dir/build/bin/llama-server"
        if [[ -x "$curr_bin" ]]; then
            ver=$("$curr_bin" --version 2>/dev/null | grep -m1 "version:" || echo "unknown")
            [[ "$ver" == "unknown" ]] && ver=$(cd "$dir" && git log --oneline -1 2>/dev/null || echo "unknown")
            echo "  $(basename "$dir"): $ver"
        fi
    done

    exit 0
fi

if [[ ! -f "$MODEL_ARG" ]]; then
    # Try as relative to model dir
    if [[ -f "$MODEL_DIR/$MODEL_ARG" ]]; then
        MODEL_ARG="$MODEL_DIR/$MODEL_ARG"
    else
        echo "Error: Model not found: $MODEL_ARG"
        exit 1
    fi
fi

MODEL_PATH="$MODEL_ARG"
MODEL_NAME="$(basename "$MODEL_PATH")"

# Apply --server-bin override (before binary check so it can provide the binary)
if [[ -n "$USER_SERVER_BIN" ]]; then
    if [[ ! -x "$USER_SERVER_BIN" ]]; then
        echo "Error: --server-bin binary not found or not executable: $USER_SERVER_BIN"
        exit 1
    fi
    LLAMA_SERVER="$USER_SERVER_BIN"
    # Setup lib hub for the new binary
    setup_lib_hub "$LLAMA_SERVER"
fi

if [[ -z "$LLAMA_SERVER" ]]; then
    echo "Error: llama-server binary not found."
    echo "Set LLAMA_SERVER env var, use --server-bin, or install ik_llama.cpp / llama.cpp."
    exit 1
fi

# Apply --lib-path override (prepend to LD_LIBRARY_PATH)
if [[ -n "$USER_LIB_PATH" ]]; then
    export LD_LIBRARY_PATH="${USER_LIB_PATH}:${LD_LIBRARY_PATH:-}"
fi

# Verify binary can actually run (catches broken shared lib chains)
# Note: --help exits 1 normally, so check for shared lib errors in output instead
_bin_check=$(timeout 5 "$LLAMA_SERVER" --help 2>&1 || true)
if [[ "$_bin_check" == *"shared libraries"* ]]; then
    echo "Error: $LLAMA_SERVER has broken shared libraries:"
    echo "$_bin_check" | grep "shared libraries" | head -3
    echo ""
    echo "Fix: rebuild (cmake --build build --config Release)"
    # Try the other backend before giving up
    if [[ "$LLAMA_SERVER" == *ik_llama* ]]; then
        ALT_BIN="$HOME/llama.cpp/build/bin/llama-server"
    else
        ALT_BIN="$HOME/ik_llama.cpp/build/bin/llama-server"
    fi
    if [[ -x "$ALT_BIN" ]]; then
        setup_lib_hub "$ALT_BIN"
        _alt_check=$(timeout 5 "$ALT_BIN" --help 2>&1 || true)
        if [[ "$_alt_check" != *"shared libraries"* ]]; then
            echo "Falling back to: $ALT_BIN"
            LLAMA_SERVER="$ALT_BIN"
        else
            echo "Error: Both backends have broken shared libraries."
            exit 1
        fi
    else
        exit 1
    fi
fi

# Detect if we're running ik_llama.cpp (supports --split-mode graph)
# Note: can't use pipe + grep -q under pipefail (SIGPIPE kills pipe).
# Reuse _bin_check from above, or check path.
IS_IK_LLAMA=0
if [[ "$LLAMA_SERVER" == *ik_llama* ]]; then
    IS_IK_LLAMA=1
elif [[ "${_bin_check:-}" == *ikawrakow* || "${_bin_check:-}" == *"split-mode-graph"* ]]; then
    IS_IK_LLAMA=1
fi

export CUDA_DEVICE_ORDER=PCI_BUS_ID

log() { [[ "$VERBOSE" == "1" ]] && echo "[DEBUG] $*" >&2 || true; }

_is_llama_proc() {
    local p="${1:-}"
    [[ -z "$p" ]] && return 1
    local cmd
    cmd=$(ps -o comm= -p "$p" 2>/dev/null | tr -d ' ' || true)
    case "$cmd" in
        llama-server|llama-cli|llama|ik_llama-server|ik_llama) return 0 ;;
        *) return 1 ;;
    esac
}

_port_listener_pids() {
    lsof -nP -t -iTCP:"${PORT}" -sTCP:LISTEN 2>/dev/null || true
}

_stop_llama_listeners_for_ai_tune() {
    local port_pids p cmd
    port_pids=$(_port_listener_pids)
    [[ -z "$port_pids" ]] && return 0

    echo "Checking existing listener on port ${PORT} before AI tuning..."
    for p in $port_pids; do
        if _is_llama_proc "$p"; then
            echo "  Stopping llama-compatible listener pid $p"
            kill -TERM "$p" 2>/dev/null || true
        else
            cmd=$(ps -o comm= -p "$p" 2>/dev/null | tr -d ' ' || true)
            [[ -z "$cmd" ]] && cmd="unknown"
            echo "  WARN: port ${PORT} held by foreign process '$cmd' (pid $p); refusing to kill" >&2
        fi
    done

    sleep 3
    port_pids=$(_port_listener_pids)
    for p in $port_pids; do
        _is_llama_proc "$p" && kill -KILL "$p" 2>/dev/null || true
    done
}

# If AI tuning, stop only llama-compatible listeners first so GPU detection sees true free VRAM.
# Dry-run must remain side-effect free and never touch existing listeners.
if (( DO_AI_TUNE && ! DRY_RUN )); then
    _stop_llama_listeners_for_ai_tune
    if [[ "${LLM_SERVER_TEST_STOP_AFTER_AI_TUNE_PRECLEANUP:-0}" == "1" ]]; then
        exit 0
    fi
fi

# ═══════════════════════════════════════════════════════════════
# Section 2: Hardware Detection
# ═══════════════════════════════════════════════════════════════

# ── Update check ──
# Checks llm-server repo + backends for available updates.
# Dismiss file suppresses the check for 7 days.
LLM_SERVER_REPO="${LLM_SERVER_REPO:-$HOME/llm-server}"
UPDATE_DISMISS_FILE="$CACHE_DIR/update_dismissed"
UPDATE_DISMISS_DAYS=7

_check_repo_behind() {
    local repo_dir="$1" label="$2"
    [[ -d "$repo_dir/.git" ]] || return 1
    # Quick fetch (timeout 5s, no output)
    git -C "$repo_dir" remote update --prune >/dev/null 2>&1 &
    local fetch_pid=$!
    ( sleep 5; kill "$fetch_pid" 2>/dev/null ) &
    wait "$fetch_pid" 2>/dev/null || return 1
    local local_head remote_head
    local_head=$(git -C "$repo_dir" rev-parse HEAD 2>/dev/null) || return 1
    remote_head=$(git -C "$repo_dir" rev-parse '@{u}' 2>/dev/null) || return 1
    [[ "$local_head" != "$remote_head" ]] && echo "$label" && return 0
    return 1
}

_should_check_updates() {
    # Skip if dismissed recently
    if [[ -f "$UPDATE_DISMISS_FILE" ]]; then
        local dismissed_at
        dismissed_at=$(cat "$UPDATE_DISMISS_FILE" 2>/dev/null)
        local now
        now=$(date +%s)
        if (( now - dismissed_at < UPDATE_DISMISS_DAYS * 86400 )); then
            return 1
        fi
    fi
    return 0
}

if [[ -z "${LLM_SERVER_UPDATE_CHECKED:-}" ]] && _should_check_updates; then
    _updates=()
    # Check llm-server repo
    _check_repo_behind "$LLM_SERVER_REPO" "llm-server" && _updates+=("llm-server")
    # Check backends (derive repo root from binary path)
    _ik_dir="$(dirname "$(dirname "$(dirname "$LLAMA_SERVER")")")"
    [[ "$_ik_dir" == *ik_llama* ]] && _check_repo_behind "$_ik_dir" "ik_llama.cpp" && _updates+=("ik_llama.cpp")
    _ll_dir="$HOME/llama.cpp"
    [[ -d "$_ll_dir" ]] && _check_repo_behind "$_ll_dir" "llama.cpp" && _updates+=("llama.cpp")

    if (( ${#_updates[@]} > 0 )); then
        echo -e "\033[1;31m⚠ Updates available: ${_updates[*]}\033[0m"
        if [[ -t 0 ]] || [[ -t 1 ]]; then
            read -r -t 15 -p "  Update now? [y/N/d=dismiss ${UPDATE_DISMISS_DAYS} days] " _answer < /dev/tty 2>/dev/null || _answer=""
        else
            echo "  (skipped in non-interactive mode - run directly to update)"
            _answer="n"
        fi
        case "${_answer,,}" in
            y)
                echo "Running --update..."
                exec "$0" --update
                ;;
            d)
                mkdir -p "$CACHE_DIR"
                date +%s > "$UPDATE_DISMISS_FILE"
                echo "  Dismissed for ${UPDATE_DISMISS_DAYS} days."
                ;;
            *)
                echo "  Skipped."
                ;;
        esac
    fi
    export LLM_SERVER_UPDATE_CHECKED=1
fi

echo "═══ llm-server v$VERSION ═══"

echo "Binary: $LLAMA_SERVER"
(( IS_IK_LLAMA )) && echo "Backend: ik_llama.cpp (graph split enabled)"

# Detect physical CPU cores
# `|| true` guards pipefail — lscpu may be absent (containers, Alpine, WSL)
PHYSICAL_CORES=$(lscpu 2>/dev/null | awk '/^Core\(s\) per socket:/ {cores=$NF} /^Socket\(s\):/ {socks=$NF} END {print cores * socks}' || true)
PHYSICAL_CORES=${PHYSICAL_CORES:-4}

# Detect RAM
RAM_AVAIL_MB=$(awk '/MemAvailable/ {printf "%.0f", $2/1024}' /proc/meminfo)
RAM_TOTAL_MB=$(awk '/MemTotal/ {printf "%.0f", $2/1024}' /proc/meminfo)

echo "CPU: ${PHYSICAL_CORES} physical cores"

# Apply --ram-budget cap
if (( RAM_BUDGET_MB > 0 && RAM_BUDGET_MB < RAM_AVAIL_MB )); then
    RAM_AVAIL_MB=$RAM_BUDGET_MB
    echo "RAM: ${RAM_AVAIL_MB}MB available (capped by --ram-budget) / ${RAM_TOTAL_MB}MB total"
else
    echo "RAM: ${RAM_AVAIL_MB}MB available / ${RAM_TOTAL_MB}MB total"
fi

# Detect GPUs
GPU_COUNT=0
declare -a GPU_INDEX GPU_NAME GPU_VRAM_TOTAL GPU_VRAM_FREE GPU_PCIE_WIDTH GPU_PCIE_GEN GPU_BANDWIDTH GPU_COMPUTE_CAP

if (( CPU_ONLY )); then
    echo "GPUs: skipped (--cpu flag)"
elif command -v nvidia-smi &>/dev/null; then
    while IFS= read -r line; do
        # Parse comma-separated fields from nvidia-smi
        IFS=',' read -ra fields <<< "$line"
        [[ ${#fields[@]} -lt 6 ]] && continue
        idx=$(echo "${fields[0]}" | tr -d ' ')
        name=$(echo "${fields[1]}" | sed 's/^ //')
        vram_total=$(echo "${fields[2]}" | tr -d ' ')
        vram_free=$(echo "${fields[3]}" | tr -d ' ')
        pcie_width=$(echo "${fields[4]}" | tr -d ' ')
        pcie_gen=$(echo "${fields[5]}" | tr -d ' ')
        # compute_cap is "8.6", "6.1", etc — may be absent on very old drivers
        compute_cap=$(echo "${fields[6]:-0.0}" | tr -d ' ')
        [[ -z "$compute_cap" || "$compute_cap" == "[N/A]" ]] && compute_cap="0.0"

        # Skip GPUs with less than 500MB free
        if (( vram_free < 500 )); then
            log "Skipping GPU $idx ($name): only ${vram_free}MB free"
            continue
        fi
        GPU_INDEX+=("$idx")
        GPU_NAME+=("$name")
        GPU_VRAM_TOTAL+=("$vram_total")
        GPU_VRAM_FREE+=("$vram_free")
        GPU_PCIE_WIDTH+=("$pcie_width")
        GPU_PCIE_GEN+=("$pcie_gen")
        GPU_COMPUTE_CAP+=("$compute_cap")
        # Effective bandwidth score: width * gen (higher = faster)
        GPU_BANDWIDTH+=( $(( pcie_width * pcie_gen )) )
        GPU_COUNT=$(( GPU_COUNT + 1 ))
    done < <(nvidia-smi --query-gpu=index,name,memory.total,memory.free,pcie.link.width.current,pcie.link.gen.current,compute_cap --format=csv,noheader,nounits 2>/dev/null)
fi

# Apply --gpus filter (restrict to specified CUDA indices)
if [[ -n "$GPUS_FILTER" && $GPU_COUNT -gt 0 ]]; then
    IFS=',' read -ra ALLOWED_GPUS <<< "$GPUS_FILTER"
    declare -a NEW_GPU_INDEX NEW_GPU_NAME NEW_GPU_VRAM_TOTAL NEW_GPU_VRAM_FREE NEW_GPU_PCIE_WIDTH NEW_GPU_PCIE_GEN NEW_GPU_BANDWIDTH NEW_GPU_COMPUTE_CAP
    NEW_GPU_COUNT=0
    for i in $(seq 0 $(( GPU_COUNT - 1 ))); do
        for allowed in "${ALLOWED_GPUS[@]}"; do
            if [[ "${GPU_INDEX[$i]}" == "$allowed" ]]; then
                NEW_GPU_INDEX+=("${GPU_INDEX[$i]}")
                NEW_GPU_NAME+=("${GPU_NAME[$i]}")
                NEW_GPU_VRAM_TOTAL+=("${GPU_VRAM_TOTAL[$i]}")
                NEW_GPU_VRAM_FREE+=("${GPU_VRAM_FREE[$i]}")
                NEW_GPU_PCIE_WIDTH+=("${GPU_PCIE_WIDTH[$i]}")
                NEW_GPU_PCIE_GEN+=("${GPU_PCIE_GEN[$i]}")
                NEW_GPU_BANDWIDTH+=("${GPU_BANDWIDTH[$i]}")
                NEW_GPU_COMPUTE_CAP+=("${GPU_COMPUTE_CAP[$i]}")
                (( NEW_GPU_COUNT++ )) || true
                break
            fi
        done
    done
    if (( NEW_GPU_COUNT == 0 )); then
        echo "Error: --gpus filter '$GPUS_FILTER' matched no detected GPUs"
        exit 1
    fi
    GPU_INDEX=("${NEW_GPU_INDEX[@]}")
    GPU_NAME=("${NEW_GPU_NAME[@]}")
    GPU_VRAM_TOTAL=("${NEW_GPU_VRAM_TOTAL[@]}")
    GPU_VRAM_FREE=("${NEW_GPU_VRAM_FREE[@]}")
    GPU_PCIE_WIDTH=("${NEW_GPU_PCIE_WIDTH[@]}")
    GPU_PCIE_GEN=("${NEW_GPU_PCIE_GEN[@]}")
    GPU_BANDWIDTH=("${NEW_GPU_BANDWIDTH[@]}")
    GPU_COMPUTE_CAP=("${NEW_GPU_COMPUTE_CAP[@]}")
    GPU_COUNT=$NEW_GPU_COUNT
    echo "GPU filter: using only GPU(s) $GPUS_FILTER ($GPU_COUNT matched)"
fi

if (( GPU_COUNT == 0 )); then
    echo "GPUs: none detected (CPU-only mode)"
else
    echo "GPUs: $GPU_COUNT detected"
    # Sort GPUs by bandwidth DESC, then VRAM_TOTAL DESC, then compute_cap DESC.
    # Tiebreakers matter on heterogeneous rigs where PCIe bandwidth ties
    # (e.g. 3080 Ti + 1080 Ti both at x8 gen1) — without them, nvidia-smi
    # order wins and we can pick the slower card for single_gpu strategy.
    declare -a GPU_ORDER
    GPU_ORDER=($(
        for i in $(seq 0 $(( GPU_COUNT - 1 ))); do
            # compute_cap "8.6" -> 86 for integer sort; missing -> 0
            cc_int=$(awk "BEGIN{printf \"%d\", ${GPU_COMPUTE_CAP[$i]:-0}*10}")
            printf "%d %d %d %d\n" "${GPU_BANDWIDTH[$i]}" "${GPU_VRAM_TOTAL[$i]}" "$cc_int" "$i"
        done | sort -k1,1rn -k2,2rn -k3,3rn | awk '{print $NF}'
    ))

    for i in $(seq 0 $(( GPU_COUNT - 1 ))); do
        gi=${GPU_ORDER[$i]}
        echo "  GPU${GPU_INDEX[$gi]}: ${GPU_NAME[$gi]} ${GPU_VRAM_FREE[$gi]}MB free / ${GPU_VRAM_TOTAL[$gi]}MB total (PCIe x${GPU_PCIE_WIDTH[$gi]} gen${GPU_PCIE_GEN[$gi]})"
    done
fi

placement_cache_key_input() {
    local parts=(
        "version=$VERSION"
        "model=$MODEL_NAME"
        "bytes=$TOTAL_SIZE_BYTES"
        "ctx=$CTX_SIZE"
        "kv=$KV_QUALITY"
        "backend=$BACKEND_TAG"
        "llama_server=$LLAMA_SERVER"
        "gpu_filter=${GPUS_FILTER:-all}"
        "ram_avail=$RAM_AVAIL_MB"
        "ram_budget=$RAM_BUDGET_MB"
        "gpu_count=$GPU_COUNT"
    )
    local i free_bucket total_bucket
    for i in $(seq 0 $(( GPU_COUNT - 1 ))); do
        # Bucket free VRAM to 1024MB so normal allocator jitter does not churn
        # cache files, but materially different co-tenancy invalidates placement.
        free_bucket=$(( (GPU_VRAM_FREE[$i] / 1024) * 1024 ))
        total_bucket=$(( (GPU_VRAM_TOTAL[$i] / 1024) * 1024 ))
        parts+=("gpu${i}_index=${GPU_INDEX[$i]}")
        parts+=("gpu${i}_name=${GPU_NAME[$i]}")
        parts+=("gpu${i}_free_bucket=${free_bucket}")
        parts+=("gpu${i}_total_bucket=${total_bucket}")
        parts+=("gpu${i}_pcie=x${GPU_PCIE_WIDTH[$i]}g${GPU_PCIE_GEN[$i]}")
        parts+=("gpu${i}_bandwidth=${GPU_BANDWIDTH[$i]}")
        parts+=("gpu${i}_compute=${GPU_COMPUTE_CAP[$i]}")
    done
    printf '%s\n' "${parts[@]}"
}

# ═══════════════════════════════════════════════════════════════
# Section 3: Model Detection
# ═══════════════════════════════════════════════════════════════

# Get total model size (handles split GGUFs)
MODEL_DIR_PATH=$(dirname "$MODEL_PATH")
SPLIT_PATTERN=$(echo "$MODEL_NAME" | sed 's/-[0-9]*-of-[0-9]*\.gguf/.gguf/')
# `|| echo 0` guards pipefail — find/du may fail on oddly-shared dirs,
# networked filesystems, or if the split pattern matches nothing.
TOTAL_SIZE_BYTES=$(find "$MODEL_DIR_PATH" -name "${SPLIT_PATTERN%.gguf}*" -type f -print0 2>/dev/null | xargs -0 du -scb 2>/dev/null | tail -1 | awk '{print $1}' || echo 0)
if [[ -z "$TOTAL_SIZE_BYTES" || "$TOTAL_SIZE_BYTES" == "0" ]]; then
    TOTAL_SIZE_BYTES=$(du -sb "$MODEL_PATH" 2>/dev/null | awk '{print $1}' || echo 0)
fi
TOTAL_SIZE_MB=$(awk "BEGIN {printf \"%.0f\", $TOTAL_SIZE_BYTES/1048576}")
TOTAL_SIZE_GB=$(awk "BEGIN {printf \"%.1f\", $TOTAL_SIZE_BYTES/1073741824}")

# Read GGUF metadata via the shared parse_gguf.py helper. This sets ~26 shell
# variables (LAYER_COUNT, EXPERT_COUNT, …, GGUF_MODEL_NAME, etc.) via
# eval-of-VAR=value lines. Falls back to all-zero/empty defaults on any error
# so every downstream `${VAR:-0}` stays defined even if Python is missing.
if [[ -f "$PARSE_GGUF" ]]; then
    eval "$(python3 "$PARSE_GGUF" --format shell "$MODEL_PATH" 2>/dev/null || true)"
else
    echo "Warning: parse_gguf.py not found next to llm-server ($SCRIPT_DIR). Re-run install.sh." >&2
fi

LAYER_COUNT=${LAYER_COUNT:-0}
EXPERT_COUNT=${EXPERT_COUNT:-0}
HEAD_COUNT_KV=${HEAD_COUNT_KV:-0}
KEY_LENGTH=${KEY_LENGTH:-0}
VALUE_LENGTH=${VALUE_LENGTH:-0}
HAS_SSM=${HAS_SSM:-0}
HAS_FUSED=${HAS_FUSED:-0}
EXPERT_BYTES=${EXPERT_BYTES:-0}
NON_EXPERT_BYTES=${NON_EXPERT_BYTES:-0}
MODEL_ARCH=${MODEL_ARCH:-unknown}
EMBEDDING_LENGTH=${EMBEDDING_LENGTH:-0}
FEED_FORWARD_LENGTH=${FEED_FORWARD_LENGTH:-0}
EXPERT_USED_COUNT=${EXPERT_USED_COUNT:-0}
EXPERT_FF=${EXPERT_FF:-0}
EXPERT_SHARED_FF=${EXPERT_SHARED_FF:-0}
KV_LORA_RANK=${KV_LORA_RANK:-0}
Q_LORA_RANK=${Q_LORA_RANK:-0}
ROPE_DIM=${ROPE_DIM:-0}
KEY_LENGTH_MLA=${KEY_LENGTH_MLA:-0}
VALUE_LENGTH_MLA=${VALUE_LENGTH_MLA:-0}
LEADING_DENSE=${LEADING_DENSE:-0}
SLIDING_WINDOW=${SLIDING_WINDOW:-0}
FULL_ATTN_INTERVAL=${FULL_ATTN_INTERVAL:-0}
HAS_SHEXP=${HAS_SHEXP:-0}
CTX_TRAIN=${CTX_TRAIN:-0}
GGUF_MODEL_NAME="${GGUF_MODEL_NAME:-}"
GGUF_BASENAME="${GGUF_BASENAME:-}"
GGUF_QUANTIZED_BY="${GGUF_QUANTIZED_BY:-}"
[[ "$LAYER_COUNT" == "0" ]] && LAYER_COUNT=48 && echo "Warning: Could not detect layer count, using default (48)"

# Properly-tagged DeepSeek V4 GGUFs use arch=deepseek4 (added in PR #22378 +
# the antirez fork). Stock llama.cpp master doesn't recognize this arch yet,
# so a non-fork binary will fail to load. Just warn — if the user pointed
# LLAMA_SERVER at a fork build, it'll work.
if [[ "$MODEL_ARCH" == "deepseek4" ]]; then
    echo "Note: arch=deepseek4 — needs a build from llama.cpp PR #22378 or" >&2
    echo "      the antirez fork. Stock llama.cpp/ik_llama.cpp won't load it." >&2
fi

# DeepSeek V4 Flash GGUFs from stock converters get tagged as `deepseek2` but
# carry V4 metadata (key_length_mla == rope.dimension_count → zero "nope" head
# dim, hits GGML_ASSERT(n_embd_head_qk_nope >= 1) at model load on stock builds).
# Warn — don't bail. If LLAMA_SERVER points at a fork build (antirez or
# PR #22378) the load will succeed.
if [[ "$MODEL_ARCH" == "deepseek2" ]] && (( KEY_LENGTH_MLA > 0 )) && (( KEY_LENGTH_MLA <= ROPE_DIM )); then
    cat >&2 <<EOF
Warning: this GGUF looks like DeepSeek V4 Flash mistagged as deepseek2.
         key_length_mla=$KEY_LENGTH_MLA, rope.dimension_count=$ROPE_DIM
         Stock llama.cpp / ik_llama.cpp will crash loading this model.
         You need a fork build:
           - https://github.com/antirez/llama.cpp-deepseek-v4-flash (CPU/Metal)
           - llama.cpp PR #22378 (CUDA-capable, draft)
         Point LLAMA_SERVER at the fork's llama-server binary if you haven't.
EOF
fi

IS_MOE=0
(( EXPERT_COUNT > 1 )) && IS_MOE=1

echo ""
echo "Model: $MODEL_NAME"
echo "Size: ${TOTAL_SIZE_GB}GB (${TOTAL_SIZE_MB}MB)"
echo "Architecture: ${LAYER_COUNT} layers, $([ "$IS_MOE" = "1" ] && echo "${EXPERT_COUNT} experts (MoE)" || echo "dense")$([ "$HAS_FUSED" = "1" ] && echo ", fused up|gate")"

(( HAS_FUSED && IS_IK_LLAMA )) && echo "Info: Fused up|gate model detected. Optimized ik_llama.cpp kernels enabled."

# Health check timeout: 240s base, +60s per 100GB of model size
HEALTH_TIMEOUT=$(( 240 + TOTAL_SIZE_MB / 1700 ))

# Section 4: Binary Selection & Support Checks
# ═══════════════════════════════════════════════════════════════

# Check if model is known to be unsupported by ik_llama.cpp
# Note: gemma4 was added in ik_llama.cpp #1581 — no longer excluded
# The runtime auto-fallback (Section 6a) handles any remaining unsupported architectures
IS_UNSUPPORTED_IK=0

# Re-detect binary if needed
if [[ -z "$USER_SERVER_BIN" ]]; then
    if (( IS_UNSUPPORTED_IK )); then
        # Prefer mainline for unsupported models
        MAINLINE="$HOME/llama.cpp/build/bin/llama-server"
        if [[ -x "$MAINLINE" ]]; then
            LLAMA_SERVER="$MAINLINE"
        fi
    fi
fi

# Apply final binary choice
if [[ -n "$USER_SERVER_BIN" ]]; then
    LLAMA_SERVER="$USER_SERVER_BIN"
fi

if [[ -z "$LLAMA_SERVER" || ! -x "$LLAMA_SERVER" ]]; then
    echo "Error: llama-server binary not found or not executable."
    exit 1
fi

setup_lib_hub "$LLAMA_SERVER"

# Detect if we're running ik_llama.cpp (supports --split-mode graph)
# Note: can't pipe --help | grep -q under pipefail — --help exits 1 and grep -q
# causes SIGPIPE, both propagate as pipe failure. Use path check + variable instead.
SERVER_HELP=$("$LLAMA_SERVER" --help 2>&1 || true)
IS_IK_LLAMA=0
if [[ "$LLAMA_SERVER" == *ik_llama* ]]; then
    IS_IK_LLAMA=1
else
    [[ "$SERVER_HELP" == *ikawrakow* ]] && IS_IK_LLAMA=1
fi
SUPPORTS_REASONING_FLAG=0
[[ "$SERVER_HELP" == *"--reasoning"* ]] && SUPPORTS_REASONING_FLAG=1

(( IS_IK_LLAMA )) && echo "Backend: ik_llama.cpp (graph split enabled)" || echo "Backend: llama.cpp (mainline)"

# Backend tag used as cache-key suffix — one tuned/MoE config per backend,
# since ik-only flags and quant layouts aren't portable.
BACKEND_TAG="llama"
(( IS_IK_LLAMA )) && BACKEND_TAG="ik"

# WSL2 detection — pinning memory via --mlock on WSL2 can freeze the Windows
# host when the guest exhausts its allocation. Gate mlock and similar pinning
# behind this flag.
IS_WSL2=0
if grep -qiE "microsoft|wsl" /proc/version 2>/dev/null; then
    IS_WSL2=1
fi

# ═══════════════════════════════════════════════════════════════
# Section 5: Smart Flag Builder

# ── Context shift: crashes on hybrid SSM/Mamba models ──
CONTEXT_SHIFT_FLAG=""
if (( HAS_SSM == 1 )); then
    CONTEXT_SHIFT_FLAG="--no-context-shift"
    echo "  SSM/Mamba hybrid → context-shift disabled"
fi

# ── Compute totals for decisions ──
TOTAL_VRAM_MB=0
BEST_GPU_VRAM=0
for i in $(seq 0 $(( GPU_COUNT - 1 ))); do
    (( TOTAL_VRAM_MB += GPU_VRAM_FREE[$i] )) || true
    (( GPU_VRAM_FREE[$i] > BEST_GPU_VRAM )) && BEST_GPU_VRAM=${GPU_VRAM_FREE[$i]}
done

# ── Memory Analysis (Informational) ──
TOTAL_MEM_MB=$(( TOTAL_VRAM_MB + RAM_AVAIL_MB ))
ESTIMATED_TOTAL_NEEDED=$(( TOTAL_SIZE_MB + TOTAL_SIZE_MB / 10 + SYSTEM_HEADROOM_MB )) # Model + ~10% overhead + system headroom

if (( TOTAL_SIZE_MB > TOTAL_MEM_MB )); then
    echo "⚠️  WARNING: Model (${TOTAL_SIZE_GB}GB) is larger than your total available memory (${TOTAL_MEM_MB}MB)."
    echo "   A system crash or heavy swapping is likely. Proceeding anyway..."
elif (( ESTIMATED_TOTAL_NEEDED > TOTAL_MEM_MB )); then
    echo "ℹ️  INFO: Model + KV Cache (~${ESTIMATED_TOTAL_NEEDED}MB) is very close to your total memory (${TOTAL_MEM_MB}MB)."
    echo "   Expect potential instability or slow performance if memory fills up."
else
    echo "✓ Memory: Model and context estimated to fit within available RAM/VRAM."
fi

FITS_ON_GPU=0
(( TOTAL_SIZE_MB * VRAM_OVERHEAD_PERCENT / 100 <= TOTAL_VRAM_MB )) && FITS_ON_GPU=1

# Free RAM after model is loaded (estimate: model goes to VRAM if it fits, else spills)
if (( FITS_ON_GPU )); then
    RAM_AFTER_LOAD=$RAM_AVAIL_MB
else
    RAM_ON_CPU=$(( TOTAL_SIZE_MB - TOTAL_VRAM_MB ))
    (( RAM_ON_CPU < 0 )) && RAM_ON_CPU=0
    RAM_AFTER_LOAD=$(( RAM_AVAIL_MB - RAM_ON_CPU ))
    (( RAM_AFTER_LOAD < 0 )) && RAM_AFTER_LOAD=0
fi

# ── Batch sizes: scale with available VRAM ──
# Larger batches = faster prompt processing but use more VRAM
# Small models with lots of VRAM headroom → max batches
# Large models barely fitting → conservative batches
if (( FITS_ON_GPU && BEST_GPU_VRAM > TOTAL_SIZE_MB + SINGLE_GPU_HEADROOM_MB )); then
    # Tons of VRAM headroom
    BATCH=8192; UBATCH=1024
    echo "  VRAM headroom large → batch=$BATCH ubatch=$UBATCH"
elif (( FITS_ON_GPU )); then
    BATCH=4096; UBATCH=512
    echo "  Model fits on GPU → batch=$BATCH ubatch=$UBATCH"
else
    # MoE offload / CPU spill — GPU VRAM is tight
    BATCH=2048; UBATCH=512
    echo "  GPU+CPU split → batch=$BATCH ubatch=$UBATCH"
fi

# ── KV cache type: high=f16, mid=q8_0 (default), low=q4_0, auto=fit-based ──
# KV cache size estimate, dispatched by family (as of 2026-04):
#   standard — dense GQA/MQA (llama/mistral/qwen2-3/phi/mixtral/olmo/...)
#   mla      — compressed KV projection (deepseek2/3, kimi-k2, minicpm3, plm, mistral4)
#   iswa     — interleaved sliding-window (gemma2/3, llama4, cohere2, exaone4, plamo3)
#   ssm      — pure SSM or SSM/attention hybrid (mamba, jamba, qwen3next,
#              granitehybrid, falconh1, nemotron-h, lfm2) — KV only on attn layers
# Detection is metadata-key driven (not arch allowlist) so new archs Just Work
# as long as they emit the standard GGUF attention/SSM keys.
KV_FAMILY="standard"
KV_FAMILY_NOTE=""
_kv_bytes_per_layer_per_token=$(( HEAD_COUNT_KV * (KEY_LENGTH + VALUE_LENGTH) ))
_iswa_bytes_per_bpe=0
if (( KV_LORA_RANK > 0 )); then
    KV_FAMILY="mla"
    # MLA stores compressed c^{KV} + RoPE'd key once per layer (not K+V ×2)
    _kv_elems_total=$(( LAYER_COUNT * CTX_SIZE * (KV_LORA_RANK + ROPE_DIM) ))
    KV_FAMILY_NOTE="MLA (kv_lora=${KV_LORA_RANK}+rope=${ROPE_DIM})"
elif (( HAS_SSM == 1 )); then
    KV_FAMILY="ssm"
    if (( FULL_ATTN_INTERVAL > 0 )); then
        _attn_layers=$(( LAYER_COUNT / FULL_ATTN_INTERVAL ))
        (( _attn_layers < 1 )) && _attn_layers=1
        KV_FAMILY_NOTE="SSM/hybrid (${_attn_layers}/${LAYER_COUNT} attn, interval=${FULL_ATTN_INTERVAL})"
    elif (( HEAD_COUNT_KV == 0 )); then
        _attn_layers=0
        KV_FAMILY_NOTE="Pure SSM (no growing KV)"
    else
        _attn_layers=$(( (LAYER_COUNT + 1) / 2 ))
        KV_FAMILY_NOTE="SSM/hybrid (~${_attn_layers}/${LAYER_COUNT} attn, default)"
    fi
    _kv_elems_total=$(( _attn_layers * CTX_SIZE * _kv_bytes_per_layer_per_token ))
elif (( SLIDING_WINDOW > 0 )); then
    KV_FAMILY="iswa"
    # swa period: interval between full-attention layers. Missing in metadata for
    # most gemma/llama4 GGUFs — default to 6 (matches gemma3; conservative for others).
    _swa_period=6
    case "$MODEL_ARCH" in
        gemma2|cohere2|exaone4|llama4) _swa_period=4 ;;
        gemma3) _swa_period=6 ;;
        plamo3) _swa_period=8 ;;
    esac
    _full_layers=$(( (LAYER_COUNT + _swa_period - 1) / _swa_period ))
    _swa_layers=$(( LAYER_COUNT - _full_layers ))
    _swa_ctx=$CTX_SIZE
    (( _swa_ctx > SLIDING_WINDOW )) && _swa_ctx=$SLIDING_WINDOW
    _kv_elems_total=$(( _full_layers * CTX_SIZE * _kv_bytes_per_layer_per_token + _swa_layers * _swa_ctx * _kv_bytes_per_layer_per_token ))
    KV_FAMILY_NOTE="ISWA (${_full_layers} full + ${_swa_layers} sw@${_swa_ctx})"
else
    _kv_elems_total=$(( LAYER_COUNT * CTX_SIZE * _kv_bytes_per_layer_per_token ))
fi

if (( HEAD_COUNT_KV > 0 && KEY_LENGTH > 0 && VALUE_LENGTH > 0 )) || [[ "$KV_FAMILY" == "mla" ]]; then
    KV_Q4_MB=$(awk "BEGIN {printf \"%.0f\", $_kv_elems_total * 0.5 / 1048576}")
    KV_Q8_MB=$(awk "BEGIN {printf \"%.0f\", $_kv_elems_total * 1.0 / 1048576}")
    KV_F16_MB=$(awk "BEGIN {printf \"%.0f\", $_kv_elems_total * 2.0 / 1048576}")
else
    KV_Q4_MB=$(( LAYER_COUNT * 70 ))
    KV_Q8_MB=$(( LAYER_COUNT * 140 ))
    KV_F16_MB=$(( LAYER_COUNT * 280 ))
fi

_kv_family_tag="${KV_FAMILY_NOTE:+ [${KV_FAMILY_NOTE}]}"
case "$KV_QUALITY" in
    high)
        KV_TYPE="f16"
        echo "  KV cache: f16 (${KV_F16_MB}MB) — highest quality${_kv_family_tag}"
        ;;
    mid)
        KV_TYPE="q8_0"
        echo "  KV cache: q8_0 (${KV_Q8_MB}MB) — balanced (default)${_kv_family_tag}"
        ;;
    low)
        KV_TYPE="q4_0"
        echo "  KV cache: q4_0 (${KV_Q4_MB}MB) — minimum VRAM${_kv_family_tag}"
        ;;
    *)
        echo "Error: --kv-quality must be one of: high, mid, low"
        exit 1
        ;;
esac

# Set KV_TOTAL_MB based on selected type (needed for OOM checks in all strategies)
case "$KV_TYPE" in
    f16)   KV_TOTAL_MB=$KV_F16_MB ;;
    q8_0)  KV_TOTAL_MB=$KV_Q8_MB ;;
    q4_0)  KV_TOTAL_MB=$KV_Q4_MB ;;
esac

# ── Max-context-fit suggestion ──
# KV is (near-)linear in ctx for all four families (standard/MLA/SSM, and ISWA
# once ctx exceeds SLIDING_WINDOW). Use the bytes-per-token we just computed
# for the current KV type to solve for the largest ctx that still leaves
# headroom, then offer it if it's meaningfully bigger than the user's value.
# Skipped when --ctx-size is explicit, non-interactive, or LLM_ASSUME_YES is
# set — no surprises in scripts.
if (( ! CTX_EXPLICIT )) && (( KV_TOTAL_MB > 0 )) && [[ -t 0 ]] && (( ${LLM_ASSUME_YES:-0} == 0 )); then
    _kv_bpt_b=$(( KV_TOTAL_MB * 1048576 / CTX_SIZE ))
    if (( _kv_bpt_b > 0 )); then
        # Budget for KV ≈ all hardware memory, minus the weights (full virtual
        # size — some lives on GPU, some on CPU, all counted), minus 8GB for
        # activations/compute buffers/OS headroom. This matches what the
        # component-based RAM estimator budgets.
        _total_hw_mb=$(( TOTAL_VRAM_MB + RAM_AVAIL_MB ))
        _fixed_overhead_mb=$(( TOTAL_SIZE_MB + 8192 ))
        if (( _total_hw_mb > _fixed_overhead_mb + KV_TOTAL_MB )); then
            _kv_budget_mb=$(( _total_hw_mb - _fixed_overhead_mb ))
            _max_ctx_raw=$(( _kv_budget_mb * 1048576 / _kv_bpt_b ))
            # Cap at the model's trained context length if we know it — pushing
            # past it forces RoPE extrapolation and usually breaks coherence.
            _hw_cap_ctx=$_max_ctx_raw
            if (( CTX_TRAIN > 0 && CTX_TRAIN < _hw_cap_ctx )); then
                _hw_cap_ctx=$CTX_TRAIN
            fi
            # Snap to nearest power-of-two-ish "nice" value at or below the cap
            _suggested_ctx=$CTX_SIZE
            for _c in 32768 65536 131072 262144 524288 1048576 2097152 4194304; do
                (( _c <= _hw_cap_ctx )) && _suggested_ctx=$_c
            done
            if (( _suggested_ctx >= CTX_SIZE * 2 )); then
                _new_kv_mb=$(( _kv_bpt_b * _suggested_ctx / 1048576 ))
                echo ""
                echo "  Context headroom available:"
                echo "    Requested:  ${CTX_SIZE} tokens → ${KV_TOTAL_MB}MB KV (${KV_TYPE})"
                echo "    Max fit:    ${_suggested_ctx} tokens → ${_new_kv_mb}MB KV"
                read -r -p "  Use max context ${_suggested_ctx}? [y/N] " _ctx_ans
                _ctx_ans="${_ctx_ans:-n}"
                if [[ "$_ctx_ans" =~ ^[Yy] ]]; then
                    # Linear rescale — exact for standard/MLA/SSM, slight
                    # overestimate for ISWA past the swa window (safe side).
                    _num=$_suggested_ctx
                    _den=$CTX_SIZE
                    CTX_SIZE=$_suggested_ctx
                    KV_Q4_MB=$(( KV_Q4_MB * _num / _den ))
                    KV_Q8_MB=$(( KV_Q8_MB * _num / _den ))
                    KV_F16_MB=$(( KV_F16_MB * _num / _den ))
                    case "$KV_TYPE" in
                        f16)   KV_TOTAL_MB=$KV_F16_MB ;;
                        q8_0)  KV_TOTAL_MB=$KV_Q8_MB ;;
                        q4_0)  KV_TOTAL_MB=$KV_Q4_MB ;;
                    esac
                    echo "  Context bumped to ${CTX_SIZE} — KV now ${KV_TOTAL_MB}MB"
                fi
            fi
        fi
    fi
fi

# ── Hadamard K-cache: only useful with quantized KV cache ──
KHAD_FLAG=""
if [[ "$KV_TYPE" == "q4_0" || "$KV_TYPE" == "q8_0" ]]; then
    KHAD_FLAG="-khad"
    echo "  Quantized KV cache → Hadamard K-transform enabled"
fi

# ── Prompt cache: scale with free RAM, cap at 10% ──
CRAM_MB=$(( RAM_AFTER_LOAD / 10 ))
(( CRAM_MB > 16384 )) && CRAM_MB=16384  # cap at 16GB
(( CRAM_MB < MIN_CRAM_MB )) && CRAM_MB=0  # disable if too small
if (( GPU_COUNT <= 1 )); then
    if (( CRAM_MB > 0 )); then
        echo "  Prompt cache: ${CRAM_MB}MB (10% of free RAM)"
    else
        echo "  Prompt cache: disabled (not enough free RAM)"
    fi
fi

# ── Thread count ──
# threads: physical cores for generation (hyperthreads hurt)
# threads-batch: can use all cores for prompt processing (parallel work)
THREADS_GEN=$PHYSICAL_CORES
THREADS_BATCH=$PHYSICAL_CORES
echo "  Threads: gen=$THREADS_GEN batch=$THREADS_BATCH (${PHYSICAL_CORES} physical cores)"

# ── Build the flags array ──
COMMON_FLAGS=(
    -m "$MODEL_PATH"
    --host "$HOST"
    --port "$PORT"
    --ctx-size "$CTX_SIZE"
    # Attention
    --flash-attn on
    # Batch sizes (dynamic)
    -b "$BATCH"
    -ub "$UBATCH"
    # KV cache (dynamic type)
    --cache-type-k "$KV_TYPE"
    --cache-type-v "$KV_TYPE"
    # Server
    --jinja
    --threads "$THREADS_GEN"
    --threads-batch "$THREADS_BATCH"
)

USER_REASONING_EXPLICIT=0
for _f in "${EXTRA_LLAMA_FLAGS[@]:-}"; do
    [[ "$_f" == "--reasoning" || "$_f" == "-rea" ]] && USER_REASONING_EXPLICIT=1
done
if (( SUPPORTS_REASONING_FLAG && ! USER_REASONING_EXPLICIT )); then
    # OpenAI-compatible clients generally expect assistant text in message.content.
    # Reasoning can still be enabled explicitly with: -- --reasoning on
    COMMON_FLAGS+=(--reasoning off)
    echo "  Reasoning: off by default for OpenAI-compatible responses"
fi

# User-requested concurrent session count (affects KV slot split + compute buffers).
# Default llama-server behavior (omit flag) uses 4 slots; passing --parallel 1
# during --ai-tune gives the cleanest single-session benchmark signal.
if [[ -n "$PARALLEL_SLOTS" ]]; then
    COMMON_FLAGS+=(--parallel "$PARALLEL_SLOTS")
fi

# Conditional flags
if [[ "$IS_IK_LLAMA" == "1" ]]; then
    COMMON_FLAGS+=(--run-time-repack)
    [[ -n "$KHAD_FLAG" ]] && COMMON_FLAGS+=("$KHAD_FLAG")
    [[ -n "$CONTEXT_SHIFT_FLAG" ]] && COMMON_FLAGS+=("$CONTEXT_SHIFT_FLAG")
    COMMON_FLAGS+=(--defrag-thold 0.1)

    # MoE-specific optimizations
    if (( IS_MOE == 1 )); then
        COMMON_FLAGS+=(-muge)           # merge up/gate expert tensors
        COMMON_FLAGS+=(-ger)            # grouped expert routing
        echo "  MoE model → -muge -ger enabled"
    fi

    if (( GPU_COUNT > 0 )); then
        COMMON_FLAGS+=(-mqkv)
    fi

    # ── Prompt cache budget ──
    # Multi-GPU: checkpoints can OOM smaller GPUs (cuBLAS workspace fails silently).
    # Cap based on VRAM headroom after model+KV+compute.
    # Single-GPU / CPU-only: use RAM-based default (CRAM_MB from above).
    if (( GPU_COUNT > 1 )); then
        MODEL_ON_GPU_MB=$(( TOTAL_SIZE_MB * VRAM_OVERHEAD_PERCENT / 100 ))
        (( MODEL_ON_GPU_MB > TOTAL_VRAM_MB )) && MODEL_ON_GPU_MB=$TOTAL_VRAM_MB
        VRAM_HEADROOM=$(( TOTAL_VRAM_MB - MODEL_ON_GPU_MB - KV_TOTAL_MB - COMPUTE_PER_GPU_MB * GPU_COUNT ))
        (( VRAM_HEADROOM < 0 )) && VRAM_HEADROOM=0
        CACHE_RAM_MB=$(( VRAM_HEADROOM / 2 ))
        (( CACHE_RAM_MB > 4096 )) && CACHE_RAM_MB=4096
        if (( CACHE_RAM_MB < 256 )); then
            CACHE_RAM_MB=0
            MAX_CHECKPOINTS=0
            COMMON_FLAGS+=(-cram 0 --ctx-checkpoints 0)
        else
            MAX_CHECKPOINTS=$(( CACHE_RAM_MB / 200 ))
            (( MAX_CHECKPOINTS < 2 )) && MAX_CHECKPOINTS=2
            (( MAX_CHECKPOINTS > 16 )) && MAX_CHECKPOINTS=16
            COMMON_FLAGS+=(-cram "$CACHE_RAM_MB" --ctx-checkpoints "$MAX_CHECKPOINTS")
        fi
        echo "  Prompt cache: ${CACHE_RAM_MB}MB (VRAM headroom: ${VRAM_HEADROOM}MB), checkpoints: ${MAX_CHECKPOINTS}"
    else
        (( CRAM_MB > 0 )) && COMMON_FLAGS+=(-cram "$CRAM_MB")
    fi
else
    # Mainline-specific or compatible flags
    [[ -n "$CONTEXT_SHIFT_FLAG" ]] && COMMON_FLAGS+=("$CONTEXT_SHIFT_FLAG")
fi

# GPU offloading
if (( GPU_COUNT > 0 )); then
    COMMON_FLAGS+=(-ngl 999 -mg "${GPU_INDEX[${GPU_ORDER[0]}]}")
fi

# Multimodal projector (vision support)
# --mmproj auto (or --vision): auto-detect locally or download from HuggingFace
# --mmproj <path>: use specific file
mmproj_label() {
    local candidate="$1"
    python3 "$PARSE_GGUF" --format json "$candidate" 2>/dev/null | python3 -c '
import json
import sys

try:
    meta = json.load(sys.stdin)
except Exception:
    print("unknown")
    sys.exit(0)

name = meta.get("basename") or meta.get("name") or "unknown"
arch = meta.get("arch") or "unknown"
print(f"{name} ({arch})")
'
}

mmproj_matches_model() {
    local candidate="$1"
    local meta

    [[ -f "$candidate" ]] || return 1
    if [[ "${LLM_SERVER_SKIP_MMPROJ_CHECK:-0}" == "1" ]]; then
        echo "  Warning: skipping mmproj compatibility check for $candidate" >&2
        return 0
    fi

    meta=$(python3 "$PARSE_GGUF" --format json "$candidate" 2>/dev/null) || return 1
    MMPROJ_META="$meta" MMPROJ_FILE="$candidate" TEXT_MODEL_NAME="${GGUF_MODEL_NAME:-}" TEXT_MODEL_BASENAME="${GGUF_BASENAME:-}" python3 -c '
import json
import os
import re
import sys

def norm(value):
    return re.sub(r"[^a-z0-9]+", "", (value or "").lower())

try:
    meta = json.loads(os.environ["MMPROJ_META"])
except Exception:
    sys.exit(1)

if meta.get("arch") != "clip":
    sys.exit(1)

expected_bytes = int(meta.get("non_expert_bytes") or 0) + int(meta.get("expert_bytes") or 0)
if expected_bytes > 0:
    try:
        actual_bytes = os.path.getsize(os.environ["MMPROJ_FILE"])
    except OSError:
        sys.exit(1)
    if actual_bytes < expected_bytes:
        sys.exit(1)

text_ids = {norm(os.environ.get("TEXT_MODEL_NAME")), norm(os.environ.get("TEXT_MODEL_BASENAME"))}
proj_ids = {norm(meta.get("name")), norm(meta.get("basename"))}
text_ids.discard("")
proj_ids.discard("")

if not text_ids or not proj_ids or text_ids.isdisjoint(proj_ids):
    sys.exit(1)
'
}

find_local_mmproj() {
    # Look for mmproj files in model directory, matching model name
    local dir="$MODEL_DIR_PATH"
    local f
    # Exact match patterns (most reliable)
    for f in "$dir"/mmproj-F16.gguf "$dir"/mmproj-BF16.gguf "$dir"/mmproj-F32.gguf; do
        [[ -f "$f" ]] || continue
        if mmproj_matches_model "$f"; then
            echo "$f"
            return
        fi
        echo "  Skipping incompatible mmproj: $f ($(mmproj_label "$f"))" >&2
    done
    # Glob for any mmproj
    for f in "$dir"/*mmproj*.gguf; do
        [[ -f "$f" ]] || continue
        if mmproj_matches_model "$f"; then
            echo "$f"
            return
        fi
        echo "  Skipping incompatible mmproj: $f ($(mmproj_label "$f"))" >&2
    done
    # Also check MODEL_DIR (may differ from model's directory)
    if [[ "$dir" != "$MODEL_DIR" ]]; then
        for f in "$MODEL_DIR"/mmproj-F16.gguf "$MODEL_DIR"/mmproj-BF16.gguf; do
            [[ -f "$f" ]] || continue
            if mmproj_matches_model "$f"; then
                echo "$f"
                return
            fi
            echo "  Skipping incompatible mmproj: $f ($(mmproj_label "$f"))" >&2
        done
    fi
    echo ""
}

list_repo_mmproj_candidates() {
    local repo="$1"
    local tree

    tree=$(curl -sfL "https://huggingface.co/api/models/${repo}/tree/main?recursive=1" 2>/dev/null || true)
    if [[ -n "$tree" ]]; then
        printf '%s' "$tree" | python3 -c '
import json
import os
import sys

try:
    data = json.load(sys.stdin)
except Exception:
    data = []

paths = []
for item in data if isinstance(data, list) else []:
    if not isinstance(item, dict):
        continue
    path = item.get("path") or item.get("rfilename") or ""
    name = os.path.basename(path).lower()
    if path and name.endswith(".gguf") and "mmproj" in name:
        paths.append(path)

def score(path):
    name = os.path.basename(path).lower()
    if name == "mmproj-f16.gguf":
        rank = 0
    elif name == "mmproj-bf16.gguf":
        rank = 1
    elif name == "mmproj-f32.gguf":
        rank = 2
    elif "f16" in name:
        rank = 3
    elif "bf16" in name:
        rank = 4
    elif "f32" in name:
        rank = 5
    elif name == "mmproj.gguf":
        rank = 6
    else:
        rank = 7
    return (rank, len(path), path)

for path in sorted(set(paths), key=score):
    print(path)
'
    fi

    # Fallback for repos where the tree API is unavailable or returns no files.
    printf '%s\n' "mmproj-F16.gguf" "mmproj-BF16.gguf" "mmproj-F32.gguf" "mmproj.gguf"
}

download_mmproj() {
    # Try to download mmproj from HuggingFace based on model metadata
    local basename="${GGUF_BASENAME:-$GGUF_MODEL_NAME}"
    local quantizer="${GGUF_QUANTIZED_BY:-}"
    [[ -z "$basename" ]] && return 1

    # Build candidate HuggingFace repo names
    # Common pattern: {quantizer}/{basename}-GGUF (e.g. unsloth/gemma-4-31B-it-GGUF)
    local candidates=()
    if [[ -n "$quantizer" ]]; then
        # Unsloth/bartowski/etc style: quantizer/BaseName-GGUF
        candidates+=("${quantizer}/${basename}-GGUF")
        # Also try with model name (sometimes differs from basename)
        [[ -n "$GGUF_MODEL_NAME" && "$GGUF_MODEL_NAME" != "$basename" ]] && \
            candidates+=("${quantizer}/${GGUF_MODEL_NAME}-GGUF")
    fi
    # Also try common quantizers
    for q in unsloth bartowski lmstudio-community; do
        [[ "$q" == "$quantizer" ]] && continue
        candidates+=("${q}/${basename}-GGUF")
    done

    local safe_basename
    safe_basename=$(printf '%s' "$basename" | tr -cs 'A-Za-z0-9._+-' '_' | sed 's/^_*//; s/_*$//')
    [[ -z "$safe_basename" ]] && safe_basename="model"

    for repo in "${candidates[@]}"; do
        local seen_remote=()
        local remote_path
        while IFS= read -r remote_path; do
            [[ -n "$remote_path" ]] || continue
            local already_seen=0 seen
            for seen in "${seen_remote[@]}"; do
                [[ "$seen" == "$remote_path" ]] && already_seen=1 && break
            done
            (( already_seen )) && continue
            seen_remote+=("$remote_path")

            local remote_base suffix safe_suffix dest tmp url
            remote_base=$(basename "$remote_path")
            suffix="$remote_base"
            suffix="${suffix#mmproj-}"
            suffix="${suffix#mmproj_}"
            [[ "$suffix" == "$remote_base" ]] && suffix="$remote_base"
            safe_suffix=$(printf '%s' "$suffix" | tr -cs 'A-Za-z0-9._+-' '_' | sed 's/^_*//; s/_*$//')
            [[ -z "$safe_suffix" ]] && safe_suffix="mmproj.gguf"
            dest="$MODEL_DIR_PATH/mmproj-${safe_basename}-${safe_suffix}"
            tmp="${dest}.tmp.$$"

            if [[ -f "$dest" ]] && mmproj_matches_model "$dest"; then
                echo "  Found compatible downloaded mmproj: $dest" >&2
                echo "$dest"
                return 0
            fi

            url=$(REPO="$repo" REPO_PATH="$remote_path" python3 -c '
import os
from urllib.parse import quote

print("https://huggingface.co/{}/resolve/main/{}".format(
    os.environ["REPO"],
    quote(os.environ["REPO_PATH"], safe="/"),
))
')
            echo "  Trying: $url" >&2
            if ! curl -sfL --head "$url" >/dev/null 2>&1; then
                continue
            fi

            echo "  Downloading mmproj from ${repo}: ${remote_path}" >&2
            rm -f "$tmp"
            if curl -fL --progress-bar -o "$tmp" "$url"; then
                # Verify it's actually a GGUF file
                if DEST="$tmp" python3 -c "
import os, sys
with open(os.environ['DEST'],'rb') as f:
    magic = f.read(4)
    if magic != b'GGUF': sys.exit(1)
" 2>/dev/null; then
                    if ! mmproj_matches_model "$tmp"; then
                        echo "  Warning: downloaded mmproj is incomplete or does not match this model ($(mmproj_label "$tmp")), removing" >&2
                        rm -f "$tmp"
                        continue
                    fi
                    mv -f "$tmp" "$dest"
                    echo "  Downloaded: $dest" >&2
                    echo "$dest"
                    return 0
                else
                    echo "  Warning: downloaded file is not a valid GGUF, removing" >&2
                    rm -f "$tmp"
                fi
            fi
        done < <(list_repo_mmproj_candidates "$repo")
    done
    return 1
}

# User passthrough flags are appended after tune-cache resolution (see below)
# so they always appear last in the final command and beat both heuristic and tune.
if (( ${#EXTRA_LLAMA_FLAGS[@]} > 0 )); then
    echo "  User flags (passthrough): ${EXTRA_LLAMA_FLAGS[*]}"
fi

# ═══════════════════════════════════════════════════════════════
# Section 5: Strategy Selection
# ═══════════════════════════════════════════════════════════════

# OOM guard: refuse to launch if model+KV+compute don't fit in the given memory pool
# Args: pool_mb pool_label
check_memory_or_die() {
    local pool_mb=$1
    local pool_label=$2
    local model_overhead_mb=$(( TOTAL_SIZE_MB * VRAM_OVERHEAD_PERCENT / 100 ))
    local needed_mb=$(( model_overhead_mb + KV_TOTAL_MB + COMPUTE_PER_GPU_MB ))

    if (( needed_mb > pool_mb )); then
        # Back-solve max safe context: max_kv = pool - model_overhead - compute
        local max_kv_mb=$(( pool_mb - model_overhead_mb - COMPUTE_PER_GPU_MB ))
        (( max_kv_mb < 0 )) && max_kv_mb=0
        local max_ctx=0
        if (( KV_TOTAL_MB > 0 )); then
            max_ctx=$(( max_kv_mb * CTX_SIZE / KV_TOTAL_MB ))
        fi
        echo ""
        echo "ERROR: Model does not fit in ${pool_label}."
        echo "  Model (with overhead): ${model_overhead_mb}MB"
        echo "  KV cache (ctx=${CTX_SIZE}): ${KV_TOTAL_MB}MB"
        echo "  Compute buffers:       ${COMPUTE_PER_GPU_MB}MB"
        echo "  ─────────────────────────────"
        echo "  Total needed:          ${needed_mb}MB"
        echo "  Available (${pool_label}): ${pool_mb}MB"
        echo "  Shortfall:             $(( needed_mb - pool_mb ))MB"
        echo ""
        if (( max_ctx > 0 )); then
            echo "  Max safe context at this memory: --ctx-size $max_ctx"
        else
            echo "  Model weights alone exceed available memory."
        fi
        echo "  Or use a smaller quantization / model."
        exit 1
    fi
}

# ═══════════════════════════════════════════════════════════════
# Section 4: Vision & Memory Budgeting
# ═══════════════════════════════════════════════════════════════

# First resolve Vision path (so we can include it in VRAM calculation)
if [[ "$MMPROJ_PATH" == "auto" ]]; then
    MMPROJ_PATH=$(find_local_mmproj)
    if [[ -z "$MMPROJ_PATH" ]]; then
        MMPROJ_PATH=$(download_mmproj) || true
    fi
    if [[ -z "$MMPROJ_PATH" ]]; then
        echo "Error: Vision enabled but no compatible mmproj was found." >&2
        echo "Place the matching mmproj GGUF next to the model, pass --mmproj /path/to/mmproj.gguf, or set LLM_SERVER_SKIP_MMPROJ_CHECK=1 to bypass metadata validation." >&2
        exit 1
    fi
fi

# Calculate VRAM needed including mmproj
VRAM_NEEDED_MB=$(( TOTAL_SIZE_MB * VRAM_OVERHEAD_PERCENT / 100 + KV_TOTAL_MB + COMPUTE_PER_GPU_MB ))
if [[ -n "$MMPROJ_PATH" ]]; then
    if [[ -f "$MMPROJ_PATH" ]]; then
        if ! mmproj_matches_model "$MMPROJ_PATH"; then
            echo "Error: mmproj metadata does not match the selected model, or the file is incomplete." >&2
            echo "  Model: ${GGUF_BASENAME:-${GGUF_MODEL_NAME:-unknown}}" >&2
            echo "  mmproj: $MMPROJ_PATH ($(mmproj_label "$MMPROJ_PATH"))" >&2
            echo "Set LLM_SERVER_SKIP_MMPROJ_CHECK=1 only if you have manually verified compatibility." >&2
            exit 1
        fi
        MMPROJ_SIZE_MB=$(du -sm "$MMPROJ_PATH" 2>/dev/null | awk '{print $1}' || echo 0)
        VRAM_NEEDED_MB=$(( VRAM_NEEDED_MB + MMPROJ_SIZE_MB ))
        COMMON_FLAGS+=(--mmproj "$MMPROJ_PATH")
        echo "  Vision: mmproj loaded from $MMPROJ_PATH"
    else
        echo "Error: Vision enabled but mmproj file not found/downloaded."
        echo "Please verify model path or use --ai-tune."
        exit 1
    fi
fi


# Global OOM check: model must fit somewhere (all GPUs + RAM combined)
# Skip for MoE — expert offload has its own fine-grained budgeting (Phase 1+2)
if (( IS_MOE == 0 )); then
    TOTAL_POOL_MB=$(( TOTAL_VRAM_MB + RAM_AVAIL_MB - SYSTEM_HEADROOM_MB ))
    check_memory_or_die "$TOTAL_POOL_MB" "total GPU+RAM"
fi

choose_strategy() {
    # CPU-only
    if (( GPU_COUNT == 0 )); then
        echo "cpu_only"
        return
    fi

    # Single GPU: model + overhead fits in best GPU
    # Use tighter estimate (110%) — quantized weights don't expand much in VRAM,
    # and 130% global overhead is too conservative for single-GPU feasibility
    # Use TOTAL VRAM (minus a 1GB safety margin), not FREE — pre-launch free
    # VRAM dips from desktop/compositor would spuriously reject single-GPU.
    # Transient users of GPU VRAM get displaced when the model reserves its slab.
    local best=${GPU_ORDER[0]}
    local single_gpu_usable=$(( GPU_VRAM_TOTAL[best] - 1024 ))
    (( single_gpu_usable < 0 )) && single_gpu_usable=0
    local single_gpu_needed=$(( TOTAL_SIZE_MB * 110 / 100 + KV_TOTAL_MB + COMPUTE_PER_GPU_MB ))
    if (( single_gpu_needed <= single_gpu_usable )); then
        echo "single_gpu"
        return
    fi

    # Multi-GPU: model fits across all GPUs
    if (( IS_MOE == 0 && VRAM_NEEDED_MB <= TOTAL_VRAM_MB )); then
        echo "multi_gpu_dense"
        return
    fi

    # MoE expert offload
    if (( IS_MOE == 1 )); then
        echo "moe_offload"
        return
    fi

    # Dense model with CPU spill
    echo "dense_cpu_offload"
}

STRATEGY=$(choose_strategy)

# Vision (mmproj) needs extra VRAM — avoid single GPU when multi-GPU is available
if [[ -n "$MMPROJ_PATH" && "$STRATEGY" == "single_gpu" && GPU_COUNT -gt 1 ]]; then
    if (( IS_MOE )); then
        STRATEGY="moe_offload"
        echo "  Vision: forcing moe_offload (mmproj needs extra VRAM)"
    else
        STRATEGY="multi_gpu_dense"
        echo "  Vision: forcing multi_gpu_dense (mmproj needs extra VRAM)"
    fi
fi

echo ""
echo "Strategy: $STRATEGY"

# ═══════════════════════════════════════════════════════════════
# Section 6: Helper Functions
# ═══════════════════════════════════════════════════════════════

# Build -ot string from array of (cuda_device, layer_start, layer_count) assignments
# Args: pairs of "CUDA_INDEX LAYER_START LAYER_COUNT" followed by end marker
build_ot_string() {
    local parts=()
    # Support both fused (gate_up/up_gate) and unfused (gate|up|down) expert tensor names
    # Longer alternatives first so regex engine matches them before shorter prefixes
    local expert_pattern="ffn_(gate_up|up_gate|gate|up|down)_exps"

    while [[ $# -ge 3 ]]; do
        local cuda_idx=$1 layer_start=$2 layer_count=$3
        shift 3
        if (( layer_count > 0 )); then
            local last=$(( layer_start + layer_count - 1 ))
            local re=$(seq "$layer_start" "$last" | tr '\n' '|' | sed 's/|$//')
            parts+=("blk\\.(${re})\\.${expert_pattern}.*=CUDA${cuda_idx}")
        fi
    done
    parts+=("exps=CPU")
    local IFS=,
    echo "${parts[*]}"
}

kill_server() {
    local pid="${1:-}"
    local own_pgid pgid=""
    own_pgid=$(ps -o pgid= -p $$ 2>/dev/null | tr -d ' ' || true)

    if [[ -n "$pid" ]] && kill -0 "$pid" 2>/dev/null; then
        pgid=$(_pgid_of "$pid" 2>/dev/null || true)
        if [[ -n "$pgid" && "$pgid" != "$own_pgid" ]]; then
            kill -TERM -- "-$pgid" 2>/dev/null || true
        else
            kill -TERM "$pid" 2>/dev/null || true
        fi
        local i=0
        while (( i < 5 )) && kill -0 "$pid" 2>/dev/null; do sleep 1; (( ++i )); done
        if kill -0 "$pid" 2>/dev/null; then
            if [[ -n "$pgid" && "$pgid" != "$own_pgid" ]]; then
                kill -KILL -- "-$pgid" 2>/dev/null || true
            else
                kill -9 "$pid" 2>/dev/null || true
            fi
        fi
        wait "$pid" 2>/dev/null || true
    fi

    # Port-listener cleanup: only target llama-named processes. Foreign
    # listeners on the same port get a warning, never SIGKILL.
    local port_pids p cmd
    port_pids=$(_port_listener_pids)
    if [[ -n "$port_pids" ]]; then
        for p in $port_pids; do
            if _is_llama_proc "$p"; then
                kill -TERM "$p" 2>/dev/null || true
            else
                cmd=$(ps -o comm= -p "$p" 2>/dev/null | tr -d ' ' || true)
                [[ -n "$cmd" ]] && echo "  WARN: port ${PORT} held by foreign process '$cmd' (pid $p) — refusing to kill" >&2
            fi
        done
        sleep 1
        port_pids=$(_port_listener_pids)
        for p in $port_pids; do
            _is_llama_proc "$p" && kill -9 "$p" 2>/dev/null || true
        done
    fi

    # Wait for port to free, but only count llama-owned listeners.
    local w=0 has_ours
    while (( w < 10 )); do
        has_ours=0
        port_pids=$(_port_listener_pids)
        for p in $port_pids; do
            _is_llama_proc "$p" && { has_ours=1; break; }
        done
        (( has_ours )) || break
        sleep 1; (( ++w ))
    done

    # Whatever we had pinned is gone now. Clear RUNNING_PID so the EXIT trap
    # doesn't chase a dead pid that may have wrapped around to another process.
    RUNNING_PID=""
}

# Wait for server health + verify it can generate. Sets RUNNING_PID on success.
wait_for_ready() {
    local pid=$1
    local i=0
    while (( i < HEALTH_TIMEOUT )); do
        if curl -sf "http://127.0.0.1:${PORT}/health" >/dev/null 2>&1; then
            local smoke
            smoke=$(curl -sf --max-time 120 "http://127.0.0.1:${PORT}/v1/chat/completions" \
                -H "Content-Type: application/json" \
                -d '{"model":"test","messages":[{"role":"user","content":"Say OK"}],"max_tokens":4,"temperature":0}' 2>/dev/null)
            if [[ -n "$smoke" ]] && echo "$smoke" | python3 -c "import sys,json; d=json.load(sys.stdin); assert d.get('choices')" 2>/dev/null; then
                RUNNING_PID=$pid
                return 0
            fi
            if ! kill -0 "$pid" 2>/dev/null; then return 1; fi
        fi
        if ! kill -0 "$pid" 2>/dev/null; then return 1; fi
        sleep 1; (( ++i ))
    done
    kill -9 "$pid" 2>/dev/null; wait "$pid" 2>/dev/null || true
    return 1
}

# V3: spawn the server in its own session/pgid via setsid so kill_server can
# target the whole group (children, helper threads, the works). On systems
# without setsid this falls back to a normal background launch — kill_server
# detects the shared-pgid case and refuses pgid-kill there.
#
# Modes: "tee" (tee to log + stdout), "tee_filter" (tee + filter known
#        noisy ik_llama spam).
# Side effects: sets RUNNING_PID, LAUNCH_LOG_OFFSET. Prints pid to stdout.
launch_backend() {
    local mode="$1"; shift
    # Use stat (no redirect) so a missing log file doesn't print a bash
    # redirect-failure message before the server even starts.
    LAUNCH_LOG_OFFSET=$(stat -c %s "$SERVER_LOG" 2>/dev/null || echo 0)
    local launcher=()
    if command -v setsid >/dev/null 2>&1; then
        launcher=(setsid)
    fi
    case "$mode" in
        tee_filter)
            "${launcher[@]}" "$LLAMA_SERVER" "$@" \
                > >(tee -a "$SERVER_LOG" | grep -v --line-buffered "record AND rewind is invalid") 2>&1 &
            ;;
        tee|*)
            "${launcher[@]}" "$LLAMA_SERVER" "$@" > >(tee -a "$SERVER_LOG") 2>&1 &
            ;;
    esac
    local pid=$!
    echo 1000 > "/proc/$pid/oom_score_adj" 2>/dev/null || true
    # Set RUNNING_PID immediately so the EXIT trap catches the orphan even if
    # the script dies before health-check completion. (V2 only set this inside
    # wait_for_ready on success, leaving an orphan window.)
    # Callers read RUNNING_PID — do NOT use `pid=$(launch_backend ...)`. The
    # tee process substitution above keeps writing to this function's stdout,
    # so a $() capture would hang until the server exits.
    RUNNING_PID="$pid"
}

# Strip ik_llama-only flags from a named flag array (bash 4.3+ nameref).
_strip_ik_only_flags() {
    local -n _arr="$1"
    local out=() skip=0 f
    for f in "${_arr[@]}"; do
        if (( skip )); then skip=0; continue; fi
        case "$f" in
            --run-time-repack|-rtr|--no-context-shift|-khad|-mqkv|-muge|-ger)
                echo "  Removing ik-only flag: $f" ;;
            -cram|--defrag-thold|--ctx-checkpoints|--split-mode)
                echo "  Removing ik-only flag: $f"
                skip=1 ;;
            *) out+=("$f") ;;
        esac
    done
    _arr=("${out[@]}")
}

# Inspect SERVER_LOG since LAUNCH_LOG_OFFSET. If ik_llama failed to load
# the model, swap LLAMA_SERVER to mainline and strip ik-only flags from
# the named array. Returns 0 if fallback applied, 1 otherwise.
# Args: $1 = name of flag array variable to mutate
_try_ik_fallback() {
    local arr_name="$1"
    (( ${IS_IK_LLAMA:-0} )) || return 1
    [[ -n "${USER_SERVER_BIN:-}" ]] && return 1
    local mainline_bin="$HOME/llama.cpp/build/bin/llama-server"
    [[ -x "$mainline_bin" ]] || return 1
    local recent_log
    recent_log=$(tail -c +"$((${LAUNCH_LOG_OFFSET:-0}+1))" "$SERVER_LOG" 2>/dev/null || true)
    # Pattern-match via case to avoid `echo | grep` SIGPIPE under pipefail.
    case "$recent_log" in
        *"unknown model architecture"*|*"unable to load model"*|*"error loading model"*) ;;
        *) return 1 ;;
    esac
    echo ""
    echo "═══ ik_llama.cpp cannot load this model — falling back to mainline llama.cpp ═══"
    LLAMA_SERVER="$mainline_bin"
    IS_IK_LLAMA=0
    setup_lib_hub "$LLAMA_SERVER"
    _strip_ik_only_flags "$arr_name"
    echo "  Retrying with: $LLAMA_SERVER"
    return 0
}

# Try starting server, wait for health. Sets RUNNING_PID on success.
# V3: on health failure, attempts ik→llama fallback once before giving up.
# This makes ai_tune's baseline launch as resilient as run_with_restart.
try_start() {
    local extra_flags=("$@")
    RUNNING_PID=""
    local mode="tee"
    local launch_flags=("${COMMON_FLAGS[@]}" "${extra_flags[@]}")
    launch_backend "$mode" "${launch_flags[@]}"
    local pid="$RUNNING_PID"
    if wait_for_ready "$pid"; then
        return 0
    fi
    # Failed health check. Try ik_llama → mainline fallback once.
    if _try_ik_fallback COMMON_FLAGS; then
        # extra_flags may also carry ik-only flags (e.g. -ot patterns)
        _strip_ik_only_flags extra_flags
        kill_server "$pid"
        launch_flags=("${COMMON_FLAGS[@]}" "${extra_flags[@]}")
        launch_backend "$mode" "${launch_flags[@]}"
        pid="$RUNNING_PID"
        wait_for_ready "$pid" && return 0
    fi
    return 1
}

print_cmd() {
    echo ""
    echo "Command:"
    local line="  $LLAMA_SERVER"
    local args=("$@")
    for (( i=0; i<${#args[@]}; i++ )); do
        local arg="${args[$i]}"
        # Pair --flag with its value (next arg that doesn't start with -)
        if [[ "$arg" == -* ]] && (( i + 1 < ${#args[@]} )) && [[ "${args[$((i+1))]}" != -* ]]; then
            local pair="$arg ${args[$((i+1))]}"
            i=$(( i + 1 ))
        else
            local pair="$arg"
        fi
        # Wrap lines at ~80 chars
        if (( ${#line} + ${#pair} + 1 > 80 )); then
            echo "$line \\"
            line="    $pair"
        else
            line="$line $pair"
        fi
    done
    echo "$line"
}

# Run benchmark: send a prompt, measure tok/s
run_benchmark() {
    local url="http://127.0.0.1:${PORT}"
    echo ""
    echo "═══ Benchmark ═══"

    # Prompt processing benchmark (short prompt)
    local pp_prompt="Explain the theory of relativity in simple terms. Cover special and general relativity, time dilation, and gravitational effects."
    local result
    result=$(curl -sf "$url/v1/chat/completions" \
        -H "Content-Type: application/json" \
        -d "{\"model\":\"test\",\"messages\":[{\"role\":\"user\",\"content\":\"$pp_prompt\"}],\"max_tokens\":200,\"temperature\":0.1}" 2>/dev/null)

    if [[ -z "$result" ]]; then
        echo "Benchmark failed — server not responding"
        return 1
    fi

    local pp_tokens tg_tokens response_rates pp_rate tg_rate
    pp_tokens=$(echo "$result" | python3 -c "import sys,json; d=json.load(sys.stdin); u=d.get('usage',{}); print(u.get('prompt_tokens',0))" 2>/dev/null || echo 0)
    tg_tokens=$(echo "$result" | python3 -c "import sys,json; d=json.load(sys.stdin); u=d.get('usage',{}); print(u.get('completion_tokens',0))" 2>/dev/null || echo 0)
    response_rates=$(echo "$result" | python3 -c "
import sys,json
try:
    d=json.load(sys.stdin)
    t=d.get('timings', {})
    pp=t.get('prompt_per_second') or 0
    tg=t.get('predicted_per_second') or 0
    print(f'{pp:.1f}\t{tg:.1f}' if pp and tg else '')
except Exception:
    print('')
" 2>/dev/null || true)

    if [[ -n "$response_rates" ]]; then
        pp_rate="${response_rates%%$'\t'*}"
        tg_rate="${response_rates#*$'\t'}"
        echo "  Prompt processing: ${pp_tokens:-?} tokens @ ${pp_rate:-?} tok/s"
        echo "  Generation:        ${tg_tokens:-?} tokens @ ${tg_rate:-?} tok/s"
    else
        # Use /slots as a fallback for older backends.
        local timings
        timings=$(curl -sf "$url/slots" 2>/dev/null)
        if [[ -n "$timings" ]]; then
        pp_rate=$(echo "$timings" | python3 -c "
	import sys,json
	d=json.load(sys.stdin)
	s=d[0] if isinstance(d,list) else d
t_pp = s.get('t_prompt_processing', 0)
n_pp = s.get('n_prompt_tokens_processed', 1)
if t_pp > 0: print(f\"{n_pp / (t_pp / 1000):.1f}\")
else: print('?')
" 2>/dev/null)
        tg_rate=$(echo "$timings" | python3 -c "
import sys,json
d=json.load(sys.stdin)
s=d[0] if isinstance(d,list) else d
t_gen = s.get('t_token_generation', 0)
n_gen = s.get('n_decoded', 1)
if t_gen > 0: print(f\"{n_gen / (t_gen / 1000):.1f}\")
	else: print('?')
	" 2>/dev/null)
            echo "  Prompt processing: ${pp_tokens:-?} tokens @ ${pp_rate:-?} tok/s"
            echo "  Generation:        ${tg_tokens:-?} tokens @ ${tg_rate:-?} tok/s"
        else
            echo "  Prompt tokens: ${pp_tokens:-?}"
            echo "  Generated tokens: ${tg_tokens:-?}"
            echo "  (Backend did not expose detailed timing)"
        fi
    fi
    echo ""
    # Auto-exit after benchmark to prevent "hanging"
    echo "Benchmark complete. Shutting down server..."
    kill_server ""
    exit 0
}

# Suggest alternatives when model doesn't fit
# Run server with automatic crash restart and backoff
# Args: all flags to pass to llama-server
run_with_restart() {
    local flags=("$@")
    local restarts=0
    local last_start=0

    while true; do
        last_start=$(date +%s)
        echo "Starting server..."
        launch_backend "tee_filter" "${flags[@]}"
        local pid="$RUNNING_PID"
        local log_start="${LAUNCH_LOG_OFFSET:-0}"
        echo "Server PID: $pid"

        # Wait for health before declaring success
        local healthy=0
        for i in $(seq 1 $HEALTH_TIMEOUT); do
            if curl -sf "http://127.0.0.1:${PORT}/health" >/dev/null 2>&1; then
                healthy=1
                break
            fi
            if ! kill -0 "$pid" 2>/dev/null; then
                # Server died; shared startup fallback handles ik_llama -> llama.cpp once.
                if _try_ik_fallback flags; then
                    kill_server "$pid"
                    restarts=0
                    continue 2
                fi
                break
            fi
            sleep 1
        done

        if (( healthy )); then
            echo "Server healthy."
            if (( BENCHMARK )); then
                run_benchmark
                BENCHMARK=0  # only run once
            fi

            restarts=0  # reset counter on successful start

            # Monitor log for fatal errors — server stays "alive" but braindead after these
            local cuda_killed=0
            local log_pos=$log_start
            while kill -0 "$pid" 2>/dev/null; do
                sleep 5
                local new_log
                new_log=$(tail -c +"$log_pos" "$SERVER_LOG" 2>/dev/null) || new_log=""
                # CUDA errors — instant kill
                if echo "$new_log" | grep -q "CUDA error"; then
                    echo ""
                    echo "═══ CUDA error detected — server is braindead, killing ═══"
                    tail -5 "$SERVER_LOG" 2>/dev/null
                    kill -9 "$pid" 2>/dev/null || true; wait "$pid" 2>/dev/null || true
                    cuda_killed=1
                    break
                fi
                # Image decode loop — server retries forever on bad image, stuck
                local img_fails
                img_fails=$(echo "$new_log" | grep -c "failed to process image" 2>/dev/null) || img_fails=0
                if (( img_fails >= 10 )); then
                    echo ""
                    echo "═══ Image decode loop detected ($img_fails failures) — server is stuck, killing ═══"
                    tail -5 "$SERVER_LOG" 2>/dev/null
                    kill -9 "$pid" 2>/dev/null || true; wait "$pid" 2>/dev/null || true
                    cuda_killed=1  # treat same as CUDA kill (recovery, not crash)
                    break
                fi
                log_pos=$(wc -c < "$SERVER_LOG" 2>/dev/null || echo "$log_pos")
            done

            local exit_code=0
            if (( cuda_killed )); then
                # CUDA kill is a recovery, not a repeated crash — don't count against restarts
                echo "Restarting after CUDA error recovery..."
                kill_server ""
                # Wait for GPU driver to fully reclaim CUDA contexts (up to 60s)
                local gpu_wait=0
                echo "Waiting for GPU memory to be released..."
                while (( gpu_wait < 60 )); do
                    local gpu_procs
                    gpu_procs=$(nvidia-smi --query-compute-apps=pid --format=csv,noheader 2>/dev/null | grep -c '[0-9]') || gpu_procs=0
                    if (( gpu_procs == 0 )); then
                        echo "GPU memory free after ${gpu_wait}s"
                        break
                    fi
                    sleep 2
                    (( gpu_wait += 2 ))
                done
                if (( gpu_wait >= 60 )); then
                    echo "Warning: GPU processes still present after 60s, attempting restart anyway"
                fi
                sleep 3  # extra settle time for driver cleanup
                restarts=-3  # extra patience: 8 total attempts (3 extra + 5 normal)
                continue
            fi
            wait "$pid" 2>/dev/null && exit_code=$? || exit_code=$?
        else
            echo "Server failed to become healthy."
            kill -9 "$pid" 2>/dev/null || true; wait "$pid" 2>/dev/null || true
            local exit_code=1
        fi

        # Server exited — decide whether to restart
        local uptime=$(( $(date +%s) - last_start ))

        # Clean exit (signal 0 or SIGTERM)
        if (( exit_code == 0 || exit_code == 143 )); then
            echo "Server exited cleanly (code $exit_code). Not restarting."
            exit 0
        fi

        restarts=$(( restarts + 1 ))
        echo ""
        echo "═══ Server crashed (exit code $exit_code, uptime ${uptime}s) ═══"
        tail -5 "$SERVER_LOG" 2>/dev/null
        echo ""

        if (( restarts > MAX_RESTARTS )); then
            if (( KEEP_ALIVE )); then
                echo "Reached $MAX_RESTARTS restarts, but --keep-alive set — continuing."
                echo "Backoff extended to 60s between attempts. Ctrl-C to stop."
                restarts=0
                sleep 60
                kill_server ""
                continue
            fi
            echo "Too many restarts ($MAX_RESTARTS). Giving up."
            echo "Use --keep-alive (or LLM_KEEP_ALIVE=1) to never give up."
            echo "Check $SERVER_LOG for details."
            exit 1
        fi

        # Backoff: 2s, 4s, 8s, 16s, 32s
        local wait_sec=$(( 2 ** restarts ))
        (( wait_sec > 30 )) && wait_sec=30

        # If server ran for >60s, it was a runtime crash (not startup OOM)
        # Reset backoff since the config itself works
        if (( uptime > 60 )); then
            wait_sec=2
            # Still count runtime crashes — don't loop forever
            echo "Runtime crash (ran ${uptime}s). Restart $restarts/$MAX_RESTARTS in ${wait_sec}s..."
        else
            echo "Startup crash. Restart $restarts/$MAX_RESTARTS in ${wait_sec}s..."

            if _try_ik_fallback flags; then
                restarts=0
                kill_server ""
                continue
            fi
        fi

        sleep "$wait_sec"

        # Clean up port before restart
        kill_server ""
    done
}

