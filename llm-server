# Convert LLM JSON overrides into extra flags array for try_start
# Args: $1 = JSON object of flag overrides {"--flag": "value", ...}
# Sets TUNE_OVERRIDE_FLAGS array — these get passed to try_start ON TOP of COMMON_FLAGS
TUNE_EXTRA_FIXED=()
declare -a TUNE_OVERRIDE_FLAGS=()
declare -a TUNE_OVERRIDE_KEYS=()

# Launch server with overrides, stripping duplicates from COMMON_FLAGS.
# Without this, the LLM proposing e.g. --cache-type-k q8_0 on top of
# the baseline's --cache-type-k q4_0 causes "specified multiple times" errors.
try_start_with_overrides() {
    local deduped=()
    local skip_next=0
    for (( i=0; i<${#COMMON_FLAGS[@]}; i++ )); do
        if (( skip_next )); then
            skip_next=0
            continue
        fi
        local flag="${COMMON_FLAGS[$i]}"
        local dominated=0
        for key in "${TUNE_OVERRIDE_KEYS[@]}"; do
            if [[ "$flag" == "$key" ]]; then
                dominated=1
                # Skip the value too if the next element isn't a flag
                if (( i + 1 < ${#COMMON_FLAGS[@]} )) && [[ "${COMMON_FLAGS[$((i+1))]}" != -* ]]; then
                    skip_next=1
                fi
                break
            fi
        done
        (( dominated )) || deduped+=("$flag")
    done
    launch_backend "tee" "${deduped[@]}" "${TUNE_OVERRIDE_FLAGS[@]}"
    local pid="$RUNNING_PID"
    wait_for_ready "$pid"
}
parse_tune_overrides() {
    local overrides_json="$1"
    TUNE_OVERRIDE_FLAGS=()
    TUNE_OVERRIDE_KEYS=()
    local kv_locked="$KV_QUALITY_EXPLICIT"
    local locked_keys_env
    locked_keys_env=$(printf '%s\n' "${TUNE_USER_LOCKED_KEYS[@]:-}")
    while IFS= read -r -d '' item; do
        case "$item" in
            F$'\t'*) TUNE_OVERRIDE_FLAGS+=("${item#F$'\t'}") ;;
            K$'\t'*) TUNE_OVERRIDE_KEYS+=("${item#K$'\t'}") ;;
        esac
    done < <(KV_LOCKED="$kv_locked" WSL2="$IS_WSL2" DO_UNLIMITED="$DO_UNLIMITED" TUNE_USER_LOCKED_KEYS="$locked_keys_env" python3 -c "
	import json, os, sys
try:
    overrides = json.loads(sys.stdin.read())
except json.JSONDecodeError:
    overrides = {}
if not isinstance(overrides, dict):
    overrides = {}
protected = {'-m', '--host', '--port', '--ctx-size', '--mmproj', '-ot', '--reasoning'}
protected |= {k for k in os.environ.get('TUNE_USER_LOCKED_KEYS', '').splitlines() if k}
if os.environ.get('DO_UNLIMITED') != '1':
    protected |= {'--device', '--tensor-split', '--split-mode', '-mg', '-ngl', '-ot', '--n-cpu-moe'}
if os.environ.get('KV_LOCKED') == '1':
    protected |= {'--cache-type-k', '--cache-type-v'}
if os.environ.get('WSL2') == '1':
    protected |= {'--mlock', '-mlk'}
# Normalize common aliases the LLM hallucinates
aliases = {
    '--mg': '-mg', '--main-gpu': '-mg',
    '--batch-size': '-b', '--ubatch-size': '-ub',
    '--ngl': '-ngl', '--n-gpu-layers': '-ngl',
    '--n-cpu-moe': '--n-cpu-moe', '-ncmoe': '--n-cpu-moe',
    '--override-tensor': '-ot',
    '--threads': '--threads', '-t': '--threads',
    '--threads-batch': '--threads-batch', '-tb': '--threads-batch',
    '--parallel': '--parallel', '-np': '--parallel',
    '--flash-attn': '--flash-attn', '-fa': '--flash-attn',
    '--reasoning': '--reasoning', '-rea': '--reasoning',
}
normalized = {}
for k, v in overrides.items():
    if not isinstance(k, str) or not k.startswith('-'):
        continue
    k = aliases.get(k, k)
    normalized[k] = v
records = []
for k, v in normalized.items():
    if k in protected:
        continue
    if v is False:
        continue
    records.append(('K', k))
    records.append(('F', k))
    if v is not True and v != '' and v is not None:
        records.append(('F', str(v)))
for kind, value in records:
    sys.stdout.write(kind + '\t' + value + '\0')
" <<< "$overrides_json" || true)
}

# Main AI tune function — iterative: benchmark → query → benchmark → query ...
_tune_fmt_duration() {
    # Seconds -> "XmYs" (or "Xh Ym" for >=1h). Minimum "0s".
    local s="$1"
    (( s < 0 )) && s=0
    if (( s < 60 )); then
        printf '%ds' "$s"
    elif (( s < 3600 )); then
        printf '%dm%02ds' $(( s / 60 )) $(( s % 60 ))
    else
        printf '%dh%02dm' $(( s / 3600 )) $(( (s % 3600) / 60 ))
    fi
}

_tune_progress_line() {
    # Args: rounds_done total_rounds start_ts best_gen best_name baseline_gen
    # rounds_done counts baseline as round 0, so total_done = arg1 + 1.
    local done="$1" total="$2" start="$3" bgen="$4" bname="$5" base="$6"
    local now elapsed avg_per eta_rem remain improvement color reset dim
    now=$(date +%s)
    elapsed=$(( now - start ))
    remain=$(( total - done ))
    (( remain < 0 )) && remain=0
    local slots_done=$(( done + 1 ))   # include round 0
    if (( slots_done > 0 && elapsed > 0 )); then
        avg_per=$(( elapsed / slots_done ))
    else
        avg_per=0
    fi
    eta_rem=$(( avg_per * remain ))

    improvement=""
    if [[ -n "$base" && "$base" != "0" && "$base" != "0.00" ]]; then
        improvement=$(python3 -c "b=float('$base'); g=float('$bgen'); print(f'{(g-b)/b*100:+.1f}%')" 2>/dev/null || echo "")
    fi

    # Use color if stdout OR stderr is a TTY (GUI may pipe one but not the other)
    if [[ -t 1 || -t 2 ]]; then
        color=$'\033[1;36m'; dim=$'\033[2m'; reset=$'\033[0m'
    else
        color=""; dim=""; reset=""
    fi

    local el_s eta_s pct bar filled empty i
    el_s=$(_tune_fmt_duration "$elapsed")
    eta_s=$(_tune_fmt_duration "$eta_rem")
    pct=0
    (( total > 0 )) && pct=$(( done * 100 / total ))
    (( pct > 100 )) && pct=100
    # 20-char progress bar (ASCII-safe — works on every terminal incl. GUI)
    filled=$(( pct / 5 ))
    empty=$(( 20 - filled ))
    bar=""
    for ((i=0; i<filled; i++)); do bar+="#"; done
    for ((i=0; i<empty;  i++)); do bar+="-"; done

    # Build the block once, then write it to stdout AND /dev/tty (if it exists).
    # /dev/tty fallback guarantees visibility even when stdout is piped/redirected
    # by the GUI or a wrapping terminal.
    local block
    block=$(printf '\n%s================ AI Tune progress ================%s\n' "$color" "$reset"
            printf '%s  round %d/%d  [%s]  %d%%%s\n' "$color" "$done" "$total" "$bar" "$pct" "$reset"
            printf '%s  elapsed %s | ETA %s | best: %s @ %s tok/s %s%s%s\n' \
                "$color" "$el_s" "$eta_s" "$bname" "$bgen" "$dim" "$improvement" "$reset"
            printf '%s==================================================%s\n' "$color" "$reset")
    printf '%s\n' "$block"
    # Also mirror to /dev/tty so the user sees it even if stdout was captured
    { printf '%s\n' "$block" > /dev/tty; } 2>/dev/null || true
}

ai_tune() {
    mkdir -p "$CACHE_DIR"
    local vision_suffix=""
    [[ -n "$MMPROJ_PATH" ]] && vision_suffix="_v"
    local tune_cache_key="${MODEL_NAME}_${TOTAL_SIZE_BYTES}_hw$(echo "${GPU_COUNT}_$(for i in $(seq 0 $((GPU_COUNT-1))); do echo -n "${GPU_NAME[$i]}_"; done)" | md5sum | cut -c1-8)${vision_suffix}_${BACKEND_TAG}"
    local tune_cache_suffix=""
    (( DO_UNLIMITED )) && tune_cache_suffix="_unlimited"
    local tune_cache="$CACHE_DIR/tune_${tune_cache_key}${tune_cache_suffix}.json"

    # Check existing cache (unless --retune)
    if [[ -f "$tune_cache" && "$RETUNE" == "0" ]]; then
        echo ""
        echo "═══ AI Tune: cached result found ═══"
        python3 -c "
import json
d = json.load(open('$tune_cache'))
b = d.get('best_config', {})
print(f'  Winner: {b.get(\"name\", \"?\")}')" 2>/dev/null
        python3 -c "
import json
d = json.load(open('$tune_cache'))
b = d.get('best_config', {})
print(f'  Gen: {b.get(\"gen_tps\", \"?\")} tok/s  PP: {b.get(\"pp_tps\", \"?\")} tok/s')
print(f'  Tuned: {d.get(\"tuned_at\", \"?\")}')" 2>/dev/null
        echo "  Run --ai-tune --retune to re-optimize"
        echo ""
        load_tune_cache || true
        echo "Launching with tuned config..."
        return 0
    fi

    # Warn if model is very large relative to system memory
    # AI tune needs to reload the model multiple times — tight fits risk OOM or very slow cycles
    local total_ram_mb
    total_ram_mb=$(awk '/MemTotal/ {printf "%.0f", $2/1024}' /proc/meminfo 2>/dev/null) || total_ram_mb=${RAM_AVAIL_MB}
    local system_mem_mb=$(( TOTAL_VRAM_MB + total_ram_mb ))
    local model_pct=$(( TOTAL_SIZE_MB * 100 / system_mem_mb ))
    if (( model_pct > 70 )); then
        echo ""
        echo "WARNING: Model uses ${model_pct}% of system memory (${TOTAL_SIZE_MB}MB / ${system_mem_mb}MB)."
        echo "  AI Tune reloads the model each round — this will be very slow (~${AI_TUNE_ROUNDS}x load time)"
        echo "  and may trigger OOM on memory-constrained systems."
        echo ""
        read -r -t 30 -p "Continue with AI Tune? [y/N] " answer < /dev/tty || answer="n"
        if [[ "${answer,,}" != "y" ]]; then
            echo "AI Tune cancelled."
            return 0
        fi
    fi

    echo ""
    echo "═══════════════════════════════════════════════════"
    if (( DO_UNLIMITED )); then
        echo "  AI Tune — Full placement mode (--placement-tune)"
        echo "  Model: ${MODEL_NAME}"
        echo "  Rounds: ${AI_TUNE_ROUNDS}  (tensor-split + split-mode unlocked)"
        echo "  Scope: may change placement/split/perf flags except explicit user choices"
        echo "  Warning: this can take 1-3 hours on large models"
    else
        echo "  AI Tune — iterative LLM-driven optimization"
        echo "  Model: ${MODEL_NAME}"
        echo "  Rounds: ${AI_TUNE_ROUNDS}"
    fi
    echo "═══════════════════════════════════════════════════"
    if (( ! VERBOSE )); then
        echo "  (quiet mode — run with -v / --verbose to see full logs)"
        echo "  Server logs: $SERVER_LOG"
    fi
    echo ""

    # Quiet mode: redirect chatty stdout/stderr to SERVER_LOG.
    # The progress box still renders via /dev/tty inside _tune_progress_line,
    # and we restore stdout before the final completion summary.
    # RETURN trap guarantees restoration on any early exit path.
    if (( ! VERBOSE )); then
        exec 7>&1 8>&2
        # shellcheck disable=SC2064
        trap '{ exec 1>&7 2>&8; exec 7>&- 8>&-; } 2>/dev/null; trap - RETURN' RETURN
        exec >> "$SERVER_LOG" 2>&1
    fi

    # Hardware hash for history tracking
    local hw_hash
    hw_hash=$(echo "${GPU_COUNT}_$(for i in $(seq 0 $((GPU_COUNT-1))); do echo -n "${GPU_NAME[$i]}_"; done)" | md5sum | cut -c1-8)

    # Load past tuning history
    local tune_history
    tune_history=$(load_tune_history "$hw_hash")

    # Collect context
    local help_text
    help_text=$("$LLAMA_SERVER" --help 2>&1 || true)
    local hw_profile
    hw_profile=$(build_hw_profile)
    local model_profile
    model_profile=$(build_model_profile)
    local fixed_flags
    fixed_flags=$(build_fixed_flags)

    # Temp dir for message passing (avoids shell escaping issues)
    local tune_msg_dir
    tune_msg_dir=$(mktemp -d /tmp/llm-tune-msgs.XXXXXX)

    # Current baseline flags description
    local baseline_flags_desc=""
    for f in "${COMMON_FLAGS[@]}"; do
        baseline_flags_desc+="$f "
    done

    # ── Round 0: Benchmark baseline ──
    local tune_start_ts
    tune_start_ts=$(date +%s)
    echo "Round 0/${AI_TUNE_ROUNDS}: Benchmarking baseline (heuristic config)..."
    kill_server ""
    if ! try_start; then
        echo "ERROR: Baseline config failed to start"
        return 1
    fi

    local bench_result baseline_gen baseline_pp
    bench_result=$(bench_gen_tps)
    # awk reads all of stdin so no SIGPIPE here, but `|| true` keeps us safe
    # if bench_result is empty or awk ever gets replaced.
    baseline_gen=$(echo "$bench_result" | awk '{print $1}' || true)
    baseline_pp=$(echo "$bench_result" | awk '{print $2}' || true)
    echo "  Baseline: gen=${baseline_gen} tok/s  pp=${baseline_pp} tok/s"
    _tune_progress_line 0 "$AI_TUNE_ROUNDS" "$tune_start_ts" "$baseline_gen" "baseline" "$baseline_gen"

    if [[ "$baseline_gen" == "0" || "$baseline_gen" == "0.00" || -z "$baseline_gen" ]]; then
        echo "ERROR: Could not measure baseline"
        kill_server "$RUNNING_PID"
        rm -rf "$tune_msg_dir"
        return 1
    fi

    # Log baseline to history
    append_tune_history 0 "$baseline_gen" "$baseline_pp" "ok" "{}" "baseline"

    # Build the system prompt (sent once, contains all static context)
    local system_prompt
    system_prompt=$(cat <<'SYSEOF'
You are an expert performance tuner for llama.cpp inference servers.

Your goal: maximize GENERATION tok/s while preserving output quality.
Speed is the primary metric. Quality must not be sacrificed for marginal speed gains.

# How this works
- I give you hardware info, model info, the full --help output, and the current config + benchmark results
- You propose ONE config per round
- I benchmark it and tell you the results (or report a crash)
- You learn from each result and propose a better config next round
- We do 8 rounds. Make each one count — never repeat a failed or worse config.

# Optimization priority (in order)
1. GPU split strategy: single GPU > graph split > row split > layer split
2. Flash attention: enable it — faster and unlocks KV quantization
3. KV cache quantization: q8_0 is the sweet spot (2x VRAM savings, negligible quality loss). q4_0 saves 4x VRAM but degrades long-context quality — only use if VRAM-starved.
4. Batch size tuning: 2048-4096 is usually optimal. Above 4096 = diminishing returns.
5. Thread count: generation threads = physical CPU cores. Hyperthreads don't help.
6. Memory flags: --no-mmap when model spans GPU + RAM. --mlock pins RAM (less swapping).

# Quality guardrails
- Prefer q8_0 KV over q4_0 — the speed difference is small but quality difference is real
- Quantized KV cache REQUIRES --flash-attn — crashes without it
- Don't reduce context size to gain speed — it cripples usability
- --parallel 1 unless multi-user is explicitly needed (extra slots waste VRAM)

# Crash recovery
- If a config crashed, your next proposal must be MORE conservative on the likely cause
- OOM = reduce batch, increase KV quantization, or spread across more GPUs
- Immediate crash = you used an unsupported or invalid flag — remove it
- Never repeat a config that crashed. Build on what worked instead.
{unlimited_section}
# Rules
1. The baseline config flags are ALREADY applied. You only propose CHANGES.
2. Your "flags" JSON should contain ONLY flags you want to ADD or OVERRIDE.
   Example: {"--batch-size": "4096", "--flash-attn": "on"} — these replace the baseline values.
3. Boolean flags: {"--no-mmap": true, "--mlock": true}
4. To remove a baseline flag: {"--some-flag": false}
5. These flags are FIXED (never include them): {fixed_flags}
6. Your response MUST contain a JSON object with these keys:
   {"name": "short description", "flags": {...}, "reasoning": "why this should be faster"}
7. Think carefully about VRAM budget — total VRAM minus model size = room for KV + batch buffers
8. ONLY use flags from the --help output. Unknown flags crash the server.
SYSEOF
)
    # Replace {fixed_flags} placeholder
    system_prompt="${system_prompt//\{fixed_flags\}/$fixed_flags}"

    # Replace {unlimited_section} — only active when --unlimited is set
    local unlimited_section=""
    if (( DO_UNLIMITED )); then
        unlimited_section=$'\n# FULL PLACEMENT MODE (--placement-tune / legacy --unlimited)\nYou may perturb normally-deterministic placement and performance flags, except flags explicitly chosen by the user. User-locked flags are rejected even if you propose them.\n- --tensor-split R0,R1,R2,... (ratios across GPUs; baseline is bandwidth-weighted; try small skews first)\n- --split-mode (graph | row | layer) — test alternatives on multi-GPU\n- --device / --main-gpu / -ngl when no user GPU filter was provided\n- Batch, micro-batch, parallelism, threads, memory flags, and KV cache type when not user-locked\nMoE expert -ot placement is locked after the placement pass; optimize around it unless a future mode explicitly unlocks MoE placement. Start small (one perturbation per round) so you can attribute gains.\n'
    fi
    system_prompt="${system_prompt//\{unlimited_section\}/$unlimited_section}"

    # WSL2-specific guardrails — on WSL2, --mlock can freeze the Windows host
    # and the OOM killer is unreliable, so we tighten memory-aggressive tuning.
    if (( IS_WSL2 )); then
        local wsl2_note=$'\n# WSL2 environment — extra caution required\n- NEVER propose --mlock (causes host freeze; script will strip it if you try).\n- Host OOM killer is unreliable — prefer conservative batch/parallel values.\n- Headroom is tighter: stay at least 3GB below the system total.\n'
        system_prompt="${system_prompt}${wsl2_note}"
    fi

    # Build the initial user message with all context
    local initial_context
    initial_context=$(cat <<CTXEOF
# Hardware
${hw_profile}

# Model
${model_profile}

# Server --help output (FULL — every available flag)
${help_text}

# Current baseline config
Flags: ${baseline_flags_desc}
Benchmark: gen=${baseline_gen} tok/s, pp=${baseline_pp} tok/s

# VRAM/RAM safety budget
- Model size: ${TOTAL_SIZE_MB}MB | KV cache: ${KV_TOTAL_MB:-0}MB (${KV_QUALITY:-?})
- Total VRAM: ${TOTAL_VRAM_MB:-0}MB | Total RAM: ${RAM_AVAIL_MB:-0}MB
- KV cache sizes at ctx=${CTX_SIZE}: q4_0≈${KV_TOTAL_MB:-0}MB, q8_0≈$((KV_TOTAL_MB * 2))MB, f16≈$((KV_TOTAL_MB * 4))MB
- CRITICAL: If model+KV+batch already uses >90% of VRAM+RAM, do NOT increase KV cache size (q4_0→q8_0 doubles it!)
- Increasing batch size also uses more VRAM. Stay within budget.
- If baseline uses q4_0 KV, it's likely because VRAM is tight — respect that choice unless headroom exists.

# Performance + quality guide
- Single GPU > Multi GPU (eliminates inter-GPU transfer overhead)
- graph split > row split > layer split (when multi-GPU is needed)
- --flash-attn: almost always faster, required for quantized KV cache
- KV cache q8_0: best speed/quality tradeoff (2x VRAM savings vs f16, negligible quality loss) — BUT 2x bigger than q4_0
- KV cache q4_0: 4x VRAM savings vs f16, slight quality loss on long contexts — use when VRAM is tight
- batch 2048-4096 usually optimal, above 4096 = diminishing returns
- threads for gen = physical CPU cores, hyperthreads don't help
- --no-mmap when model is split across GPU + system RAM
- Quantized KV (q4_0/q8_0) REQUIRES --flash-attn — crashes without it
- ONLY use flags from the --help output above. Unknown flags crash the server.
- Check the "backend" field in Model info to know which server binary you're tuning.

# Previous tuning history (learn from past results!)
${tune_history}

Propose your first config to try. Think about what might beat the baseline. Use the history above to avoid repeating mistakes and build on what worked.
CTXEOF
)

    # Write messages to temp files for safe JSON construction
    echo "$system_prompt" > "$tune_msg_dir/system.txt"
    echo "$initial_context" > "$tune_msg_dir/context.txt"

    local messages
    messages=$(python3 -c "
import json
msgs = [
    {'role': 'system', 'content': open('${tune_msg_dir}/system.txt').read()},
    {'role': 'user', 'content': open('${tune_msg_dir}/context.txt').read()}
]
print(json.dumps(msgs))
")

    # Track all results
    local all_results="[]"
    local best_gen="$baseline_gen"
    local best_pp="$baseline_pp"
    local best_name="baseline"
    local best_flags_json="{}"

    # ── Iterative tuning rounds ──
    local round=0 crash_retries=0
    while (( round < AI_TUNE_ROUNDS )); do
        (( ++round ))
        echo ""
        echo "Round ${round}/${AI_TUNE_ROUNDS}: Querying model for config proposal..."

        # Query the currently running model
        local llm_response
        llm_response=$(query_llm_chat "$messages")

        if [[ -z "$llm_response" || "$llm_response" == "ERROR" ]]; then
            echo "  WARNING: No response from model, skipping round"
            continue
        fi

        # Parse the config from LLM response
        local parsed
        parsed=$(python3 -c "
import json, sys, re

text = sys.stdin.read()

# Find JSON object in response
# Try to find {...} pattern
matches = list(re.finditer(r'\{[^{}]*(?:\{[^{}]*\}[^{}]*)*\}', text, re.DOTALL))
if not matches:
    print('PARSE_ERROR')
    sys.exit(0)

# Find the one that has 'flags' key
for m in matches:
    try:
        obj = json.loads(m.group())
        if 'flags' in obj:
            print(json.dumps(obj))
            sys.exit(0)
    except json.JSONDecodeError:
        continue

# Fallback: try last match
try:
    obj = json.loads(matches[-1].group())
    print(json.dumps(obj))
except:
    print('PARSE_ERROR')
" <<< "$llm_response")

        if [[ "$parsed" == "PARSE_ERROR" || -z "$parsed" ]]; then
            echo "  WARNING: Could not parse config from response, skipping"
            # Add to conversation so LLM knows it failed
            echo "$llm_response" > "$tune_msg_dir/resp_${round}.txt"
            messages=$(python3 -c "
import json, sys
msgs = json.loads(sys.stdin.read())
msgs.append({'role': 'assistant', 'content': open('${tune_msg_dir}/resp_${round}.txt').read()})
msgs.append({'role': 'user', 'content': 'ERROR: Could not parse your response as JSON. Please respond with a JSON object containing \"name\", \"flags\" (object), and \"reasoning\" keys.'})
print(json.dumps(msgs))
" <<< "$messages")
            continue
        fi

        local config_name config_reasoning config_flags_json
        # pipefail guards: a malformed LLM JSON response would silently exit
        # the tuner (and the whole script) without these.
        config_name=$(echo "$parsed" | python3 -c "import sys,json; print(json.load(sys.stdin).get('name','config_${round}'))" 2>/dev/null || echo "config_${round}")
        config_reasoning=$(echo "$parsed" | python3 -c "import sys,json; print(json.load(sys.stdin).get('reasoning',''))" 2>/dev/null || echo "")
        config_flags_json=$(echo "$parsed" | python3 -c "import sys,json; print(json.dumps(json.load(sys.stdin).get('flags',{})))" 2>/dev/null || echo "{}")

        echo "  Config: ${config_name}"
        echo "  Reason: ${config_reasoning}"

        # Parse LLM overrides into flag array
        parse_tune_overrides "$config_flags_json"
        echo "  Overrides: ${TUNE_OVERRIDE_FLAGS[*]:-none}"

        # Add assistant response to conversation
        echo "$llm_response" > "$tune_msg_dir/resp_${round}.txt"
        messages=$(python3 -c "
import json, sys
msgs = json.loads(sys.stdin.read())
msgs.append({'role': 'assistant', 'content': open('${tune_msg_dir}/resp_${round}.txt').read()})
print(json.dumps(msgs))
" <<< "$messages")

        # RAM/VRAM safety check — will this config OOM the system?
        # Factors considered: KV cache type (f16/q8_0/q4_0), batch size (-b/-ub),
        # parallel slot count (--parallel N multiplies KV + compute buffers).
        # 5GB reserved for OS/other processes.
        local est_kv_mb=${KV_TOTAL_MB:-0}
        local proposed_kv_k proposed_batch proposed_ubatch proposed_parallel
        proposed_kv_k=$(echo "$config_flags_json" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('--cache-type-k',''))" 2>/dev/null) || true
        proposed_batch=$(echo "$config_flags_json" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('-b', d.get('--batch-size','')))" 2>/dev/null) || true
        proposed_ubatch=$(echo "$config_flags_json" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('-ub', d.get('--ubatch-size','')))" 2>/dev/null) || true
        proposed_parallel=$(echo "$config_flags_json" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('--parallel', d.get('-np','')))" 2>/dev/null) || true

        # KV multiplier from proposed cache type (falls back to current KV_QUALITY)
        local kv_mult=1
        case "${proposed_kv_k:-${KV_QUALITY:-q4_0}}" in
            f16)  kv_mult=4 ;;
            q8_0) kv_mult=2 ;;
            q4_0) kv_mult=1 ;;
        esac
        est_kv_mb=$(( KV_TOTAL_MB * kv_mult ))

        # --parallel multiplies KV cache allocation per slot
        local parallel_slots=${proposed_parallel:-${PARALLEL_SLOTS:-4}}
        [[ ! "$parallel_slots" =~ ^[0-9]+$ ]] && parallel_slots=4
        (( parallel_slots < 1 )) && parallel_slots=1
        est_kv_mb=$(( est_kv_mb * parallel_slots ))

        # Compute buffer scales with batch size. Conservative estimate:
        # ~0.5 MB per token of batch (model-dependent, err high).
        local batch_sz=${proposed_batch:-${BATCH:-2048}}
        [[ ! "$batch_sz" =~ ^[0-9]+$ ]] && batch_sz=2048
        local est_compute_mb=$(( batch_sz / 2 ))
        (( est_compute_mb < 512 )) && est_compute_mb=512

        local est_total_mb=$(( TOTAL_SIZE_MB + est_kv_mb + est_compute_mb ))
        local total_ram_mb
        total_ram_mb=$(awk '/MemTotal/ {printf "%.0f", $2/1024}' /proc/meminfo 2>/dev/null) || total_ram_mb=${RAM_AVAIL_MB}
        local system_total_mb=$(( TOTAL_VRAM_MB + total_ram_mb - 5120 ))  # 5GB OS reserve
        # Tighter reserve on WSL2 since host freeze is catastrophic and OOM killer is unreliable
        (( IS_WSL2 )) && system_total_mb=$(( system_total_mb - 3072 ))

        if (( est_total_mb > system_total_mb )); then
            echo "  SKIPPED — estimated ${est_total_mb}MB > system capacity ${system_total_mb}MB (OOM protection)"
            echo "Result for '${config_name}': SKIPPED — needs ~${est_total_mb}MB (model ${TOTAL_SIZE_MB}MB + KV ${est_kv_mb}MB [parallel=${parallel_slots}] + compute ${est_compute_mb}MB [batch=${batch_sz}]) but system has ${system_total_mb}MB usable. Do NOT increase KV cache, batch size, or parallel. Try other flags." > "$tune_msg_dir/feedback_${round}.txt"
            messages=$(python3 -c "
import json, sys
msgs = json.loads(sys.stdin.read())
msgs.append({'role': 'user', 'content': open('${tune_msg_dir}/feedback_${round}.txt').read()})
print(json.dumps(msgs))
" <<< "$messages")
            _tune_progress_line "$round" "$AI_TUNE_ROUNDS" "$tune_start_ts" "$best_gen" "$best_name" "$baseline_gen"
            # Baseline is still running — no restart needed
            continue
        fi

        # Kill current server, start with new config (COMMON_FLAGS + overrides)
        kill_server "$RUNNING_PID"
        sleep 1

        local round_gen="0" round_pp="0" round_status="ok"

        if ! try_start_with_overrides; then
            echo "  CRASHED — config failed to start"
            kill_server ""
            round_status="crashed"
            (( ++crash_retries ))

            # Crashes don't count toward round limit (up to MAX_CRASHES free retries)
            if (( crash_retries <= AI_TUNE_MAX_CRASHES )); then
                echo "  (free retry ${crash_retries}/${AI_TUNE_MAX_CRASHES} — crash doesn't count as a round)"
                (( round-- ))
            fi

            # Restart with baseline to query for next round
            echo "  Restarting baseline for next query..."
            try_start || { echo "ERROR: Can't restart baseline"; break; }
        else
            # Benchmark this config
            echo "  Benchmarking..."
            bench_result=$(bench_gen_tps)
            round_gen=$(echo "$bench_result" | awk '{print $1}' || true)
            round_pp=$(echo "$bench_result" | awk '{print $2}' || true)

            local delta improvement
            delta=$(python3 -c "print(f'{${round_gen:-0} - ${baseline_gen:-0}:.2f}')" 2>/dev/null || echo "0.00")
            improvement=$(python3 -c "g=${baseline_gen:-0}; print(f'{(${round_gen:-0}-g)/g*100:.1f}' if g>0 else '0')" 2>/dev/null || echo "0")

            if python3 -c "exit(0 if ${round_gen} > ${best_gen} else 1)"; then
                echo "  ★ NEW BEST: gen=${round_gen} tok/s (+${improvement}%)  pp=${round_pp} tok/s"
                best_gen="$round_gen"
                best_pp="$round_pp"
                best_name="$config_name"
                best_flags_json="$config_flags_json"
            else
                echo "  Result: gen=${round_gen} tok/s (${improvement}%)  pp=${round_pp} tok/s"
            fi

            # Kill tested config, restart baseline for next query
            kill_server "$RUNNING_PID"
            sleep 1
            echo "  Restarting baseline for next query..."
            try_start || { echo "ERROR: Can't restart baseline after benchmark"; break; }
        fi

        # Record result (local + persistent history)
        echo "$config_name" > "$tune_msg_dir/name_${round}.txt"
        all_results=$(CONFIG_FLAGS_JSON="$config_flags_json" python3 -c "
import json, os, sys
results = json.loads(sys.stdin.read())
try:
    flags_obj = json.loads(os.environ.get('CONFIG_FLAGS_JSON', '{}'))
except json.JSONDecodeError:
    flags_obj = {}
results.append({
    'round': ${round},
    'name': open('${tune_msg_dir}/name_${round}.txt').read().strip(),
    'gen_tps': ${round_gen},
    'pp_tps': ${round_pp},
    'flags': flags_obj,
    'status': '${round_status}'
})
print(json.dumps(results))
" <<< "$all_results")

        # Append to persistent history
        append_tune_history "$round" "$round_gen" "$round_pp" "$round_status" "$config_flags_json" "$config_name"

        # Progress: elapsed + ETA + best-so-far
        _tune_progress_line "$round" "$AI_TUNE_ROUNDS" "$tune_start_ts" "$best_gen" "$best_name" "$baseline_gen"

        # Feed result back to LLM for next round
        local feedback
        if [[ "$round_status" == "crashed" ]]; then
            feedback="Result for '${config_name}': CRASHED (server failed to start — likely OOM or invalid flags). Current best: gen=${best_gen} tok/s. Baseline: gen=${baseline_gen} tok/s. IMPORTANT: Do NOT increase memory usage (bigger KV cache, bigger batch) — this system is memory-constrained. Try changing non-memory flags instead (threads, split mode, micro-batch)."
        else
            feedback="Result for '${config_name}': gen=${round_gen} tok/s, pp=${round_pp} tok/s (baseline: gen=${baseline_gen}, best so far: gen=${best_gen}). Propose your next config."
        fi

        echo "$feedback" > "$tune_msg_dir/feedback_${round}.txt"
        messages=$(python3 -c "
import json, sys
msgs = json.loads(sys.stdin.read())
msgs.append({'role': 'user', 'content': open('${tune_msg_dir}/feedback_${round}.txt').read()})
print(json.dumps(msgs))
" <<< "$messages")

    done

    # ── Save results ──
    kill_server "$RUNNING_PID"
    kill_server ""

    local tune_total_elapsed=$(( $(date +%s) - tune_start_ts ))

    # Restore stdout/stderr so the final summary is visible in quiet mode
    if (( ! VERBOSE )); then
        exec 1>&7 2>&8
        exec 7>&- 8>&-
    fi

    echo ""
    echo "═══════════════════════════════════════════════════"
    if [[ "$best_name" == "baseline" ]]; then
        echo "  AI Tune complete: baseline wins"
        echo "  The heuristic config is already optimal (${baseline_gen} tok/s)"
        echo "  Total time: $(_tune_fmt_duration "$tune_total_elapsed")"
        echo "═══════════════════════════════════════════════════"

        # Save a marker cache so future --ai-tune runs detect "already tuned"
        # best_config.flags is empty → load_tune_cache returns 1 and COMMON_FLAGS
        # is unchanged (which is exactly what "baseline wins" means).
        python3 -c "
import json
from datetime import datetime, timezone
cache = {
    'model': '${MODEL_NAME}',
    'tuned_at': datetime.now(timezone.utc).isoformat().replace('+00:00', 'Z'),
    'provider': 'self',
    'baseline_gen_tps': ${baseline_gen},
    'baseline_pp_tps': ${baseline_pp},
    'baseline_wins': True,
    'best_config': {
        'name': 'baseline',
        'flags': {},
        'gen_tps': ${baseline_gen},
        'pp_tps': ${baseline_pp},
    },
    'rounds': ${AI_TUNE_ROUNDS},
    'all_results': json.loads(open('/dev/stdin').read())
}
with open('${tune_cache}', 'w') as f:
    json.dump(cache, f, indent=2)
print(f'  Saved marker to: ${tune_cache}')
" <<< "$all_results"
    else
        local total_improvement
        total_improvement=$(python3 -c "g=${baseline_gen}; print(f'{(${best_gen}-g)/g*100:.1f}' if g>0 else '0')")
        echo "  AI Tune complete: ${best_name} wins!"
        echo "  Baseline: ${baseline_gen} tok/s → Best: ${best_gen} tok/s (+${total_improvement}%)"
        echo "  Total time: $(_tune_fmt_duration "$tune_total_elapsed")"
        echo "═══════════════════════════════════════════════════"

        # Save to cache
        echo "$best_name" > "$tune_msg_dir/best_name.txt"
        BEST_FLAGS_JSON="$best_flags_json" python3 -c "
import json, os
from datetime import datetime, timezone
try:
    best_flags = json.loads(os.environ.get('BEST_FLAGS_JSON', '{}'))
except json.JSONDecodeError:
    best_flags = {}
cache = {
    'model': '${MODEL_NAME}',
    'tuned_at': datetime.now(timezone.utc).isoformat().replace('+00:00', 'Z'),
    'provider': 'self',
    'baseline_gen_tps': ${baseline_gen},
    'baseline_pp_tps': ${baseline_pp},
    'best_config': {
        'name': open('${tune_msg_dir}/best_name.txt').read().strip(),
        'flags': best_flags,
        'gen_tps': ${best_gen},
        'pp_tps': ${best_pp},
    },
    'rounds': ${AI_TUNE_ROUNDS},
    'all_results': json.loads(open('/dev/stdin').read())
}
with open('${tune_cache}', 'w') as f:
    json.dump(cache, f, indent=2)
print(f'  Saved to: ${tune_cache}')
" <<< "$all_results"
    fi

    # Cleanup temp files
    rm -rf "$tune_msg_dir"

    echo ""
    exit 0
}

# Load AI tune cache — merges tuned flag overrides with fixed flags
load_tune_cache() {
    mkdir -p "$CACHE_DIR"
    local vision_suffix=""
    [[ -n "$MMPROJ_PATH" ]] && vision_suffix="_v"
    local tune_cache_key="${MODEL_NAME}_${TOTAL_SIZE_BYTES}_hw$(echo "${GPU_COUNT}_$(for i in $(seq 0 $((GPU_COUNT-1))); do echo -n "${GPU_NAME[$i]}_"; done)" | md5sum | cut -c1-8)${vision_suffix}_${BACKEND_TAG}"
    local tune_cache_suffix=""
    (( DO_UNLIMITED )) && tune_cache_suffix="_unlimited"
    local tune_cache="$CACHE_DIR/tune_${tune_cache_key}${tune_cache_suffix}.json"
    local explicit_cache=0
    if [[ -n "$EXPLICIT_TUNE_CACHE" ]]; then
        explicit_cache=1
        tune_cache="$EXPLICIT_TUNE_CACHE"
        if [[ ! -f "$tune_cache" ]]; then
            echo "Error: --tune-cache not found: $tune_cache" >&2
            exit 1
        fi
        if ! MODEL_NAME="$MODEL_NAME" TUNE_CACHE="$tune_cache" python3 -c "
import json, os, sys
try:
    d = json.load(open(os.environ['TUNE_CACHE'], encoding='utf-8'))
except Exception as exc:
    print(f'Error: invalid tune cache JSON: {exc}', file=sys.stderr)
    sys.exit(1)
if d.get('model') != os.environ['MODEL_NAME']:
    print(f\"Error: tune cache is for {d.get('model', '?')}, not {os.environ['MODEL_NAME']}\", file=sys.stderr)
    sys.exit(1)
b = d.get('best_config', {}) or {}
if not b.get('gen_tps') and not d.get('baseline_wins'):
    print('Error: tune cache has no successful measured config', file=sys.stderr)
    sys.exit(1)
"; then
            exit 1
        fi
    # Full-placement cache preferred when --placement-tune is set; fall back to regular if present.
    elif (( DO_UNLIMITED )) && [[ ! -f "$tune_cache" && -f "$CACHE_DIR/tune_${tune_cache_key}.json" ]]; then
        tune_cache="$CACHE_DIR/tune_${tune_cache_key}.json"
    fi

    if [[ -f "$tune_cache" ]]; then
        echo ""
        if (( explicit_cache )); then
            echo "Using selected AI-tuned config: $(basename "$tune_cache")"
        else
            echo "Using AI-tuned config (run --ai-tune --retune to re-optimize)"
        fi

        # Apply tuned overrides on top of COMMON_FLAGS (with alias normalization + dedup)
        local tuned_extras=() override_keys=() locked_keys_env allow_placement=0
        TUNE_CACHE_HAS_PLACEMENT=0
        if (( DO_UNLIMITED || explicit_cache )); then
            allow_placement=1
        fi
        locked_keys_env=$(printf '%s\n' "${TUNE_USER_LOCKED_KEYS[@]:-}")
        while IFS= read -r -d '' item; do
            case "$item" in
                F$'\t'*) tuned_extras+=("${item#F$'\t'}") ;;
                K$'\t'*) override_keys+=("${item#K$'\t'}") ;;
            esac
        done < <(TUNE_CACHE="$tune_cache" ALLOW_PLACEMENT="$allow_placement" TUNE_USER_LOCKED_KEYS="$locked_keys_env" python3 -c "
import json, os, sys
try:
    with open(os.environ['TUNE_CACHE'], encoding='utf-8') as f:
        d = json.load(f)
except (OSError, json.JSONDecodeError, KeyError):
    d = {}
overrides = d.get('best_config', {}).get('flags', {})
if not isinstance(overrides, dict):
    overrides = {}
aliases = {
    '--mg': '-mg', '--main-gpu': '-mg',
    '--batch-size': '-b', '--ubatch-size': '-ub',
    '--ngl': '-ngl', '--n-gpu-layers': '-ngl',
    '--n-cpu-moe': '--n-cpu-moe', '-ncmoe': '--n-cpu-moe',
    '--override-tensor': '-ot',
    '--threads': '--threads', '-t': '--threads',
    '--threads-batch': '--threads-batch', '-tb': '--threads-batch',
    '--parallel': '--parallel', '-np': '--parallel',
    '--flash-attn': '--flash-attn', '-fa': '--flash-attn',
    '--reasoning': '--reasoning', '-rea': '--reasoning',
}
protected = {'-m', '--host', '--port', '--ctx-size', '--mmproj', '-ot', '--reasoning'}
protected |= {k for k in os.environ.get('TUNE_USER_LOCKED_KEYS', '').splitlines() if k}
if os.environ.get('ALLOW_PLACEMENT') != '1':
    protected |= {'--device', '--tensor-split', '--split-mode', '-mg', '-ngl', '-ot', '--n-cpu-moe'}
records = []
for k, v in overrides.items():
    if not isinstance(k, str) or not k.startswith('-'):
        continue
    k = aliases.get(k, k)
    if k in protected:
        continue
    if v is False:
        continue
    records.append(('K', k))
    records.append(('F', k))
    if v is not True and v != '' and v is not None:
        records.append(('F', str(v)))
for kind, value in records:
    sys.stdout.write(kind + '\t' + value + '\0')
	" 2>/dev/null || true)

        if (( ${#tuned_extras[@]} > 0 )); then
            local key
            for key in "${override_keys[@]}"; do
                case "$key" in
                    --device|--tensor-split|--split-mode|-mg|-ngl|-ot|--n-cpu-moe)
                        TUNE_CACHE_HAS_PLACEMENT=1
                        ;;
                esac
            done
            # Strip flags from COMMON_FLAGS that the tuned config overrides
            local deduped=()
            local skip_next=0
            for (( ci=0; ci<${#COMMON_FLAGS[@]}; ci++ )); do
                if (( skip_next )); then skip_next=0; continue; fi
                local cflag="${COMMON_FLAGS[$ci]}"
                local dominated=0
                for key in "${override_keys[@]}"; do
                    if [[ "$cflag" == "$key" ]]; then
                        dominated=1
                        if (( ci + 1 < ${#COMMON_FLAGS[@]} )) && [[ "${COMMON_FLAGS[$((ci+1))]}" != -* ]]; then
                            skip_next=1
                        fi
                        break
                    fi
                done
                (( dominated )) || deduped+=("$cflag")
            done
            COMMON_FLAGS=("${deduped[@]}" "${tuned_extras[@]}")
            TUNE_CACHE="$tune_cache" python3 -c "
import json, os
d = json.load(open(os.environ['TUNE_CACHE']))
b = d.get('best_config', {})
print(f'  Config: {b.get(\"name\", \"?\")}')" 2>/dev/null
            TUNE_CACHE="$tune_cache" python3 -c "
import json, os
d = json.load(open(os.environ['TUNE_CACHE']))
b = d.get('best_config', {})
print(f'  Expected: gen={b.get(\"gen_tps\", \"?\")} tok/s  pp={b.get(\"pp_tps\", \"?\")} tok/s')" 2>/dev/null
            return 0
        else
            # baseline-wins marker: no overrides to apply, but note it was tuned
            local is_baseline_wins
            is_baseline_wins=$(TUNE_CACHE="$tune_cache" python3 -c "
import json, os
try:
    d = json.load(open(os.environ['TUNE_CACHE']))
    print('1' if d.get('baseline_wins') else '0')
except: print('0')" 2>/dev/null)
            if [[ "$is_baseline_wins" == "1" ]]; then
                echo "  (baseline already optimal — no override flags needed)"
            fi
        fi
    fi
    return 1
}

maybe_ai_tune_launch_flags() {
    (( DO_AI_TUNE )) || return 1
    COMMON_FLAGS=("$@")
    TUNE_EXTRA_FIXED=()
    ai_tune
    return 0
}

maybe_prompt_first_run_ai_tune() {
    (( DO_AI_TUNE || DRY_RUN || BENCHMARK || RETUNE )) && return 0
    (( TUNE_LOADED )) && return 0
    [[ -n "$EXPLICIT_TUNE_CACHE" ]] && return 0
    [[ -t 0 && -r /dev/tty ]] || return 0
    (( ${LLM_ASSUME_YES:-0} == 0 )) || return 0

    local answer
    echo ""
    echo "No AI-tuned config found for this model/hardware/backend."
    echo "AI Tune can create a better config now by loading the model and benchmarking several rounds."
    echo "This usually takes a few minutes; large models or full placement mode can take longer."
    read -r -p "Run AI Tune before launching? [y/N] " answer < /dev/tty || answer=""
    case "${answer,,}" in
        y|yes)
            DO_AI_TUNE=1
            echo "AI Tune enabled for this launch."
            ;;
        *)
            echo "Continuing with heuristic config."
            ;;
    esac
}

# ═══════════════════════════════════════════════════════════════
# Section 7: Execute Strategy
# ═══════════════════════════════════════════════════════════════

# Detect user intent on mmap once, globally. USER_NO_MMAP=1 means the user
# passed --no-mmap on the CLI — respected by every strategy. The MoE section
# may further promote this to Phase 2's mmap path (MMAP_PATH=1).
# (cpu_only and dense_cpu_offload still force --no-mmap by default — that is
# intentional legacy behaviour; those paths don't benefit from paging since
# dense models touch every layer on every token.)
USER_NO_MMAP=0
for _f in "${EXTRA_LLAMA_FLAGS[@]:-}"; do
    [[ "$_f" == "--no-mmap" ]] && USER_NO_MMAP=1
done

# Load cached tune config if available — bypasses strategy-specific launch
TUNE_LOADED=0
TUNE_CACHE_HAS_PLACEMENT=0
if (( !DO_AI_TUNE )); then
    if load_tune_cache; then
        TUNE_LOADED=1
    fi
fi

# Append user passthrough flags last so they override heuristic + tune on conflict
if (( ${#EXTRA_LLAMA_FLAGS[@]} > 0 )); then
    COMMON_FLAGS+=("${EXTRA_LLAMA_FLAGS[@]}")
fi

maybe_prompt_first_run_ai_tune

# Kill any existing server on this port
kill_server ""

# Placement-tuned caches already include final placement flags, so they can skip
# strategy logic. Plain performance caches must still flow through the selected
# strategy so device/split flags are added after the tuned overrides.
if (( TUNE_LOADED && TUNE_CACHE_HAS_PLACEMENT )) && [[ "$STRATEGY" != "moe_offload" ]]; then
    if (( DRY_RUN )); then
        print_cmd "${COMMON_FLAGS[@]}"
        exit 0
    fi
    run_with_restart "${COMMON_FLAGS[@]}"
fi

case "$STRATEGY" in
    cpu_only)
        if (( CPU_ONLY )); then
            echo "Running on CPU only (forced via --cpu)"
        else
            echo "Running on CPU only (no GPUs detected)"
        fi
        check_memory_or_die "$RAM_AVAIL_MB" "RAM"
        # Build CPU-optimized flags from scratch (no GPU flags)
        LAUNCH_FLAGS=(
            -m "$MODEL_PATH" --host "$HOST" --port "$PORT"
            --ctx-size "$CTX_SIZE" --flash-attn on
            -b 512 -ub 256 -ngl 0 --no-mmap
            --cache-type-k "$KV_TYPE" --cache-type-v "$KV_TYPE"
            --jinja --threads "$THREADS_GEN" --threads-batch "$THREADS_BATCH"
        )
	        if (( SUPPORTS_REASONING_FLAG && ! USER_REASONING_EXPLICIT )); then
	            LAUNCH_FLAGS+=(--reasoning off)
	        fi
	        # Skip --mlock on WSL2 — pinning can freeze the Windows host
	        (( ! IS_WSL2 )) && LAUNCH_FLAGS+=(--mlock)
	        [[ -n "$CONTEXT_SHIFT_FLAG" ]] && LAUNCH_FLAGS+=("$CONTEXT_SHIFT_FLAG")
	        [[ -n "$MMPROJ_PATH" ]] && LAUNCH_FLAGS+=(--mmproj "$MMPROJ_PATH")
	        if (( DRY_RUN )); then
	            print_cmd "${LAUNCH_FLAGS[@]}"
	            exit 0
        fi
        if maybe_ai_tune_launch_flags "${LAUNCH_FLAGS[@]}"; then
            run_with_restart "${COMMON_FLAGS[@]}"
        fi
        run_with_restart "${LAUNCH_FLAGS[@]}"
        ;;

    single_gpu)
        local_best=${GPU_ORDER[0]}
        echo "Model fits on GPU${GPU_INDEX[$local_best]} (${GPU_NAME[$local_best]})"
        LAUNCH_FLAGS=("${COMMON_FLAGS[@]}" --device "CUDA${GPU_INDEX[$local_best]}")
        if (( DRY_RUN )); then
            print_cmd "${LAUNCH_FLAGS[@]}"
            exit 0
        fi
        if maybe_ai_tune_launch_flags "${LAUNCH_FLAGS[@]}"; then
            run_with_restart "${COMMON_FLAGS[@]}"
        fi
        run_with_restart "${LAUNCH_FLAGS[@]}"
        ;;

    multi_gpu_dense)
        # Find the smallest subset of fastest GPUs that can fit the model
        # GPU_ORDER is already sorted by bandwidth (descending)
        # Use TOTAL - 1GB per GPU (not FREE): transient desktop/compositor
        # VRAM dips on fast GPUs would otherwise spuriously reject the 2-GPU
        # subset and pull the slow PCIe GPU back in. Matches single_gpu logic.
        USE_GPU_COUNT=$GPU_COUNT
        for n in $(seq 2 $(( GPU_COUNT ))); do
            subset_vram=0
            for j in $(seq 0 $(( n - 1 ))); do
                gi=${GPU_ORDER[$j]}
                gi_usable=$(( GPU_VRAM_TOTAL[gi] - 1024 ))
                (( gi_usable < 0 )) && gi_usable=0
                (( subset_vram += gi_usable )) || true
            done
            if (( VRAM_NEEDED_MB <= subset_vram )); then
                USE_GPU_COUNT=$n
                break
            fi
        done

        # Build set of selected GPU indices for quick lookup
        declare -A SELECTED_GPUS
        for j in $(seq 0 $(( USE_GPU_COUNT - 1 ))); do
            SELECTED_GPUS[${GPU_ORDER[$j]}]=1
        done

        if (( USE_GPU_COUNT < GPU_COUNT )); then
            echo "Dense model split across $USE_GPU_COUNT of $GPU_COUNT GPUs (skipping slower GPUs)"
            for j in $(seq 0 $(( USE_GPU_COUNT - 1 ))); do
                gi=${GPU_ORDER[$j]}
                echo "  Using GPU${GPU_INDEX[$gi]}: ${GPU_NAME[$gi]} (bw=${GPU_BANDWIDTH[$gi]})"
            done
        else
            echo "Dense model split across $GPU_COUNT GPUs"
        fi

        # Build tensor-split proportional to free VRAM weighted by bandwidth
        # Zero-weight GPUs not in the selected subset
        total_weighted=0
        for i in $(seq 0 $(( GPU_COUNT - 1 ))); do
            if [[ -n "${SELECTED_GPUS[$i]:-}" ]]; then
                (( total_weighted += GPU_VRAM_FREE[$i] * GPU_BANDWIDTH[$i] )) || true
            fi
        done
        TS=""
        for i in $(seq 0 $(( GPU_COUNT - 1 ))); do
            if [[ -n "${SELECTED_GPUS[$i]:-}" ]]; then
                w=$(awk "BEGIN {printf \"%.2f\", ${GPU_VRAM_FREE[$i]} * ${GPU_BANDWIDTH[$i]} / $total_weighted}")
            else
                w="0.00"
            fi
            TS="${TS:+$TS,}$w"
        done
        echo "Tensor split: $TS"

        # Prefer graph split for both backends if more than 1 GPU
        GRAPH_EXTRA=(--split-mode graph --tensor-split "$TS")
        
        if (( IS_IK_LLAMA )); then
            LAYER_EXTRA=(--split-mode layer --tensor-split "$TS")
            if (( DRY_RUN )); then
                print_cmd "${COMMON_FLAGS[@]}" "${GRAPH_EXTRA[@]}"
                exit 0
            fi
            echo "Trying graph split (fastest)..."
            if try_start "${GRAPH_EXTRA[@]}"; then
                echo "  Graph split works — restarting with crash recovery..."
                kill_server "$RUNNING_PID"
                if maybe_ai_tune_launch_flags "${COMMON_FLAGS[@]}" "${GRAPH_EXTRA[@]}"; then
                    run_with_restart "${COMMON_FLAGS[@]}"
                fi
                run_with_restart "${COMMON_FLAGS[@]}" "${GRAPH_EXTRA[@]}"
            else
                echo "  Graph split failed — retrying with NCCL_P2P_DISABLE=1..."
                kill_server ""
                export NCCL_P2P_DISABLE=1
                if try_start "${GRAPH_EXTRA[@]}"; then
                    echo "  Graph split works with P2P disabled — restarting with crash recovery..."
                    kill_server "$RUNNING_PID"
                    if maybe_ai_tune_launch_flags "${COMMON_FLAGS[@]}" "${GRAPH_EXTRA[@]}"; then
                        run_with_restart "${COMMON_FLAGS[@]}"
                    fi
                    run_with_restart "${COMMON_FLAGS[@]}" "${GRAPH_EXTRA[@]}"
                else
                    echo "  Graph split unavailable — falling back to layer split"
                    kill_server ""
                    unset NCCL_P2P_DISABLE
                    if maybe_ai_tune_launch_flags "${COMMON_FLAGS[@]}" "${LAYER_EXTRA[@]}"; then
                        run_with_restart "${COMMON_FLAGS[@]}"
                    fi
                    run_with_restart "${COMMON_FLAGS[@]}" "${LAYER_EXTRA[@]}"
                fi
            fi
        else
            # Mainline llama.cpp
            # Test if mainline supports graph mode
            if timeout 5 "$LLAMA_SERVER" --help 2>&1 | grep -q "graph" 2>/dev/null; then
                if (( DRY_RUN )); then
                    print_cmd "${COMMON_FLAGS[@]}" "${GRAPH_EXTRA[@]}"
                    exit 0
                fi
                echo "Mainline supports graph mode — attempting launch..."
                if maybe_ai_tune_launch_flags "${COMMON_FLAGS[@]}" "${GRAPH_EXTRA[@]}"; then
                    run_with_restart "${COMMON_FLAGS[@]}"
                fi
                run_with_restart "${COMMON_FLAGS[@]}" "${GRAPH_EXTRA[@]}"
            else
                # Fallback to row split (classic mainline multi-GPU)
                LAUNCH_FLAGS=("${COMMON_FLAGS[@]}" --split-mode row --tensor-split "$TS")
                if (( DRY_RUN )); then
                    print_cmd "${LAUNCH_FLAGS[@]}"
                    exit 0
                fi
                if maybe_ai_tune_launch_flags "${LAUNCH_FLAGS[@]}"; then
                    run_with_restart "${COMMON_FLAGS[@]}"
                fi
                run_with_restart "${LAUNCH_FLAGS[@]}"
            fi
        fi
        ;;

    dense_cpu_offload)
        echo "Dense model with CPU offload"
        check_memory_or_die "$(( TOTAL_VRAM_MB + RAM_AVAIL_MB - SYSTEM_HEADROOM_MB ))" "GPU+RAM"
        if (( GPU_COUNT > 1 )); then
            GRAPH_EXTRA=(--split-mode graph --no-mmap)
            if (( IS_IK_LLAMA )); then
                # (ik_llama specific graph logic already handled above or can be simplified here)
                if (( DRY_RUN )); then print_cmd "${COMMON_FLAGS[@]}" "${GRAPH_EXTRA[@]}"; exit 0; fi
                if maybe_ai_tune_launch_flags "${COMMON_FLAGS[@]}" "${GRAPH_EXTRA[@]}"; then
                    run_with_restart "${COMMON_FLAGS[@]}"
                fi
                run_with_restart "${COMMON_FLAGS[@]}" "${GRAPH_EXTRA[@]}"
            else
                # Mainline
                if timeout 5 "$LLAMA_SERVER" --help 2>&1 | grep -q "graph" 2>/dev/null; then
                    if (( DRY_RUN )); then print_cmd "${COMMON_FLAGS[@]}" "${GRAPH_EXTRA[@]}"; exit 0; fi
                    if maybe_ai_tune_launch_flags "${COMMON_FLAGS[@]}" "${GRAPH_EXTRA[@]}"; then
                        run_with_restart "${COMMON_FLAGS[@]}"
                    fi
                    run_with_restart "${COMMON_FLAGS[@]}" "${GRAPH_EXTRA[@]}"
                else
                    LAUNCH_FLAGS=("${COMMON_FLAGS[@]}" --no-mmap)
                    if (( DRY_RUN )); then print_cmd "${LAUNCH_FLAGS[@]}"; exit 0; fi
                    if maybe_ai_tune_launch_flags "${LAUNCH_FLAGS[@]}"; then
                        run_with_restart "${COMMON_FLAGS[@]}"
                    fi
                    run_with_restart "${LAUNCH_FLAGS[@]}"
                fi
            fi
        else
            LAUNCH_FLAGS=("${COMMON_FLAGS[@]}" --no-mmap)
            if (( DRY_RUN )); then
                print_cmd "${LAUNCH_FLAGS[@]}"
                exit 0
            fi
            if maybe_ai_tune_launch_flags "${LAUNCH_FLAGS[@]}"; then
                run_with_restart "${COMMON_FLAGS[@]}"
            fi
            run_with_restart "${LAUNCH_FLAGS[@]}"
        fi
        ;;

    moe_offload)
        # MoE expert placement and auto-tuning follows
        ;;
    *)
        echo "Error: Unknown strategy: $STRATEGY"
        exit 1
        ;;
esac

# Only MoE offload reaches here — all other strategies call run_with_restart (never returns)
[[ "$STRATEGY" != "moe_offload" ]] && exit 0

# ═══════════════════════════════════════════════════════════════
# Section 8: MoE Expert Placement & Auto-Tuning
# ═══════════════════════════════════════════════════════════════

# Short-circuit if the user already specified --n-cpu-moe N: they know their
# setup. Skip the full -ot placement math (which would conflict with their
# flag anyway) and go straight to launch. Both `-ncmoe N` and `--n-cpu-moe N`
# forms are recognized.
USER_NCPUMOE=""
_prev=""
for _f in "${EXTRA_LLAMA_FLAGS[@]:-}"; do
    if [[ "$_prev" == "--n-cpu-moe" || "$_prev" == "-ncmoe" ]]; then
        USER_NCPUMOE="$_f"
        break
    fi
    _prev="$_f"
done
if [[ -n "$USER_NCPUMOE" ]]; then
    echo ""
    echo "User-supplied --n-cpu-moe ${USER_NCPUMOE} detected — skipping MoE placement."
    echo "  Launching directly with your flag (expert-layer tuning is your responsibility)."
    if (( DRY_RUN )); then
        print_cmd "${COMMON_FLAGS[@]}"
        exit 0
    fi
    if (( DO_AI_TUNE )); then
        TUNE_EXTRA_FIXED=()
        ai_tune
    fi
    run_with_restart "${COMMON_FLAGS[@]}"
fi

mkdir -p "$CACHE_DIR"
CACHE_KEY_INPUT="$(placement_cache_key_input)"
CACHE_KEY=$(printf '%s\n' "$CACHE_KEY_INPUT" | md5sum | awk '{print $1}')
CACHE_FILE="$CACHE_DIR/${CACHE_KEY}.conf"

load_placement_cache_file() {
    local file="$1" line key value
    unset CACHED_GPU_ASSIGNMENTS CACHED_NCPUMOE CACHED_BATCH CACHED_UBATCH CACHED_PARALLEL CACHED_KVUNIFIED CACHED_MMAP
    while IFS= read -r line || [[ -n "$line" ]]; do
        [[ -z "$line" || "$line" == \#* ]] && continue
        key="${line%%=*}"
        value="${line#*=}"
        [[ "$value" == \"*\" ]] || return 1
        value="${value:1:${#value}-2}"
        case "$key" in
            CACHED_GPU_ASSIGNMENTS)
                [[ "$value" =~ ^[0-9:\ ]*$ ]] || return 1
                CACHED_GPU_ASSIGNMENTS="$value" ;;
            CACHED_NCPUMOE)
                [[ "$value" =~ ^[0-9]+$ ]] || return 1
                CACHED_NCPUMOE="$value" ;;
            CACHED_BATCH)
                [[ "$value" =~ ^[0-9]+$ ]] || return 1
                CACHED_BATCH="$value" ;;
            CACHED_UBATCH)
                [[ "$value" =~ ^[0-9]+$ ]] || return 1
                CACHED_UBATCH="$value" ;;
            CACHED_PARALLEL)
                [[ "$value" =~ ^[0-9]+$ ]] || return 1
                CACHED_PARALLEL="$value" ;;
            CACHED_KVUNIFIED)
                [[ "$value" =~ ^[0-9]+$ ]] || return 1
                CACHED_KVUNIFIED="$value" ;;
            CACHED_MMAP)
                [[ "$value" =~ ^[0-9]+$ ]] || return 1
                CACHED_MMAP="$value" ;;
            *)
                return 1 ;;
        esac
    done < "$file"
}

# Per-layer expert size from GGUF tensor data (fallback: estimate 90%)
if (( EXPERT_BYTES > 0 )); then
    EXPERT_TOTAL_MB=$(( EXPERT_BYTES / 1048576 ))
    NON_EXPERT_TOTAL_MB=$(( NON_EXPERT_BYTES / 1048576 ))
    EXPERT_PER_LAYER_MB=$(( EXPERT_TOTAL_MB / LAYER_COUNT ))
    EXPERT_PCT=$(( EXPERT_TOTAL_MB * 100 / TOTAL_SIZE_MB ))
    echo "Expert size per layer: ${EXPERT_PER_LAYER_MB}MB (${EXPERT_PCT}% expert, from GGUF tensors)"
else
    EXPERT_TOTAL_MB=$(awk "BEGIN {printf \"%.0f\", $TOTAL_SIZE_MB * 0.90}")
    EXPERT_PER_LAYER_MB=$(awk "BEGIN {printf \"%.0f\", $EXPERT_TOTAL_MB / $LAYER_COUNT}")
    echo "Expert size per layer: ~${EXPERT_PER_LAYER_MB}MB (estimated 90%, no tensor data)"
fi

# KV_TOTAL_MB already set in Section 4 after KV type selection

# Check cached config
if [[ -f "$CACHE_FILE" && "$RETUNE" == "0" ]]; then
    echo ""
    echo "Using cached config: $CACHE_FILE"
    # Allow CACHED_GPU_ASSIGNMENTS (-ot path), CACHED_NCPUMOE (recovery path),
    # and CACHED_MMAP (Phase 2 mmap opt-in so we don't forget user consent).
    if grep -qvE '^(#.*|CACHED_GPU_ASSIGNMENTS="[0-9: ]*"|CACHED_(NCPUMOE|BATCH|UBATCH|PARALLEL|KVUNIFIED|MMAP)="[0-9]+"|[[:space:]]*)$' "$CACHE_FILE"; then
        echo "WARNING: Cache file contains unexpected content, ignoring."
        rm -f "$CACHE_FILE"
    elif ! load_placement_cache_file "$CACHE_FILE"; then
        echo "WARNING: Cache file failed validation, ignoring."
        rm -f "$CACHE_FILE"
    else
        :
    fi
fi

# Recovered --n-cpu-moe cache: apply and launch directly
if [[ -f "$CACHE_FILE" && "$RETUNE" == "0" && -n "${CACHED_NCPUMOE:-}" ]]; then
    echo "  Recovered config: --n-cpu-moe ${CACHED_NCPUMOE} -b ${CACHED_BATCH:-1024} -ub ${CACHED_UBATCH:-512} --parallel ${CACHED_PARALLEL:-2}"
    # Strip batch/parallel from COMMON_FLAGS (we're overriding)
    FILTERED=()
    skip_next=0
    for f in "${COMMON_FLAGS[@]}"; do
        if (( skip_next )); then skip_next=0; continue; fi
        case "$f" in
            -b|-ub|--parallel) skip_next=1; continue ;;
        esac
        FILTERED+=("$f")
    done
    COMMON_FLAGS=("${FILTERED[@]}" -b "${CACHED_BATCH:-1024}" -ub "${CACHED_UBATCH:-512}" --parallel "${CACHED_PARALLEL:-2}" --n-cpu-moe "$CACHED_NCPUMOE")
    [[ "${CACHED_KVUNIFIED:-0}" == "1" ]] && COMMON_FLAGS+=(--kv-unified)
    if (( DRY_RUN )); then
        print_cmd "${COMMON_FLAGS[@]}"
        exit 0
    fi
    run_with_restart "${COMMON_FLAGS[@]}"
fi

if [[ -f "$CACHE_FILE" && "$RETUNE" == "0" && -n "${CACHED_GPU_ASSIGNMENTS:-}" ]]; then
    # Validate cached config against current VRAM
    CACHE_VALID=1
    OT_ARGS=()
    for assignment in $CACHED_GPU_ASSIGNMENTS; do
        IFS=: read -r ci cs cc <<< "$assignment"
        OT_ARGS+=("$ci" "$cs" "$cc")
        # Check this GPU has enough VRAM for assigned layers + its share of KV cache
        layer_mb=$(( cc * EXPERT_PER_LAYER_MB ))
        kv_share_mb=$(( KV_TOTAL_MB * cc / LAYER_COUNT + COMPUTE_PER_GPU_MB ))  # proportional KV + compute
        needed=$(( layer_mb + kv_share_mb ))
        # Find free VRAM for this CUDA index
        for gi in $(seq 0 $(( GPU_COUNT - 1 ))); do
            if [[ "${GPU_INDEX[$gi]}" == "$ci" ]]; then
                if (( needed > GPU_VRAM_FREE[$gi] )); then
                    echo "  WARNING: GPU${ci} needs ${needed}MB but only ${GPU_VRAM_FREE[$gi]}MB free"
                    CACHE_VALID=0
                fi
                break
            fi
        done
        echo "  GPU${ci}: ${cc} layers (starting at block ${cs})"
    done

    if (( CACHE_VALID )); then
        # Restore Phase-2 mmap opt-in from cache (CACHED_MMAP=1 means
        # "user said yes to paging on demand last time"). Fall back to
        # legacy --no-mmap for older caches without this key.
        CACHED_MMAP_FLAGS=(--no-mmap)
        if [[ "${CACHED_MMAP:-0}" == "1" ]]; then
            CACHED_MMAP_FLAGS=()
            echo "  Cache says: mmap path (Phase 2 opt-in remembered)"
        fi
        OT_STRING=$(build_ot_string "${OT_ARGS[@]}")
        LAUNCH_FLAGS=("${COMMON_FLAGS[@]}" "${CACHED_MMAP_FLAGS[@]}" -ot "$OT_STRING")
        if (( DRY_RUN )); then
            print_cmd "${LAUNCH_FLAGS[@]}"
            exit 0
        fi
        # AI Tune with cached MoE placement locked
        if (( DO_AI_TUNE )); then
            echo ""
            echo "MoE placement loaded from cache. Running AI Tune with placement locked..."
            COMMON_FLAGS+=("${CACHED_MMAP_FLAGS[@]}" -ot "$OT_STRING")
            TUNE_EXTRA_FIXED=("${CACHED_MMAP_FLAGS[@]}" -ot "$OT_STRING")
            ai_tune
            kill_server "$RUNNING_PID"
            run_with_restart "${COMMON_FLAGS[@]}"
        fi
        run_with_restart "${LAUNCH_FLAGS[@]}"
    else
        echo "  Cached config invalid for current VRAM — retuning..."
        rm -f "$CACHE_FILE"
    fi
fi

# Calculate initial conservative placement
# Budget: GPUs get decreasing % based on priority (fastest gets most headroom for compute)
# Reserve VRAM on primary GPU for KV cache + batch buffers + compute scratch
declare -a LAYERS_PER_GPU
BUDGET_PCTS=(70 55 50 45 40 35 30 25)  # Decreasing budget for lower-priority GPUs
# Bump sequence for redistribution. Caps at 98 because large-MoE layers can be
# almost the full per-GPU VRAM (e.g. Kimi-K2 IQ3_K: 24GB layer on 26GB A40).
REDIST_BUMPS=(80 85 90 95 98)
NEXT_LAYER=0
TOTAL_GPU_LAYERS=0

# Per-GPU VRAM budget: each layer on a GPU costs expert + non-expert + KV
# With -ngl 999, non-expert tensors (attention, norms) also go to GPUs
# Primary GPU (-mg 0) also gets global tensors (embeddings, output head)
KV_PER_LAYER_MB=$(( KV_TOTAL_MB / LAYER_COUNT ))
NON_EXPERT_RAM_MB=${NON_EXPERT_TOTAL_MB:-$(( TOTAL_SIZE_MB - EXPERT_TOTAL_MB ))}
NON_EXPERT_PER_LAYER_MB=$(( NON_EXPERT_RAM_MB / LAYER_COUNT ))
# COMPUTE_PER_GPU_MB defined in constants section at top
MAIN_GPU_EXTRA_MB=2048  # embeddings + output head on primary GPU (-mg 0)
COST_PER_LAYER_MB=$(( EXPERT_PER_LAYER_MB + KV_PER_LAYER_MB + NON_EXPERT_PER_LAYER_MB ))
echo "  Per-layer cost: ${EXPERT_PER_LAYER_MB}MB experts + ${NON_EXPERT_PER_LAYER_MB}MB attn/norm + ${KV_PER_LAYER_MB}MB KV = ${COST_PER_LAYER_MB}MB"

for i in $(seq 0 $(( GPU_COUNT - 1 ))); do
    gi=${GPU_ORDER[$i]}
    pct=${BUDGET_PCTS[$i]:-20}
    # Primary GPU needs extra headroom for global tensors (embeddings, output)
    local_overhead=$COMPUTE_PER_GPU_MB
    (( i == 0 )) && local_overhead=$(( COMPUTE_PER_GPU_MB + MAIN_GPU_EXTRA_MB ))
    available_mb=$(( GPU_VRAM_FREE[$gi] - local_overhead ))
    (( available_mb < 0 )) && available_mb=0
    budget_mb=$(( available_mb * pct / 100 ))
    layers=0
    if (( COST_PER_LAYER_MB > 0 )); then
        layers=$(( budget_mb / COST_PER_LAYER_MB ))
    fi
    # Cap to remaining layers
    remain=$(( LAYER_COUNT - NEXT_LAYER ))
    (( layers > remain )) && layers=$remain
    LAYERS_PER_GPU[$gi]=$layers
    NEXT_LAYER=$(( NEXT_LAYER + layers ))
    TOTAL_GPU_LAYERS=$(( TOTAL_GPU_LAYERS + layers ))
done

LAYERS_CPU=$(( LAYER_COUNT - TOTAL_GPU_LAYERS ))

# RAM safety check — component-based estimate (see issue #11).
# The old "15% of CPU_EXPERT_MB" padding scaled linearly with model size, which
# invented ~221GB of phantom overhead on a 1.5TB-RAM server trying to load a
# 460GB MoE. Non-weight RAM overhead is mostly CONSTANT, not a percentage:
#   ggml compute scratch:  ~2GB  (graph exec buffers, fixed)
#   CUDA host pinned:      ~1GB  (output + transfer buffers, fixed)
#   mmap page tables:      ~0.2% of model size on x86_64 (8 bytes per 4KB page)
#   CPU activation buffer: ubatch × (embd + ffn_dim) × 4 × 2-layer peak
# ggml reuses scratch across layers so the per-layer activation peaks at ~2
# layers' worth, not batch × n_layer.
CPU_EXPERT_MB=$(( LAYERS_CPU * EXPERT_PER_LAYER_MB ))
CUDA_HOST_MB=1024
GRAPH_SCRATCH_MB=2048
MMAP_PT_MB=$(( TOTAL_SIZE_MB / 500 ))
# Effective FFN dim: MoE uses top-k × expert_ff (+ shared_ff); dense uses ff.
# MLA adds compressed q/kv lora projections to per-layer activations.
if (( EMBEDDING_LENGTH > 0 )); then
    if (( EXPERT_COUNT > 0 && EXPERT_USED_COUNT > 0 && EXPERT_FF > 0 )); then
        _act_ffn=$(( EXPERT_USED_COUNT * EXPERT_FF ))
        (( EXPERT_SHARED_FF > 0 )) && _act_ffn=$(( _act_ffn + EXPERT_SHARED_FF ))
    else
        _act_ffn=$FEED_FORWARD_LENGTH
    fi
    (( KV_LORA_RANK > 0 )) && _act_ffn=$(( _act_ffn + KV_LORA_RANK + Q_LORA_RANK ))
    CPU_ACT_MB=$(( UBATCH * (EMBEDDING_LENGTH + _act_ffn) * 4 * 2 / 1048576 ))
    (( CPU_ACT_MB < 64 )) && CPU_ACT_MB=64
else
    CPU_ACT_MB=512   # fallback when arch metadata is missing
fi
RAM_OVERHEAD_MB=$(( CUDA_HOST_MB + GRAPH_SCRATCH_MB + MMAP_PT_MB + CPU_ACT_MB ))
RAM_NEEDED=$(( CPU_EXPERT_MB + RAM_OVERHEAD_MB ))

# Phase 1: If CPU layers would OOM, push layers to GPUs one at a time (least disruption)
if (( RAM_NEEDED > RAM_AVAIL_MB && LAYERS_CPU > 0 && GPU_COUNT > 0 )); then
    echo "WARNING: Conservative placement needs ${RAM_NEEDED}MB RAM but only ${RAM_AVAIL_MB}MB available"
    echo "  Redistributing layers to GPUs to fit in RAM..."

    # Recalculate with increasing GPU budgets until CPU fits in RAM
    for bump in "${REDIST_BUMPS[@]}"; do
        NEXT_LAYER=0
        TOTAL_GPU_LAYERS=0
        # Build budget array: primary GPU gets bump%, others get slightly less
        for i in $(seq 0 $(( GPU_COUNT - 1 ))); do
            gi=${GPU_ORDER[$i]}
            pct=$(( bump - i * 5 ))
            (( pct < 30 )) && pct=30
            local_overhead=$COMPUTE_PER_GPU_MB
            (( i == 0 )) && local_overhead=$(( COMPUTE_PER_GPU_MB + MAIN_GPU_EXTRA_MB ))
            available_mb=$(( GPU_VRAM_FREE[$gi] - local_overhead ))
            (( available_mb < 0 )) && available_mb=0
            budget_mb=$(( available_mb * pct / 100 ))
            layers=0
            if (( COST_PER_LAYER_MB > 0 )); then
                layers=$(( budget_mb / COST_PER_LAYER_MB ))
                # Hard-max floor: when per-layer cost is near per-GPU VRAM
                # (e.g. Kimi-K2 IQ3_K with 24GB layer on 26GB A40), pct-gated
                # budget rounds to 0 layers even though 1 would physically fit.
                # On the final bump pass, allow up to the raw hard-fit count.
                if (( layers == 0 && bump == ${REDIST_BUMPS[-1]} )); then
                    layers=$(( available_mb / COST_PER_LAYER_MB ))
                fi
            fi
            remain=$(( LAYER_COUNT - NEXT_LAYER ))
            (( layers > remain )) && layers=$remain
            LAYERS_PER_GPU[$gi]=$layers
            NEXT_LAYER=$(( NEXT_LAYER + layers ))
            TOTAL_GPU_LAYERS=$(( TOTAL_GPU_LAYERS + layers ))
        done
        LAYERS_CPU=$(( LAYER_COUNT - TOTAL_GPU_LAYERS ))
        CPU_EXPERT_MB=$(( LAYERS_CPU * EXPERT_PER_LAYER_MB ))
        RAM_NEEDED=$(( CPU_EXPERT_MB + RAM_OVERHEAD_MB ))
        if (( RAM_NEEDED <= RAM_AVAIL_MB )); then
            echo "  Adjusted GPU budget to ${bump}% — ${LAYERS_CPU} CPU layers (${RAM_NEEDED}MB RAM)"
            break
        fi
    done
fi

# mmap strategy for MoE: historically the launcher forced --no-mmap for every
# MoE launch so that the CPU-resident expert tensors had a predictable resident
# footprint. That fails hard when the model's virtual size exceeds physical
# RAM even if the *working set* would fit (issue #11, #7). The fix: default
# to --no-mmap for the familiar path, but let Phase 2 switch to mmap on
# demand when the kernel can page cold experts in/out.
#
# MMAP_PATH   = 1 means mmap will be used for the launch (no --no-mmap flag)
# MMAP_PATH   = 0 means --no-mmap will be passed (full resident footprint)
# USER_NO_MMAP was detected earlier (Section 7 header).
MMAP_PATH=0
MOE_MMAP_FLAGS=(--no-mmap)

# Phase 2: If still over RAM after maxing GPU budgets, warn but allow continue
# when mmap can reasonably handle the gap. The RAM_NEEDED estimate counts the
# full virtual size of CPU-resident expert tensors, but with mmap (default)
# the kernel pages cold experts out on demand. Only the hot working set needs
# to physically fit. Safe-to-proceed floor: enough RAM for compute buffers +
# a handful of hot layers' worth of expert working set.
if (( RAM_NEEDED > RAM_AVAIL_MB )); then
    # Working-set floor: compute buffers + ~8 hot expert layers + KV overhead.
    # This is what actually needs to be resident during inference on the mmap
    # path — most layers sit in the page cache and are paged in on demand.
    WORKING_SET_FLOOR=$(( RAM_OVERHEAD_MB + 8 * EXPERT_PER_LAYER_MB ))
    SHORTFALL=$(( RAM_NEEDED - RAM_AVAIL_MB ))
    echo ""
    if (( USER_NO_MMAP )); then
        # User opted out of mmap → full resident footprint is mandatory.
        echo "ERROR: --no-mmap requested, but full resident size exceeds available RAM."
        echo "  With --no-mmap every CPU expert byte must stay pinned in RAM."
        echo "  Full resident size:    ${RAM_NEEDED}MB  (CPU experts + overhead)"
        echo "  RAM available:         ${RAM_AVAIL_MB}MB"
        echo "  Shortfall:             ${SHORTFALL}MB"
        echo "  Remove --no-mmap to let the kernel page experts on demand,"
        echo "  or use more GPU VRAM / a smaller quantization."
        exit 1
    fi
    echo "NOTE: Full resident MoE size would exceed available RAM."
    echo "      (On the mmap path this is informational — the kernel pages"
    echo "       cold experts in/out and only the working set needs to fit.)"
    echo ""
    echo "  Breakdown:"
    echo "    CPU expert layers:     ${LAYERS_CPU} layers (${CPU_EXPERT_MB}MB)"
    echo "    ggml compute scratch:  ${GRAPH_SCRATCH_MB}MB"
    echo "    CUDA host buffers:     ${CUDA_HOST_MB}MB"
    echo "    mmap page tables:      ${MMAP_PT_MB}MB  (~0.2% of model size)"
    echo "    CPU activation buffer: ${CPU_ACT_MB}MB  (ubatch=${UBATCH} × (embd+ffn) peak)"
    echo "    ───────────────────────────────────"
    echo "    Full resident size:    ${RAM_NEEDED}MB"
    echo "    RAM available:         ${RAM_AVAIL_MB}MB"
    echo "    Shortfall (resident):  ${SHORTFALL}MB"
    echo ""
    if (( RAM_AVAIL_MB >= WORKING_SET_FLOOR )); then
        echo "  Working set on mmap path: ~${WORKING_SET_FLOOR}MB (compute + 8 hot layers)"
        echo "  — that fits in your ${RAM_AVAIL_MB}MB of available RAM."
        echo ""
        if [[ -t 0 ]] && (( ${LLM_ASSUME_YES:-0} == 0 )); then
            read -r -p "  Continue and let mmap page cold experts on demand? [y/N] " _reply
            _reply="${_reply:-n}"
            if [[ ! "$_reply" =~ ^[Yy] ]]; then
                echo "  Aborted by user."
                exit 1
            fi
        else
            echo "  Non-interactive (or LLM_ASSUME_YES=1) — continuing."
        fi
        echo "  Proceeding with mmap paging enabled (no --no-mmap)."
        MMAP_PATH=1
        MOE_MMAP_FLAGS=()   # drop any --no-mmap we might have queued
    else
        echo "  Working set on mmap path would be ~${WORKING_SET_FLOOR}MB, still above"
        echo "  ${RAM_AVAIL_MB}MB available. Options:"
        echo "  1. Add more system RAM"
        echo "  2. Use a smaller quantization (IQ3 → IQ2)"
        echo "  3. Use a smaller model"
        exit 1
    fi
fi

# Build -ot string
OT_ARGS=()
NEXT_LAYER=0
echo ""
echo "Expert placement (conservative):"
for i in $(seq 0 $(( GPU_COUNT - 1 ))); do
    gi=${GPU_ORDER[$i]}
    layers=${LAYERS_PER_GPU[$gi]}
    if (( layers > 0 )); then
        OT_ARGS+=("${GPU_INDEX[$gi]}" "$NEXT_LAYER" "$layers")
        echo "  GPU${GPU_INDEX[$gi]} (${GPU_NAME[$gi]}): ${layers} layers (blk ${NEXT_LAYER}-$((NEXT_LAYER + layers - 1)))"
        NEXT_LAYER=$(( NEXT_LAYER + layers ))
    fi
done
echo "  CPU (RAM): ${LAYERS_CPU} layers (~${CPU_EXPERT_MB}MB)"

OT_STRING=$(build_ot_string "${OT_ARGS[@]}")

if (( DRY_RUN )); then
    print_cmd "${COMMON_FLAGS[@]}" "${MOE_MMAP_FLAGS[@]}" -ot "$OT_STRING"
    exit 0
fi

# ── Auto-tuning loop ──
echo ""
echo "Starting server (conservative)..."
if try_start "${MOE_MMAP_FLAGS[@]}" -ot "$OT_STRING"; then
    echo "  Server healthy (PID $RUNNING_PID)"

    # Measure actual VRAM after load (server is already healthy, VRAM is settled)
    echo "  Measuring VRAM headroom..."
    declare -a ACTUAL_FREE
    for i in $(seq 0 $(( GPU_COUNT - 1 ))); do
        gi=${GPU_ORDER[$i]}
        # CRITICAL: trailing `|| true` is required under `set -euo pipefail`.
        # Without it, a transient nvidia-smi failure (common on cloud/datacenter
        # rigs right after loading a huge model — driver is still settling)
        # causes the whole pipeline to return non-zero via pipefail, which makes
        # the `var=$(...)` assignment silently abort the script — no error, no
        # cleanup, orphaned server. See issue #11 and #7.
        raw_free=$(nvidia-smi --query-gpu=memory.free --format=csv,noheader,nounits -i "${GPU_INDEX[$gi]}" 2>/dev/null | tr -d ' ' || true)
        # Fall back to pre-launch free minus an estimate of what we just loaded
        # so the script doesn't blow up on empty-string arithmetic under nounset.
        if [[ ! "$raw_free" =~ ^[0-9]+$ ]]; then
            estimated_used=$(( LAYERS_PER_GPU[$gi] * COST_PER_LAYER_MB ))
            raw_free=$(( GPU_VRAM_FREE[$gi] - estimated_used ))
            (( raw_free < 0 )) && raw_free=0
            log "  GPU${GPU_INDEX[$gi]}: nvidia-smi free readback failed, estimating ${raw_free}MB"
        fi
        ACTUAL_FREE[$gi]=$raw_free
        log "  GPU${GPU_INDEX[$gi]}: ${ACTUAL_FREE[$gi]}MB free after load"
    done

    # Calculate extra layers per GPU
    # IMPORTANT: ACTUAL_FREE doesn't include KV cache yet (allocated on first prompt)
    # Subtract current KV share per GPU before calculating extra capacity
    SAFETY_MB=$COMPUTE_PER_GPU_MB
    TOTAL_EXTRA=0
    declare -a EXTRA_PER_GPU
    for i in $(seq 0 $(( GPU_COUNT - 1 ))); do
        gi=${GPU_ORDER[$i]}
        extra=0
        # Subtract KV cache that will be allocated for layers already on this GPU
        current_kv=$(( LAYERS_PER_GPU[$gi] * KV_PER_LAYER_MB ))
        usable_free=$(( ACTUAL_FREE[$gi] - current_kv - SAFETY_MB ))
        (( usable_free < 0 )) && usable_free=0
        if (( COST_PER_LAYER_MB > 0 )); then
            extra=$(( usable_free / COST_PER_LAYER_MB ))
        fi
        (( extra < 0 )) && extra=0
        EXTRA_PER_GPU[$gi]=$extra
        (( TOTAL_EXTRA += extra ))
    done

    # Apply extras (priority order), cap to remaining CPU layers
    if (( TOTAL_EXTRA > 0 && LAYERS_CPU > 0 )); then
        remaining_cpu=$LAYERS_CPU
        for i in $(seq 0 $(( GPU_COUNT - 1 ))); do
            gi=${GPU_ORDER[$i]}
            add=$(( EXTRA_PER_GPU[$gi] < remaining_cpu ? EXTRA_PER_GPU[$gi] : remaining_cpu ))
            LAYERS_PER_GPU[$gi]=$(( LAYERS_PER_GPU[$gi] + add ))
            remaining_cpu=$(( remaining_cpu - add ))
            (( remaining_cpu <= 0 )) && break
        done
        LAYERS_CPU=$remaining_cpu
        TOTAL_GPU_LAYERS=$(( LAYER_COUNT - LAYERS_CPU ))

        # Rebuild -ot string with optimized placement
        OT_ARGS=()
        NEXT_LAYER=0
        echo ""
        echo "Optimized placement:"
        for i in $(seq 0 $(( GPU_COUNT - 1 ))); do
            gi=${GPU_ORDER[$i]}
            layers=${LAYERS_PER_GPU[$gi]}
            if (( layers > 0 )); then
                OT_ARGS+=("${GPU_INDEX[$gi]}" "$NEXT_LAYER" "$layers")
                echo "  GPU${GPU_INDEX[$gi]} (${GPU_NAME[$gi]}): ${layers} layers (blk ${NEXT_LAYER}-$((NEXT_LAYER + layers - 1)))"
                NEXT_LAYER=$(( NEXT_LAYER + layers ))
            fi
        done
        echo "  CPU (RAM): ${LAYERS_CPU} layers"

        OT_STRING=$(build_ot_string "${OT_ARGS[@]}")

        # Restart with optimized config
        kill_server "$RUNNING_PID"
        echo ""
        echo "Restarting with optimized config (Gentle Load enabled)..."
        # --mlock pins CPU-resident weights so they don't get swapped — but on
        # WSL2 that pinning can freeze the Windows host, so we skip it there
        # and let the Linux page cache handle it. Also skip when we're on the
        # mmap path (Phase 2 promise): mlock would pin every mmap'd page and
        # defeat the paging-on-demand the user just consented to.
        MLOCK_ARGS=()
        if (( MMAP_PATH )); then
            log "  mmap path active — skipping --mlock (would pin all pages)"
        elif (( IS_WSL2 )); then
            log "  WSL2 detected — skipping --mlock to avoid host freeze"
        else
            MLOCK_ARGS=(--mlock)
        fi
        if ! try_start "${MOE_MMAP_FLAGS[@]}" "${MLOCK_ARGS[@]}" -ot "$OT_STRING"; then
            echo "  Optimized config failed — retrying without mlock..."
            kill_server ""
            if ! try_start "${MOE_MMAP_FLAGS[@]}" -ot "$OT_STRING"; then
                echo "  FAILED: Could not start server. Check $SERVER_LOG"
                exit 1
            fi
        fi
    else
        echo "  Conservative config is already optimal (GPUs full)"
    fi

    # Save to cache
    CACHED_GPU_ASSIGNMENTS=""
    NEXT_LAYER=0
    for i in $(seq 0 $(( GPU_COUNT - 1 ))); do
        gi=${GPU_ORDER[$i]}
        layers=${LAYERS_PER_GPU[$gi]}
        if (( layers > 0 )); then
            CACHED_GPU_ASSIGNMENTS+="${GPU_INDEX[$gi]}:${NEXT_LAYER}:${layers} "
            NEXT_LAYER=$(( NEXT_LAYER + layers ))
        fi
    done

    cat > "$CACHE_FILE" <<CEOF
# Auto-tuned config for $MODEL_NAME
# Generated: $(date)
# Total layers: $LAYER_COUNT, Experts: $EXPERT_COUNT
CACHED_GPU_ASSIGNMENTS="$CACHED_GPU_ASSIGNMENTS"
CACHED_MMAP="${MMAP_PATH}"
CEOF

    TOTAL_GPU_LAYERS=$(( LAYER_COUNT - LAYERS_CPU ))
    echo ""
    echo "═══════════════════════════════════════════"
    echo "  Model: $MODEL_NAME"
    echo "  Size: ${TOTAL_SIZE_GB}GB | Layers: $LAYER_COUNT | Experts: $EXPERT_COUNT"
    echo "  GPU layers: $TOTAL_GPU_LAYERS | CPU layers: $LAYERS_CPU"
    echo "  Context: $CTX_SIZE | Port: $PORT"
    echo "  Config cached: $CACHE_FILE"
    echo "═══════════════════════════════════════════"

    # AI Tune on top of MoE placement: optimize flags with placement locked
    if (( DO_AI_TUNE )); then
        echo ""
        echo "MoE placement complete. Running AI Tune with placement locked..."
        COMMON_FLAGS+=("${MOE_MMAP_FLAGS[@]}" -ot "$OT_STRING")
        TUNE_EXTRA_FIXED=("${MOE_MMAP_FLAGS[@]}" -ot "$OT_STRING")
        ai_tune
    fi

    # Kill the tuning server, restart via the crash-safe loop
    kill_server "$RUNNING_PID"
    # If ai-tune already added placement flags to COMMON_FLAGS, don't duplicate
    if (( DO_AI_TUNE )); then
        run_with_restart "${COMMON_FLAGS[@]}"
    else
        run_with_restart "${COMMON_FLAGS[@]}" "${MOE_MMAP_FLAGS[@]}" -ot "$OT_STRING"
    fi
else
    echo ""
    echo "  Conservative -ot placement failed — trying tighter recovery config..."
    tail -5 "$SERVER_LOG" 2>/dev/null | sed 's/^/    /'
    kill_server ""

    # Recovery: use --n-cpu-moe (experts-only offload, tighter VRAM packing)
    # with reduced batch + kv-unified + parallel=2 (matches manual-tune recipes
    # that work when per-layer -ot placement hits compute-buffer fragmentation).
    # See issue #8: RTX 4060 Ti 16GB + Qwen3.5-35B-A3B at 64k.
    NCPUMOE_SUPPORTED=0
    KVUNIFIED_SUPPORTED=0
    if "$LLAMA_SERVER" --help 2>&1 | grep -qE "^ *-ncmoe.*--n-cpu-moe\b"; then
        NCPUMOE_SUPPORTED=1
    fi
    if "$LLAMA_SERVER" --help 2>&1 | grep -qE "^ *-kvu.*--kv-unified\b"; then
        KVUNIFIED_SUPPORTED=1
    fi

    RECOVERED=0
    if (( NCPUMOE_SUPPORTED )); then
        # Strip incompatible flags from COMMON_FLAGS (we're replacing placement)
        RECOVERY_COMMON=()
        skip_next=0
        for f in "${COMMON_FLAGS[@]}"; do
            if (( skip_next )); then skip_next=0; continue; fi
            case "$f" in
                -b|-ub) skip_next=1; continue ;;
                -ot|--override-tensor) skip_next=1; continue ;;
                --parallel) skip_next=1; continue ;;
            esac
            RECOVERY_COMMON+=("$f")
        done
        RECOVERY_COMMON+=(-b 1024 -ub 512 --parallel 2)
        (( KVUNIFIED_SUPPORTED )) && RECOVERY_COMMON+=(--kv-unified)

        # Swap COMMON_FLAGS so try_start uses the recovery base
        SAVED_COMMON_FLAGS=("${COMMON_FLAGS[@]}")
        COMMON_FLAGS=("${RECOVERY_COMMON[@]}")

        # Search upward from LAYERS_CPU; more CPU offload = less VRAM pressure
        # Cap at LAYER_COUNT-2 (need at least a couple layers on GPU for speed)
        START_N=$LAYERS_CPU
        (( START_N < 1 )) && START_N=1
        MAX_N=$(( LAYER_COUNT - 2 ))
        (( MAX_N < START_N )) && MAX_N=$START_N
        for N in $(seq "$START_N" 2 "$MAX_N"); do
            echo "  Recovery attempt: --n-cpu-moe $N (b=1024 ub=512 parallel=2$( (( KVUNIFIED_SUPPORTED )) && echo ' kv-unified'))"
            if try_start --n-cpu-moe "$N"; then
                RECOVERED=1
                echo "  Server healthy with --n-cpu-moe $N"
                # Persist recovered config so next launch goes straight here
                COMMON_FLAGS+=(--n-cpu-moe "$N")
                OT_STRING=""
                LAYERS_CPU=$N
                # Cache the recovered mode so next launch skips the failed -ot path
                cat > "$CACHE_FILE" <<CEOF
# Auto-tuned config for $MODEL_NAME (recovered via --n-cpu-moe)
# Generated: $(date)
# Total layers: $LAYER_COUNT, Experts: $EXPERT_COUNT
CACHED_NCPUMOE="$N"
CACHED_BATCH="1024"
CACHED_UBATCH="512"
CACHED_PARALLEL="2"
CACHED_KVUNIFIED="$KVUNIFIED_SUPPORTED"
CEOF
                break
            fi
            kill_server ""
        done
    fi

    if (( ! RECOVERED )); then
        echo ""
        echo "FAILED: Could not start server even with conservative config."
        echo "Check $SERVER_LOG for details."
        tail -20 "$SERVER_LOG" 2>/dev/null
        echo ""
        echo "═══ Model doesn't fit ═══"
        echo "  Model needs: ~${VRAM_NEEDED_MB}MB (with overhead)"
        echo "  Available:   ~$(( TOTAL_VRAM_MB + RAM_AVAIL_MB ))MB (GPU + RAM)"
        echo ""
        echo "  Options:"
        echo "  1. Use a smaller quantization (e.g., Q4 → IQ3, IQ3 → IQ2)"
        echo "  2. Reduce context size: --ctx-size 16384 or --ctx-size 8192"
        echo "  3. Use a smaller model (fewer parameters or MoE with fewer active)"
        if (( GPU_COUNT > 0 )); then
            echo "  4. Add more RAM (cheapest upgrade for MoE expert offload)"
        else
            echo "  4. Add a GPU (even a used RTX 3060 12GB helps significantly)"
        fi
        echo ""
        exit 1
    fi

    # Recovered path: hand off to the crash-safe loop
    kill_server "$RUNNING_PID"
    run_with_restart "${COMMON_FLAGS[@]}"
fi
